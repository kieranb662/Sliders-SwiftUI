{"hierarchy":{"paths":[["doc:\/\/Sliders\/documentation\/Sliders"]]},"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"title":"Essentials","anchor":"Essentials","identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/LSlider","doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","doc:\/\/Sliders\/documentation\/Sliders\/LSliderConfiguration","doc:\/\/Sliders\/documentation\/Sliders\/TickMarkSpacing"]},{"title":"Tutorials","anchor":"Tutorials","identifiers":["doc:\/\/Sliders\/tutorials\/LSlider-Tutorials"]}],"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true},{"type":"text","text":" is a fully stylable linear slider that fits itself to its container at any angle. Unlike the built-in "},{"type":"codeVoice","code":"Slider"},{"type":"text","text":", you can place an "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true},{"type":"text","text":" horizontally, vertically, or at any diagonal and it will automatically scale its track to the available space. Tick marks can be added and will optionally fire haptic feedback as the thumb passes over them."}]},{"anchor":"Parameters","text":"Parameters","type":"heading","level":2},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Parameter","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type"}]}],[{"type":"paragraph","inlineContent":[{"text":"Default","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"value"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Binding<Double>"}]}],[{"type":"paragraph","inlineContent":[{"text":"required","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"The value the slider controls","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"range"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ClosedRange<Double>"}]}],[{"type":"paragraph","inlineContent":[{"code":"0...1","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"The minimum and maximum values"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"angle","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":"Angle","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".zero"},{"text":" (horizontal)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"The angle at which the slider is drawn","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"keepThumbInTrack","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":"Bool","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"false"}]}],[{"type":"paragraph","inlineContent":[{"text":"Constrains the thumb centre to stay within the track’s extent","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"trackThickness","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":"Double","type":"codeVoice"}]}],[{"inlineContent":[{"code":"20","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"The thickness of the track in points","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"tickMarkSpacing"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"TickMarkSpacing?"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"nil"}]}],[{"type":"paragraph","inlineContent":[{"text":"How tick marks are spaced, or ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" to hide them","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"hapticFeedbackEnabled","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":"Bool","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"true"}]}],[{"type":"paragraph","inlineContent":[{"text":"Whether crossing a tick mark triggers haptic feedback (iOS only)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"label"}]}],[{"inlineContent":[{"code":"(Double) -> some View","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":"Text","type":"codeVoice"},{"type":"text","text":" (value, 2 dp)"}]}],[{"inlineContent":[{"type":"text","text":"A view builder that receives the current value and returns the floating label displayed near the thumb"}],"type":"paragraph"}]]]},{"anchor":"Labels","text":"Labels","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A floating label is displayed just above the thumb and updates live as the thumb moves. By default it shows the current value formatted to two decimal places. Pass a custom "},{"code":"label","type":"codeVoice"},{"text":" closure to render anything:","type":"text"}]},{"code":["@State var volume = 0.5","","LSlider($volume, range: 0...100) { value in","    Label(\"\\(Int(value)) dB\", systemImage: \"speaker.wave.2\")","}",".frame(height: 60)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Use the ","type":"text"},{"type":"codeVoice","code":".labelsVisibility(_:)"},{"text":" modifier to hide the label across all sliders in a container:","type":"text"}],"type":"paragraph"},{"code":["VStack {","    LSlider($red,   range: 0...1)","    LSlider($green, range: 0...1)","    LSlider($blue,  range: 0...1)","}",".labelsVisibility(.hidden)"],"syntax":"swift","type":"codeListing"},{"text":"Basic Usage","anchor":"Basic-Usage","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A horizontal slider over a "},{"type":"codeVoice","code":"0...1"},{"type":"text","text":" range with no tick marks:"}]},{"type":"codeListing","syntax":"swift","code":["@State var volume = 0.5","","LSlider($volume, range: 0...1, keepThumbInTrack: true, trackThickness: 20)","    .frame(height: 60)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A vertical slider (90 degrees):"}]},{"type":"codeListing","syntax":"swift","code":["@State var brightness = 0.75","","LSlider($brightness, range: 0...1, angle: .degrees(90), keepThumbInTrack: true)","    .frame(width: 60, height: 200)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A diagonal slider:"}]},{"type":"codeListing","syntax":"swift","code":["@State var value = 0.5","","LSlider($value, range: 0...1, angle: .degrees(325), keepThumbInTrack: true, trackThickness: 20)","    .frame(width: 300, height: 120)"]},{"level":2,"type":"heading","text":"Tick Marks","anchor":"Tick-Marks"},{"type":"paragraph","inlineContent":[{"text":"Tick marks are controlled through the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TickMarkSpacing"},{"text":" enum. There are three cases:","type":"text"}]},{"anchor":"countn","text":"`.count(n)`","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Places exactly ","type":"text"},{"code":"n","type":"codeVoice"},{"type":"text","text":" tick marks evenly distributed across the range, including both endpoints:"}]},{"type":"codeListing","syntax":"swift","code":["@State var step = 0.5","","LSlider(","    $step,","    range: 0...1,","    keepThumbInTrack: true,","    trackThickness: 20,","    tickMarkSpacing: .count(11),","    hapticFeedbackEnabled: true",")",".frame(height: 60)"]},{"text":"`.spacing(step)`","anchor":"spacingstep","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Places a tick mark every "},{"type":"codeVoice","code":"step"},{"type":"text","text":" units across the value domain:"}]},{"syntax":"swift","code":["@State var temperature = 3.0","","LSlider(","    $temperature,","    range: 0...10,","    keepThumbInTrack: true,","    trackThickness: 20,","    tickMarkSpacing: .spacing(1),","    hapticFeedbackEnabled: true",")",".frame(height: 60)"],"type":"codeListing"},{"type":"heading","text":"`.values([...])`","level":3,"anchor":"values"},{"inlineContent":[{"type":"text","text":"Places tick marks at specific values within the range:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@State var position = 0.5","","LSlider(","    $position,","    range: 0...1,","    keepThumbInTrack: true,","    trackThickness: 20,","    tickMarkSpacing: .values([0.0, 0.25, 0.5, 0.75, 1.0]),","    hapticFeedbackEnabled: false",")",".frame(height: 60)"]},{"text":"Haptic Feedback","anchor":"Haptic-Feedback","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Haptic feedback fires each time the thumb passes over a tick mark. It is powered by "},{"type":"codeVoice","code":"CoreHaptics"},{"text":" and is available on iOS. On platforms that do not support ","type":"text"},{"code":"CoreHaptics","type":"codeVoice"},{"text":" the calls are silently ignored. To disable haptics entirely, pass ","type":"text"},{"code":"hapticFeedbackEnabled: false","type":"codeVoice"},{"text":". Haptics require tick marks to be configured; if ","type":"text"},{"code":"tickMarkSpacing","type":"codeVoice"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" no feedback is fired."}]},{"anchor":"Styling-the-Slider","text":"Styling the Slider","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Conform to ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"text":" and implement these methods:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"makeThumb(configuration:)","type":"codeVoice"},{"text":" — the draggable thumb view","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"makeTrack(configuration:)"},{"type":"text","text":" — the track and fill view"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"makeTickMark(configuration:tickValue:)","type":"codeVoice"},{"text":" — the view rendered at each tick mark position","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"makeLabel(configuration:content:)","type":"codeVoice"},{"text":" — ","type":"text"},{"inlineContent":[{"type":"text","text":"(optional, default provided)"}],"type":"emphasis"},{"type":"text","text":" wraps the label view floating above the thumb"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Apply your style using the "},{"code":"linearSliderStyle(_:)","type":"codeVoice"},{"text":" modifier on the slider or any ancestor view.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"All four methods receive an ","type":"text"},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderConfiguration","isActive":true},{"type":"text","text":" that exposes the current state of the slider:"}]},{"type":"codeListing","code":["struct LSliderConfiguration {","    let isDisabled: Bool","    let isActive: Bool","    let pctFill: Double","    let value: Double","    let angle: Angle","    let min: Double","    let max: Double","    let keepThumbInTrack: Bool","    let trackThickness: Double","    let tickMarkSpacing: TickMarkSpacing?","    let tickValues: [Double]","}"],"syntax":"swift"},{"level":3,"anchor":"Custom-Style-Example","type":"heading","text":"Custom Style Example"},{"type":"codeListing","syntax":"swift","code":["struct BarLSliderStyle: LSliderStyle {","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        RoundedRectangle(cornerRadius: 4)","            .fill(configuration.isActive ? Color.orange : Color.white)","            .frame(width: configuration.trackThickness,","                   height: configuration.trackThickness * 1.4)","            .shadow(radius: 3)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness,","                         angle: configuration.angle)","                .fill(Color(white: 0.2))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                cap: .square,","                adjustmentForThumb: adjustment \/ 2","            )","            .fill(Color.orange)","            .mask(AdaptiveLine(thickness: configuration.trackThickness,","                               angle: configuration.angle))","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration,","                      tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let distance  = abs(thumbPct - tickPct)","        let proximity = max(0, 1 - distance \/ 0.15)","","        let size    = 6.0 + 6.0 * proximity","        let opacity = 0.4 + 0.6 * proximity","","        return Rectangle()","            .fill(Color.orange.opacity(opacity))","            .frame(width: size, height: size)","            .rotationEffect(.degrees(45))","            .animation(.easeOut(duration: 0.08), value: proximity)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Apply the style:"}]},{"type":"codeListing","code":["LSlider($value, range: 0...1, keepThumbInTrack: true, trackThickness: 40,","        tickMarkSpacing: .spacing(0.1), hapticFeedbackEnabled: true)","    .linearSliderStyle(BarLSliderStyle())","    .frame(height: 60)"],"syntax":"swift"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"linearSliderStyle","type":"codeVoice"},{"text":" modifier cascades through the view hierarchy, so you can apply one style to a container and have it affect every ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"text":" inside it.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/sliders\/lsliderguide"]}],"identifier":{"url":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderGuide","interfaceLanguage":"swift"},"sections":[],"abstract":[{"type":"text","text":"A deep dive into "},{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","type":"reference"},{"type":"text","text":" — the spatially adaptive linear slider that fits its container at any angle."}],"metadata":{"role":"collectionGroup","title":"LSlider Guide","roleHeading":"API Collection","modules":[{"name":"Sliders"}]},"seeAlsoSections":[{"title":"Guides","generated":true,"identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/DoubleLSliderGuide","doc:\/\/Sliders\/documentation\/Sliders\/RSliderGuide","doc:\/\/Sliders\/documentation\/Sliders\/DoubleRSliderGuide","doc:\/\/Sliders\/documentation\/Sliders\/TrackPadGuide","doc:\/\/Sliders\/documentation\/Sliders\/RadialPadGuide","doc:\/\/Sliders\/documentation\/Sliders\/JoystickGuide","doc:\/\/Sliders\/documentation\/Sliders\/PSliderGuide","doc:\/\/Sliders\/documentation\/Sliders\/OverflowSliderGuide"],"anchor":"Guides"}],"references":{"doc://Sliders/documentation/Sliders/RSliderGuide":{"kind":"article","role":"collectionGroup","url":"\/documentation\/sliders\/rsliderguide",