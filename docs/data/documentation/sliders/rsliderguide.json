anchor":"Parameters","text":"Parameters"},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Parameter","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Default"}]}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"value"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":"Binding<Double>","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"required"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"The value the slider controls"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"range","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":"ClosedRange<Double>","type":"codeVoice"}]}],[{"inlineContent":[{"type":"codeVoice","code":"0...1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The minimum and maximum values"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"originAngle"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Angle"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":".zero"}],"type":"paragraph"}],[{"inlineContent":[{"text":"The angle that corresponds to the minimum value (3 o’clock by default)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"maxWinds","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Double"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Number of full rotations spanned by the range"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":"tickSpacing","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"TickMarkSpacing?"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"nil"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Tick mark placement. Use "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to hide tick marks"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"affinityEnabled"}]}],[{"inlineContent":[{"type":"codeVoice","code":"Bool"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"false"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Enables snapping toward tick marks","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"affinityRadius"}],"type":"paragraph"}],[{"inlineContent":[{"code":"Double","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"0.04"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Snap radius as a fraction of the full value range"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"affinityResistance","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Double"}]}],[{"type":"paragraph","inlineContent":[{"code":"0.02","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Extra escape distance beyond ","type":"text"},{"type":"codeVoice","code":"affinityRadius"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"disableHaptics"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Bool"}]}],[{"type":"paragraph","inlineContent":[{"code":"false","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Disables all haptic feedback","type":"text"}]}]],[[{"inlineContent":[{"type":"codeVoice","code":"label"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"(Double) -> some View"}],"type":"paragraph"}],[{"inlineContent":[{"code":"Text","type":"codeVoice"},{"text":" (value, 2 dp)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"A view builder for the floating label near the thumb","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"anchor":"Labels","level":2,"text":"Labels","type":"heading"},{"inlineContent":[{"type":"text","text":"A floating label is displayed just outside the thumb and updates live. By default it shows the current value formatted to two decimal places. Pass a custom "},{"code":"label","type":"codeVoice"},{"type":"text","text":" closure:"}],"type":"paragraph"},{"code":["@State private var speed = 0.5","","RSlider($speed, range: 0...200) { value in","    Text(\"\\(Int(value)) km\/h\")","}",".frame(width: 220, height: 220)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":".labelsVisibility(_:)"},{"type":"text","text":" to hide labels:"}],"type":"paragraph"},{"code":["RSlider($value)","    .labelsVisibility(.hidden)","    .frame(width: 220, height: 220)"],"type":"codeListing","syntax":"swift"},{"level":2,"anchor":"Basic-Usage","type":"heading","text":"Basic Usage"},{"code":["@State private var value = 0.5","","RSlider($value)","    .frame(width: 180, height: 180)"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Set a Range and Start Angle","level":3,"anchor":"Set-a-Range-and-Start-Angle"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"originAngle"},{"type":"text","text":" sets where the minimum value is located on the circle:"}]},{"code":["@State private var temperature = 20.0","","RSlider($temperature, range: 0...100, originAngle: .degrees(-90))","    .frame(width: 220, height: 220)"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Multiple Rotations (Winds)","level":3,"anchor":"Multiple-Rotations-Winds"},{"type":"paragraph","inlineContent":[{"code":"maxWinds","type":"codeVoice"},{"text":" controls how many full rotations cover the entire value range:","type":"text"}]},{"code":["@State private var revolutionsValue = 0.0","","RSlider($revolutionsValue, range: 0...1, maxWinds: 3)","    .frame(width: 220, height: 220)"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Tick Marks","level":2,"anchor":"Tick-Marks"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tick marks are controlled through "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TickMarkSpacing","isActive":true},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["@State private var stepped = 0.5","","RSlider($stepped, range: 0...1, tickSpacing: .count(11))","    .frame(width: 220, height: 220)"]},{"anchor":"Tick-Affinity-Snapping","text":"Tick Affinity (Snapping)","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"type":"codeVoice","code":"affinityEnabled"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"true"},{"text":", the thumb is pulled onto the nearest tick when it is close enough:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["RSlider(","    $snapped,","    range: 0...1,","    tickSpacing: .count(11),","    affinityEnabled: true,","    affinityRadius: 0.02,","    affinityResistance: 0.01",")",".frame(width: 220, height: 220)"]},{"type":"heading","anchor":"Styling-the-Slider","level":2,"text":"Styling the Slider"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Conform to "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSliderStyle","isActive":true},{"type":"text","text":" and implement:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"makeThumb(configuration:)"},{"type":"text","text":" — the draggable thumb"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"makeTrack(configuration:)"},{"text":" — the circular track","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"makeTickMark(configuration:tickValue:)"},{"type":"text","text":" — each tick mark view"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"makeLabel(configuration:content:)","type":"codeVoice"},{"type":"text","text":" — "},{"type":"emphasis","inlineContent":[{"type":"text","text":"(optional)"}]},{"text":" wraps the label near the thumb","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Apply a style using "},{"type":"codeVoice","code":"radialSliderStyle(_:)"},{"type":"text","text":" on the slider or a parent view."}]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSliderConfiguration","type":"reference","isActive":true},{"type":"text","text":" provides the style with the current state including "},{"code":"value","type":"codeVoice"},{"type":"text","text":", "},{"code":"angle","type":"codeVoice"},{"type":"text","text":", tick mark values, and wind information."}]},{"type":"codeListing","syntax":"swift","code":["struct ExampleRSliderStyle: RSliderStyle {","    func makeThumb(configuration: RSliderConfiguration) -> some View {","        Circle()","            .fill(configuration.isActive ? Color.cyan : Color.white)","            .frame(width: 28, height: 28)","            .shadow(radius: 2)","    }","","    func makeTrack(configuration: RSliderConfiguration) -> some View {","        ZStack {","            Circle()","                .stroke(Color.gray.opacity(0.3), lineWidth: 18)","            CircularArc(percent: configuration.withinWind)","                .stroke(Color.cyan, style: StrokeStyle(lineWidth: 18, lineCap: .round))","        }","        .padding(9)","    }","","    func makeTickMark(configuration: RSliderConfiguration,","                      tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let proximity = max(0, 1 - abs(thumbPct - tickPct) \/ 0.20)","        let size    = 4.0 + 6.0 * proximity","        let opacity = 0.35 + 0.65 * proximity","","        return Circle()","            .fill(Color.white.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also use the built-in styles:"}]},{"syntax":"swift","type":"codeListing","code":["RSlider($value)","    .radialSliderStyle(.default(trackThickness: 18))","","RSlider($value)","    .radialSliderStyle(.knob)"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/sliders\/rsliderguide"]}],"hierarchy":{"paths":[["doc:\/\/Sliders\/documentation\/Sliders"]]},"metadata":{"role":"collectionGroup","title":"RSlider Guide","modules":[{"name":"Sliders"}],"roleHeading":"API Collection"},"references":{"doc://Sliders/documentation/Sliders/LSlider":{"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"LSlider"}],"title":"LSlider","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"LSlider"}],"url":"\/documentation\/sliders\/lslider","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","abstract":[{"type":"text","text":"A fully stylable linear slider that can be placed at any angle.  Tick marks can be"},{"text":" ","type":"text"},{"text":"added via the ","type":"text"},{"code":"tickMarkSpacing","type":"codeVoice"},{"text":" parameter and will optionally play haptic feedback","type":"text"},{"text":" ","type":"text"},{"text":"when the thumb passes over them.","type":"text"}],"type":"topic"},"doc://Sliders/documentation/Sliders/TrackPadGuide":{"url":"\/documentation\/sliders\/trackpadguide","type":"topic","abstract":[{"text":"A deep dive into ","type":"text"},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TrackPad","type":"reference","isActive":true},{"text":" — the 2-D slider that maps horizontal and 