ext":" to hide tick marks","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"affinityEnabled","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":"Bool","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"false"}]}],[{"inlineContent":[{"type":"text","text":"Enables snapping toward tick marks"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"affinityRadius"}],"type":"paragraph"}],[{"inlineContent":[{"code":"Double","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"0.04","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Snap radius as a fraction of the full value range","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"affinityResistance","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Double"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"0.02"}]}],[{"type":"paragraph","inlineContent":[{"text":"Extra escape distance beyond ","type":"text"},{"type":"codeVoice","code":"affinityRadius"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"disableHaptics"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Bool"}]}],[{"type":"paragraph","inlineContent":[{"code":"false","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Disables all haptic feedback"}]}]],[[{"inlineContent":[{"type":"codeVoice","code":"label"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"(Double) -> some View"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Text"},{"type":"text","text":" (value, 2 dp)"}]}],[{"type":"paragraph","inlineContent":[{"text":"A view builder for the floating label near the thumb","type":"text"}]}]]],"header":"row"},{"level":2,"text":"Labels","anchor":"Labels","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"A floating label is displayed just outside the thumb and updates live. By default it shows the current value formatted to two decimal places. Pass a custom ","type":"text"},{"code":"label","type":"codeVoice"},{"text":" closure:","type":"text"}]},{"syntax":"swift","code":["@State private var speed = 0.5","","RSlider($speed, range: 0...200) { value in","    Text(\"\\(Int(value)) km\/h\")","}",".frame(width: 220, height: 220)"],"type":"codeListing"},{"inlineContent":[{"text":"Use ","type":"text"},{"code":".labelsVisibility(_:)","type":"codeVoice"},{"text":" to hide labels:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["RSlider($value)","    .labelsVisibility(.hidden)","    .frame(width: 220, height: 220)"],"type":"codeListing"},{"text":"Basic Usage","level":2,"anchor":"Basic-Usage","type":"heading"},{"syntax":"swift","type":"codeListing","code":["@State private var value = 0.5","","RSlider($value)","    .frame(width: 180, height: 180)"]},{"level":3,"text":"Set a Range and Start Angle","type":"heading","anchor":"Set-a-Range-and-Start-Angle"},{"type":"paragraph","inlineContent":[{"code":"originAngle","type":"codeVoice"},{"type":"text","text":" sets where the minimum value is located on the circle:"}]},{"syntax":"swift","type":"codeListing","code":["@State private var temperature = 20.0","","RSlider($temperature, range: 0...100, originAngle: .degrees(-90))","    .frame(width: 220, height: 220)"]},{"level":3,"type":"heading","text":"Multiple Rotations (Winds)","anchor":"Multiple-Rotations-Winds"},{"type":"paragraph","inlineContent":[{"code":"maxWinds","type":"codeVoice"},{"type":"text","text":" controls how many full rotations cover the entire value range:"}]},{"syntax":"swift","type":"codeListing","code":["@State private var revolutionsValue = 0.0","","RSlider($revolutionsValue, range: 0...1, maxWinds: 3)","    .frame(width: 220, height: 220)"]},{"level":2,"anchor":"Tick-Marks","text":"Tick Marks","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Tick marks are controlled through ","type":"text"},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TickMarkSpacing","type":"reference","isActive":true},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["@State private var stepped = 0.5","","RSlider($stepped, range: 0...1, tickSpacing: .count(11))","    .frame(width: 220, height: 220)"]},{"level":2,"type":"heading","text":"Tick Affinity (Snapping)","anchor":"Tick-Affinity-Snapping"},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"code":"affinityEnabled","type":"codeVoice"},{"type":"text","text":" is "},{"code":"true","type":"codeVoice"},{"type":"text","text":", the thumb is pulled onto the nearest tick when it is close enough:"}]},{"code":["RSlider(","    $snapped,","    range: 0...1,","    tickSpacing: .count(11),","    affinityEnabled: true,","    affinityRadius: 0.02,","    affinityResistance: 0.01",")",".frame(width: 220, height: 220)"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Styling the Slider","level":2,"anchor":"Styling-the-Slider"},{"type":"paragraph","inlineContent":[{"text":"Conform to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSliderStyle","type":"reference"},{"text":" and implement:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"code":"makeThumb(configuration:)","type":"codeVoice"},{"text":" — the draggable thumb","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"makeTrack(configuration:)"},{"type":"text","text":" — the circular track"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"makeTickMark(configuration:tickValue:)"},{"text":" — each tick mark view","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"makeLabel(configuration:content:)"},{"type":"text","text":" — "},{"type":"emphasis","inlineContent":[{"text":"(optional)","type":"text"}]},{"type":"text","text":" wraps the label near the thumb"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Apply a style using ","type":"text"},{"code":"radialSliderStyle(_:)","type":"codeVoice"},{"type":"text","text":" on the slider or a parent view."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSliderConfiguration","isActive":true},{"type":"text","text":" provides the style with the current state including "},{"type":"codeVoice","code":"value"},{"type":"text","text":", "},{"type":"codeVoice","code":"angle"},{"text":", tick mark values, and wind information.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct ExampleRSliderStyle: RSliderStyle {","    func makeThumb(configuration: RSliderConfiguration) -> some View {","        Circle()","            .fill(configuration.isActive ? Color.cyan : Color.white)","            .frame(width: 28, height: 28)","            .shadow(radius: 2)","    }","","    func makeTrack(configuration: RSliderConfiguration) -> some View {","        ZStack {","            Circle()","                .stroke(Color.gray.opacity(0.3), lineWidth: 18)","            CircularArc(percent: configuration.withinWind)","                .stroke(Color.cyan, style: StrokeStyle(lineWidth: 18, lineCap: .round))","        }","        .padding(9)","    }","","    func makeTickMark(configuration: RSliderConfiguration,","                      tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let proximity = max(0, 1 - abs(thumbPct - tickPct) \/ 0.20)","        let size    = 4.0 + 6.0 * proximity","        let opacity = 0.35 + 0.65 * proximity","","        return Circle()","            .fill(Color.white.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","}"]},{"inlineContent":[{"type":"text","text":"You can also use the built-in styles:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["RSlider($value)","    .radialSliderStyle(.default(trackThickness: 18))","","RSlider($value)","    .radialSliderStyle(.knob)"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/sliders\/rsliderguide"]}],"abstract":[{"type":"text","text":"A deep dive into "},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSlider","type":"reference","isActive":true},{"type":"text","text":" — the circular slider whose thumb travels around a configurable arc."}],"hierarchy":{"paths":[["doc:\/\/Sliders\/documentation\/Sliders"]]},"sections":[],"references":{"doc://Sliders/documentation/Sliders/JoystickGuide":{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/JoystickGuide","kind":"article","abstract":[{"type":"text","text":"A deep dive into "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick","isActive":true},{"type":"text","text":" — the on-screen joystick that appears wherever the user drags within a hit-box."}],"url":"\/documentation\/sliders\/joystickguide","type":"topic","role":"collectionGroup","title":"Joystick Guide"},"doc://Sliders/documentation/Sliders/DoubleLSliderGuide":{"title":"DoubleLSlider Guide","role":"collectionGroup","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/DoubleLSliderGuide","type":"topic","url":"\/documentation\/sliders\/doublelsliderguide","kind":"article","abstract":[{"type":"text","text":"A deep dive into "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/DoubleLSlider","isActive":true},{"type":"text","text":" — the linear range slider with two independent thumbs and a draggable active-track segment."}]},"doc://Sliders/documentation/Sliders/Tra