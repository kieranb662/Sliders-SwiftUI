{"hierarchy":{"paths":[["doc:\/\/Sliders\/documentation\/Sliders"]]},"sections":[],"abstract":[{"text":"A deep dive into ","type":"text"},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/PSlider","type":"reference","isActive":true},{"text":" — turn any SwiftUI ","type":"text"},{"type":"codeVoice","code":"Shape"},{"text":" into a slider whose thumb travels along the shape’s path.","type":"text"}],"variants":[{"paths":["\/documentation\/sliders\/psliderguide"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/Sliders\/documentation\/Sliders\/PSliderGuide","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"topicSections":[{"anchor":"Essentials","identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/PSlider","doc:\/\/Sliders\/documentation\/Sliders\/PSliderStyle","doc:\/\/Sliders\/documentation\/Sliders\/PSliderConfiguration"],"title":"Essentials"},{"anchor":"Tutorials","identifiers":["doc:\/\/Sliders\/tutorials\/PSlider-Tutorials"],"title":"Tutorials"}],"metadata":{"title":"PSlider Guide","roleHeading":"API Collection","role":"collectionGroup","modules":[{"name":"Sliders"}]},"kind":"article","seeAlsoSections":[{"anchor":"Guides","identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/LSliderGuide","doc:\/\/Sliders\/documentation\/Sliders\/DoubleLSliderGuide","doc:\/\/Sliders\/documentation\/Sliders\/RSliderGuide","doc:\/\/Sliders\/documentation\/Sliders\/DoubleRSliderGuide","doc:\/\/Sliders\/documentation\/Sliders\/TrackPadGuide","doc:\/\/Sliders\/documentation\/Sliders\/RadialPadGuide","doc:\/\/Sliders\/documentation\/Sliders\/JoystickGuide","doc:\/\/Sliders\/documentation\/Sliders\/OverflowSliderGuide"],"title":"Guides","generated":true}],"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/PSlider"},{"text":" takes any SwiftUI ","type":"text"},{"code":"Shape","type":"codeVoice"},{"text":" and converts it into a slider. The thumb follows the outline of the shape, and the track fills as the thumb is dragged. This makes it great for creating unique, organic user experiences.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Parameters","anchor":"Parameters","level":2},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Parameter"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Default"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"value"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Binding<Double>"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"required"}]}],[{"type":"paragraph","inlineContent":[{"text":"The current value of the slider","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"shape"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Shape"}]}],[{"type":"paragraph","inlineContent":[{"text":"required","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"Shape"},{"type":"text","text":" to be used as the slider’s track"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"range"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ClosedRange<Double>"}]}],[{"type":"paragraph","inlineContent":[{"code":"0...1","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"The minimum and maximum numbers that "},{"type":"codeVoice","code":"value"},{"text":" can be","type":"text"}]}]],[[{"inlineContent":[{"code":"isDisabled","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Bool"}],"type":"paragraph"}],[{"inlineContent":[{"code":"false","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Whether the slider should be disabled"}],"type":"paragraph"}]]],"type":"table"},{"level":2,"type":"heading","anchor":"Basic-Usage","text":"Basic Usage"},{"type":"paragraph","inlineContent":[{"text":"Use any SwiftUI ","type":"text"},{"type":"codeVoice","code":"Shape"},{"text":" as the track:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@State private var value = 0.5","","PSlider($value, shape: Circle())","    .frame(width: 200, height: 200)"]},{"level":3,"type":"heading","anchor":"Custom-Range","text":"Custom Range"},{"type":"codeListing","syntax":"swift","code":["@State private var value = 50.0","","PSlider($value, range: 0...100, shape: Circle())","    .frame(width: 200, height: 200)"]},{"level":3,"type":"heading","anchor":"Using-a-Custom-Shape","text":"Using a Custom Shape"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any conforming "},{"type":"codeVoice","code":"Shape"},{"type":"text","text":" works — including your own:"}]},{"type":"codeListing","syntax":"swift","code":["@State private var value = 0.5","","PSlider($value, shape: RoundedRectangle(cornerRadius: 20))","    .frame(width: 250, height: 150)"]},{"level":2,"type":"heading","anchor":"PSliderConfiguration","text":"PSliderConfiguration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both style methods provide access to state values through "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/PSliderConfiguration"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["struct PSliderConfiguration {","    let isDisabled: Bool","    let isActive: Bool","    let pctFill: Double","    let value: Double","    let angle: Angle","    let min: Double","    let max: Double","    let shape: AnyShape","}"]},{"level":2,"type":"heading","anchor":"Styling","text":"Styling"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Conform to "},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/PSliderStyle","isActive":true,"type":"reference"},{"text":" and implement two methods:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"makeThumb(configuration:)"},{"type":"text","text":" — the draggable thumb that follows the shape’s path"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"makeTrack(configuration:)"},{"type":"text","text":" — the track that fills or empties as the thumb drags"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Apply with ","type":"text"},{"code":".pathSliderStyle(_:)","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["struct MyPSliderStyle: PSliderStyle {","    func makeThumb(configuration: PSliderConfiguration) -> some View {","        Circle()","            .frame(width: 30, height: 30)","            .foregroundColor(configuration.isActive ? Color.yellow : Color.white)","    }","","    func makeTrack(configuration: PSliderConfiguration) -> some View {","        ZStack {","            configuration.shape","                .stroke(Color.gray, lineWidth: 8)","            configuration.shape","                .trim(from: 0, to: CGFloat(configuration.pctFill))","                .stroke(Color.purple, lineWidth: 10)","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Apply the style:"}],"type":"paragraph"},{"code":["PSlider($value, shape: Circle())","    .pathSliderStyle(MyPSliderStyle())","    .frame(width: 200, height: 200)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The "},{"code":"pathSliderStyle","type":"codeVoice"},{"type":"text","text":" modifier cascades through the view hierarchy."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://Sliders/documentation/Sliders/DoubleLSlider":{"identifier":"doc:\/\/Sliders\/documentation\/