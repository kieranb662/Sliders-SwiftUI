{"abstract":[{"type":"text","text":"A deep dive into "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/PSlider"},{"type":"text","text":" — turn any SwiftUI "},{"type":"codeVoice","code":"Shape"},{"type":"text","text":" into a slider whose thumb travels along the shape’s path."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/sliders\/psliderguide"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"modules":[{"name":"Sliders"}],"roleHeading":"API Collection","title":"PSlider Guide","role":"collectionGroup"},"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/PSlider","type":"reference","isActive":true},{"type":"text","text":" takes any SwiftUI "},{"type":"codeVoice","code":"Shape"},{"type":"text","text":" and converts it into a slider. The thumb follows the outline of the shape, and the track fills as the thumb is dragged. This makes it great for creating unique, organic user experiences."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Parameters","anchor":"Parameters"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Parameter"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Default"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"value"}],"type":"paragraph"}],[{"inlineContent":[{"code":"Binding<Double>","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"required","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The current value of the slider"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"shape","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Shape"}],"type":"paragraph"}],[{"inlineContent":[{"text":"required","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"The ","type":"text"},{"code":"Shape","type":"codeVoice"},{"text":" to be used as the slider’s track","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"range"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"ClosedRange<Double>"}],"type":"paragraph"}],[{"inlineContent":[{"code":"0...1","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The minimum and maximum numbers that "},{"code":"value","type":"codeVoice"},{"type":"text","text":" can be"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"isDisabled","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Bool"}],"type":"paragraph"}],[{"inlineContent":[{"code":"false","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Whether the slider should be disabled"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"type":"heading","text":"Basic Usage","anchor":"Basic-Usage","level":2},{"inlineContent":[{"text":"Use any SwiftUI ","type":"text"},{"type":"codeVoice","code":"Shape"},{"type":"text","text":" as the track:"}],"type":"paragraph"},{"code":["@State private var value = 0.5","","PSlider($value, shape: Circle())","    .frame(width: 200, height: 200)"],"type":"codeListing","syntax":"swift"},{"text":"Custom Range","level":3,"anchor":"Custom-Range","type":"heading"},{"syntax":"swift","code":["@State private var value = 50.0","","PSlider($value, range: 0...100, shape: Circle())","    .frame(width: 200, height: 200)"],"type":"codeListing"},{"text":"Using a Custom Shape","level":3,"anchor":"Using-a-Custom-Shape","type":"heading"},{"inlineContent":[{"text":"Any conforming ","type":"text"},{"code":"Shape","type":"codeVoice"},{"text":" works — including your own:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["@State private var value = 0.5","","PSlider($value, shape: RoundedRectangle(cornerRadius: 20))","    .frame(width: 250, height: 150)"],"type":"codeListing"},{"text":"PSliderConfiguration","level":2,"anchor":"PSliderConfiguration","type":"heading"},{"inlineContent":[{"type":"text","text":"Both style methods provide access to state values through "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/PSliderConfiguration"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["struct PSliderConfiguration {","    let isDisabled: Bool","    let isActive: Bool","    let pctFill: Double","    let value: Double","    let angle: Angle","    let min: Double","    let max: Double","    let shape: AnyShape","}"],"type":"codeListing"},{"text":"Styling","level":2,"anchor":"Styling","type":"heading"},{"inlineContent":[{"type":"text","text":"Conform to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/PSliderStyle"},{"type":"text","text":" and implement two methods:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"code":"makeThumb(configuration:)","type":"codeVoice"},{"text":" — the draggable thumb that follows the shape’s path","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"makeTrack(configuration:)"},{"type":"text","text":" — the track that fills or empties as the thumb drags"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Apply with "},{"type":"codeVoice","code":".pathSliderStyle(_:)"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["struct MyPSliderStyle: PSliderStyle {","    func makeThumb(configuration: PSliderConfiguration) -> some View {","        Circle()","            .frame(width: 30, height: 30)","            .foregroundColor(configuration.isActive ? Color.yellow : Color.white)","    }","","    func makeTrack(configuration: PSliderConfiguration) -> some View {","        ZStack {","            configuration.shape","                .stroke(Color.gray, lineWidth: 8)","            configuration.shape","                .trim(from: 0, to: CGFloat(configuration.pctFill))","                .stroke(Color.purple, lineWidth: 10)","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Apply the style:"}],"type":"paragraph"},{"type":"codeListing","code":["PSlider($value, shape: Circle())","    .pathSliderStyle(MyPSliderStyle())","    .frame(width: 200, height: 200)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"pathSliderStyle"},{"type":"text","text":" modifier cascades through the view hierarchy."}]}],"kind":"content"}],"topicSections":[{"title":"Essentials","identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/PSlider","doc:\/\/Sliders\/documentation\/Sliders\/PSliderStyle","doc:\/\/Sliders\/documentation\/Sliders\/PSliderConfiguration"],"anchor":"Essentials"},{"title":"Tutorials","identifiers":["doc:\/\/Sliders\/tutorials\/PSlider-Tutorials"],"anchor":"Tutorials"}],"hierarchy":{"paths":[["doc:\/\/Sliders\/documentation\/Sliders"]]},"kind":"article","sections":[],"identifier":{"url":"doc:\/\/Sliders\/documentation\/Sliders\/PSliderGuide","interfaceLanguage":"swift"},"seeAlsoSections":[{"anchor":"Guides","title":"Guides","identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/LSliderGuide","doc:\/\/Sliders\/documentation\/Sliders\/DoubleLSliderGuide","doc:\/\/Sliders\/documentation\/Sliders\/RSliderGuide","doc:\/\/Sliders\/documentation\/Sliders\/DoubleRSliderGuide","doc:\/\/Sliders\/documentation\/Sliders\/TrackPadGuide","doc:\/\/Sliders\/documentation\/Sliders\/RadialPadGuide","doc:\/\/Sliders\/documentation\/Sliders\/JoystickGuide","doc:\/\/Sliders\/documentation\/Sliders\/OverflowSliderGuide"],"generated":true}],"references":{"doc://Sliders/documentation/Sliders/LSlider":{"kind":"symbol","fragments":[{"kind":"keyword","text