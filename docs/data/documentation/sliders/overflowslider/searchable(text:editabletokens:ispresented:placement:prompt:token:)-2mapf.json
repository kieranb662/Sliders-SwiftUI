ind":"symbol","title":"OverflowSlider","url":"\/documentation\/sliders\/overflowslider","type":"topic","navigatorTitle":[{"text":"OverflowSlider","kind":"identifier"}],"abstract":[{"type":"text","text":"A Slider which has a fixed frame but a movable track in the background. Used for values that have a discrete nature to them but would not necessarily fit on screen."},{"text":" ","type":"text"},{"text":"Both the thumb and track can be dragged, if the track is dragged and thrown the velocity of the throw is added to the tracks velocity and it slows gradually to a stop.","type":"text"},{"text":" ","type":"text"},{"text":"If the thumb is currently being dragged and reachs the minimum or maximum value of its bounds, velocity is added to the track in the opposite direction of the drag.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OverflowSlider","kind":"identifier"}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","role":"symbol"}}}