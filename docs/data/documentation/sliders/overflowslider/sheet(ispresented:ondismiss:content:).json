]},"references":{"doc://Sliders/documentation/Sliders/OverflowSlider":{"kind":"symbol","abstract":[{"type":"text","text":"A Slider which has a fixed frame but a movable track in the background. Used for values that have a discrete nature to them but would not necessarily fit on screen."},{"type":"text","text":" "},{"text":"Both the thumb and track can be dragged, if the track is dragged and thrown the velocity of the throw is added to the tracks velocity and it slows gradually to a stop.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If the thumb is currently being dragged and reachs the minimum or maximum value of its bounds, velocity is added to the track in the opposite direction of the drag."}],"title":"OverflowSlider","url":"\/documentation\/sliders\/overflowslider","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OverflowSlider","kind":"identifier"}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","navigatorTitle":[{"kind":"identifier","text":"OverflowSlider"}],"role":"symbol","type":"topic"},"doc://Sliders/documentation/Sliders/OverflowSlider/sheet(isPresented:onDismiss:content:)":{"url":"\/documentation\/sliders\/overflowslider\/sheet(ispresented:ondismiss:content:)","abstract":[],"title":"sheet(isPresented:onDismiss:content:)","type":"topic","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider\/sheet(isPresented:onDismiss:content:)","kind":"symbol","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sheet","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"isPresented","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:7SwiftUI7BindingV","text":"Binding","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":">, ","kind":"text"},{"text":"onDismiss