\/documentation\/sliders\/overflowslider","type":"topic","navigatorTitle":[{"text":"OverflowSlider","kind":"identifier"}],"abstract":[{"type":"text","text":"A Slider which has a fixed frame but a movable track in the background. Used for values that have a discrete nature to them but would not necessarily fit on screen."},{"text":" ","type":"text"},{"text":"Both the thumb and track can be dragged, if the track is dragged and thrown the velocity of the throw is added to the tracks velocity and it slows gradually to a stop.","type":"text"},{"text":" ","type":"text"},{"text":"If the thumb is currently being dragged and reachs the minimum or maximum value of its bounds, velocity is added to the track in the opposite direction of the drag.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OverflowSlider","kind":"identifier"}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","role":"symbol"},"doc://Sliders/documentation/Sliders/OverflowSlider/fileExporter(isPresented:document:contentTypes:defaultFilename:onCompletion:onCancellation:)-6gkwg":{"url":"\/documentation\/sliders\/overflowslider\/fileexporter(ispresented:document:contenttypes:defaultfilename:oncompletion:oncancellation:)-6gkwg","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fileExporter","kind":"identifier"},{"text":"<","kind":"text"},{"text":"D","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"isPresented","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:7SwiftUI7BindingV","text":"Binding","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":">, ","kind":"text"},{"text":"document","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"D","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"contentTypes","kind":"externalParam"},{"text":": [","kind":"text"},{"preciseIdentifier"