/documentation\/Sliders\/OverflowSlider","role":"symbol","title":"OverflowSlider","abstract":[{"text":"A Slider which has a fixed frame but a movable track in the background. Used for values that have a discrete nature to them but would not necessarily fit on screen.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Both the thumb and track can be dragged, if the track is dragged and thrown the velocity of the throw is added to the tracks velocity and it slows gradually to a stop."},{"type":"text","text":" "},{"type":"text","text":"If the thumb is currently being dragged and reachs the minimum or maximum value of its bounds, velocity is added to the track in the opposite direction of the drag."}],"type":"topic","url":"\/documentation\/sliders\/overflowslider","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OverflowSlider","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OverflowSlider"}]},"doc://Sliders/documentation/Sliders/OverflowSlider/navigationDocument(_:preview:)-2supv":{"role":"symbol","title":"navigationDocument(_:preview:)","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider\/navigationDocument(_:preview:)-2supv","abstract":[],"kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"navigationDocument","kind":"identifier"},{"text":"<","kind":"text"},{"text":"D","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"D","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"preview","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:7SwiftUI12SharePreviewV","text":"SharePreview","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:s5NeverO","text":"Never","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:s5NeverO","text":"Never","kind":"typeIdentifier"},{"text":">) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text"