ck in the opposite direction of the drag."}],"role":"symbol","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","url":"\/documentation\/sliders\/overflowslider","navigatorTitle":[{"text":"OverflowSlider","kind":"identifier"}],"type":"topic","title":"OverflowSlider"}}}