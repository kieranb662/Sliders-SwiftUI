/documentation/Sliders":{"type":"topic","title":"Sliders","role":"collection","abstract":[{"text":"A collection of fully stylable, drag-based SwiftUI controls — including linear, radial, range, and 2D sliders.","type":"text"}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders","kind":"symbol","url":"\/documentation\/sliders"},"doc://Sliders/documentation/Sliders/OverflowSlider":{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","role":"symbol","title":"OverflowSlider","abstract":[{"text":"A Slider which has a fixed frame but a movable track in the background. Used for values that have a discrete nature to them but would not necessarily fit on screen.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Both the thumb and track can be dragged, if the track is dragged and thrown the velocity of the throw is added to the tracks velocity and it slows gradually to a stop."},{"type":"text","text":" "},{"type":"text","text":"If the thumb is currently being dragged and reachs the minimum or maximum value of its bounds, velocity is added to the track in the opposite direction of the drag."}],"type":"topic","url":"\/documentation\/sliders\/overflowslider","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OverflowSlider","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OverflowSlider"}]}}}