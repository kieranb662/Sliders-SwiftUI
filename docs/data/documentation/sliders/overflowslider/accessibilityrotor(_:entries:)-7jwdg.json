ers/OverflowSlider":{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","role":"symbol","title":"OverflowSlider","abstract":[{"text":"A Slider which has a fixed frame but a movable track in the background. Used for values that have a discrete nature to them but would not necessarily fit on screen.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Both the thumb and track can be dragged, if the track is dragged and thrown the velocity of the throw is added to the tracks velocity and it slows gradually to a stop."},{"type":"text","text":" "},{"type":"text","text":"If the thumb is currently being dragged and reachs the minimum or maximum value of its bounds, velocity is added to the track in the opposite direction of the drag."}],"type":"topic","url":"\/documentation\/sliders\/overflowslider","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OverflowSlider","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OverflowSlider"}]},"doc://Sliders/documentation/Sliders/OverflowSlider/accessibilityRotor(_:entries:)-7jwdg":{"url":"\/documentation\/sliders\/overflowslider\/accessibilityrotor(_:entries:)-7jwdg","abstract":[],"kind":"symbol","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider\/accessibilityRotor(_:entries:)-7jwdg","type":"topic","title":"accessibilityRotor(_:entries:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"accessibilityRotor"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Content"},{"kind":"text","text":">("},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI24AccessibilitySystemRotorV","text":"AccessibilitySystemRotor"},{"kind":"text","text":", "},{"kind":"externalParam","text":"entries"},{"kind":"text","text":": () -> "},{"kind":"typeIdentifier","text":"Content"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kin