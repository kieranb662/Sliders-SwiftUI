":"symbol","abstract":[{"type":"text","text":"A Slider which has a fixed frame but a movable track in the background. Used for values that have a discrete nature to them but would not necessarily fit on screen."},{"type":"text","text":" "},{"text":"Both the thumb and track can be dragged, if the track is dragged and thrown the velocity of the throw is added to the tracks velocity and it slows gradually to a stop.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If the thumb is currently being dragged and reachs the minimum or maximum value of its bounds, velocity is added to the track in the opposite direction of the drag."}],"title":"OverflowSlider","url":"\/documentation\/sliders\/overflowslider","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OverflowSlider","kind":"identifier"}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","navigatorTitle":[{"kind":"identifier","text":"OverflowSlider"}],"role":"symbol","type":"topic"},"doc://Sliders/documentation/Sliders":{"type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/Sliders\/documentation\/Sliders","abstract":[],"title":"Sliders","url":"\/documentation\/sliders"}}}