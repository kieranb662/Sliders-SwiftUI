 frame but a movable track in the background. Used for values that have a discrete nature to them but would not necessarily fit on screen."},{"type":"text","text":" "},{"type":"text","text":"Both the thumb and track can be dragged, if the track is dragged and thrown the velocity of the throw is added to the tracks velocity and it slows gradually to a stop."},{"type":"text","text":" "},{"type":"text","text":"If the thumb is currently being dragged and reachs the minimum or maximum value of its bounds, velocity is added to the track in the opposite direction of the drag."}],"role":"symbol","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","url":"\/documentation\/sliders\/overflowslider","navigatorTitle":[{"text":"OverflowSlider","kind":"identifier"}],"type":"topic","title":"OverflowSlider"},"doc://Sliders/documentation/Sliders/TickMarks":{"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TickMarks"}],"abstract":[],"url":"\/documentation\/sliders\/tickmarks","type":"topic","title":"TickMarks","navigatorTitle":[{"kind":"identifier","text":"TickMarks"}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TickMarks","kind":"symbol","role":"symbol"},"doc://Sliders/tutorials/OverflowSlider-Tutorials":{"kind":"overview","abstract":[{"type":"text","text":"Learn how to add a meter-style overflow slider to your app using the built-in"},{"text":" ","type":"text"},{"text":"default style and its configuration options.","type":"text"}],"identifier":"doc:\/\/Sliders\/tutorials\/OverflowSlider-Tutorials","title":"Building Meter Sliders with OverflowSlider","url":"\/tutorials\/overflowslider-tutorials","role":"overview","type":"topic"},"doc://Sliders/documentation/Sliders/OverflowSliderConfiguration":{"navigatorTitle":[{"kind":"identifier","text":"OverflowSliderConfiguration"}],"abstract":[],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"OverflowSliderConf