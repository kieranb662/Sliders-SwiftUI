{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick"},"metadata":{"roleHeading":"Structure","modules":[{"name":"Sliders"}],"externalID":"s:7Sliders8JoystickV","title":"Joystick","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Joystick","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Joystick"}],"symbolKind":"struct","role":"symbol"},"abstract":[{"type":"text","text":"Joystick view used to control various activities such as moving a character on the screen."},{"type":"text","text":" "},{"type":"text","text":"The View creates a Rectangular region to act as a hitbox for drag gestures. Once a drag"},{"type":"text","text":" "},{"type":"text","text":"is initiated the joystick appears on screen centered at the start location of the gesture. While"},{"type":"text","text":" "},{"type":"text","text":"dragging, the thumb of the joystick is limited be within the "},{"type":"codeVoice","code":"radius"},{"type":"text","text":" of the sticks background circle."}],"relationshipsSections":[{"type":"conformsTo","kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/Sliders\/s8SendableP","doc:\/\/Sliders\/s16SendableMetatypeP","doc:\/\/Sliders\/7SwiftUI4ViewP"]}],"seeAlsoSections":[{"title":"2D Controls","identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/TrackPad","doc:\/\/Sliders\/documentation\/Sliders\/RadialPad"],"generated":true,"anchor":"2D-Controls"}],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/init(state:radius:)","doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/init(state:radius:canLock:isDisabled:)","doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/init(state:radius:isDisabled:)"],"generated":true,"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/body","doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/state"],"generated":true,"anchor":"Instance-Properties"},{"title":"Default Implementations","identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/View-Implementations","doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/View-Implementations"],"generated":true,"anchor":"Default-Implementations"}],"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/Sliders\/documentation\/Sliders"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Joystick"}],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"","type":"text"},{"code":"Binding<JoyState>","type":"codeVoice"},{"type":"text","text":"  you provide a binding to a Joystate  value which allows you to maintain access to all of the Joysticks state values"}],"type":"paragraph"}],"name":"state"},{"name":"radius","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"Double"},{"text":" The radius of the track","type":"text"}]}]},{"name":"canLock","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A boolean value describing whether the joystick has locking behavior ("},{"type":"strong","inlineContent":[{"type":"text","text":"default: true"}]},{"type":"text","text":")"}]}]},{"name":"isDisabled","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"code":"Bool","type":"codeVoice"},{"text":" whether the joystick allows hit testing or not (","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"default: false"}]},{"text":")","type":"text"}]}]}]},{"content":[{"level":2,"text":"Style","anchor":"Style","type":"heading"},{"inlineContent":[{"text":"The Joystick can be themed and styled by making a custom struct conforming to the ","type":"text"},{"code":"JoystickStyle","type":"codeVoice"},{"text":" ","type":"text"},{"text":"protocol. Conformance requires that you implement 4 methods","type":"text"},{"text":" ","type":"text"},{"text":"1.  ","type":"text"},{"code":"makeHitBox","type":"codeVoice"},{"text":" - Creates the rectangular region that responds the the users touch","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"2. "},{"code":"makeLockBox","type":"codeVoice"},{"type":"text","text":" - Creates a view such that if the drag gestures location is contained within the lockbox, the joystick goes into the locked state"},{"type":"text","text":" "},{"text":"3.  ","type":"text"},{"type":"codeVoice","code":"makeTrack"},{"text":" - Creates the circular track that contains the joystick thumb","type":"text"},{"text":" ","type":"text"},{"text":"4   ","type":"text"},{"type":"codeVoice","code":"makeThumb"},{"text":" - Creates the part of the joystick the moves when dragging","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"These 3 methods all provide access to the "},{"type":"codeVoice","code":"JoystickConfiguration"},{"type":"text","text":" ."},{"type":"text","text":" "},{"type":"text","text":"Make use of the various state values to customize the Joystick to your liking."}],"type":"paragraph"},{"code":["    struct JoystickConfiguration {","        let isDisabled: Bool \/\/ whether or not the slider is current disables","        let isActive: Bool \/\/ True if the joystick thumb is dragging or if the joystick is locked","        let isAtLimit: Bool \/\/ whether the offset of the thumb reached the radius of the circle","        let isLocked: Bool \/\/ Whether the joystick is locked or not","        let angle: Angle \/\/ The angle of the line between the pads center and the thumbs location, measured from the vector pointing in the trailing direction","        let radialOffset: Double \/\/ The current displacement of the thumb from the track's center","     }"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Once your custom style has been created, implement it by calling the "},{"code":"joystickStyle(_ :)","type":"codeVoice"},{"type":"text","text":" method on the "},{"code":"Joystick","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"text","text":"a view containing the "},{"code":"Joystick","type":"codeVoice"},{"text":" to be styled. To make it easier try using the follow example based upon the ","type":"text"},{"code":"DefaultJoystickStyle","type":"codeVoice"}],"type":"paragraph"},{"code":["     struct <#My Joystick Style#>: JoystickStyle {","         func makeHitBox(configuration: JoystickConfiguration) -> some View {","             Rectangle()","                 .fill(Color.white.opacity(0.05))","         }","         func makeLockBox(configuration: JoystickConfiguration) -> some View {","             Circle()","                 .fill(Color.black)","                 .overlay(Circle().fill(Color.yellow).scaleEffect(0.7))","                 .frame(width: 25, height: 25)","         }","         func makeTrack(configuration: JoystickConfiguration) -> some View {","             Circle()","                 .fill(Color.gray.opacity(0.4))","         }","         func makeThumb(configuration: JoystickConfiguration) -> some View {","             Circle()","                 .fill(Color.blue)","                 .frame(width: 45, height: 45)","","         }","     }"],"type":"codeListing","syntax":null}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/sliders\/joystick"]}],"references":{"doc://Sliders/documentation/Sliders/Joystick/init(state:radius:canLock:isDisabled:)":{"abstract":[],"role":"symbol","title":"init(state:radius:canLock:isDisabled:)","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/init(state:radius:canLock:isDisabled:)","url":"\/documentation\/sliders\/joystick\/init(state:radius:canlock:isdisabled:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"state","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI7BindingV","text":"Binding"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:7Sliders8JoyStateO","text":"JoyState"},{"kind":"text","text":">, "},{"text":"radius","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sd","kind":"typeIdentifier","text":"Double"},{"kind":"text","text":", "},{"kind":"externalParam","text":"canLock"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"isDisabled"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"text":")","kind":"text"}],"type":"topic","kind":"symbol"},"doc://Sliders/s8SendableP":{"identifier":"doc:\/\/Sliders\/s8SendableP","type":"unresolvable","title":"Swift.Sendable"},"doc://Sliders/7SwiftUI4ViewP":{"title":"SwiftUICore.View","type":"unresolvable","identifier":"doc:\/\/Sliders\/7SwiftUI4ViewP"},"doc://Sliders/documentation/Sliders/TrackPad":{"abstract":[{"type":"text","text":"The 2-D equivalent of a "},{"code":"Slider","type":"codeVoice"},{"type":"text","text":". A draggable thumb moves freely inside a rectangular"},{"type":"text","text":" "},{"type":"text","text":"area, controlling independent x and y values simultaneously."}],"title":"TrackPad","url":"\/documentation\/sliders\/trackpad","type":"topic","role":"symbol","navigatorTitle":[{"text":"TrackPad","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TrackPad","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TrackPad","kind":"identifier"}]},"doc://Sliders/documentation/Sliders/RadialPad":{"url":"\/documentation\/