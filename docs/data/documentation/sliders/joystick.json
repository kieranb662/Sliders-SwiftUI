{"hierarchy":{"paths":[["doc:\/\/Sliders\/documentation\/Sliders"]]},"kind":"symbol","abstract":[{"type":"text","text":"Joystick view used to control various activities such as moving a character on the screen."},{"type":"text","text":" "},{"type":"text","text":"The View creates a Rectangular region to act as a hitbox for drag gestures. Once a drag"},{"type":"text","text":" "},{"type":"text","text":"is initiated the joystick appears on screen centered at the start location of the gesture. While"},{"type":"text","text":" "},{"type":"text","text":"dragging, the thumb of the joystick is limited be within the "},{"type":"codeVoice","code":"radius"},{"type":"text","text":" of the sticks background circle."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Joystick","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"parameters":[{"name":"state","content":[{"inlineContent":[{"text":"","type":"text"},{"code":"Binding<JoyState>","type":"codeVoice"},{"text":"  you provide a binding to a Joystate  value which allows you to maintain access to all of the Joysticks state values","type":"text"}],"type":"paragraph"}]},{"name":"radius","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"Double"},{"type":"text","text":" The radius of the track"}],"type":"paragraph"}]},{"name":"canLock","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A boolean value describing whether the joystick has locking behavior ("},{"inlineContent":[{"type":"text","text":"default: true"}],"type":"strong"},{"type":"text","text":")"}]}]},{"name":"isDisabled","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"Bool"},{"type":"text","text":" whether the joystick allows hit testing or not ("},{"type":"strong","inlineContent":[{"type":"text","text":"default: false"}]},{"type":"text","text":")"}]}]}],"kind":"parameters"},{"content":[{"anchor":"Style","type":"heading","text":"Style","level":2},{"inlineContent":[{"type":"text","text":"The Joystick can be themed and styled by making a custom struct conforming to the "},{"type":"codeVoice","code":"JoystickStyle"},{"type":"text","text":" "},{"type":"text","text":"protocol. Conformance requires that you implement 4 methods"},{"type":"text","text":" "},{"type":"text","text":"1.  "},{"type":"codeVoice","code":"makeHitBox"},{"type":"text","text":" - Creates the rectangular region that responds the the users touch"},{"type":"text","text":" "},{"type":"text","text":"2. "},{"type":"codeVoice","code":"makeLockBox"},{"text":" - Creates a view such that if the drag gestures location is contained within the lockbox, the joystick goes into the locked state","type":"text"},{"text":" ","type":"text"},{"text":"3.  ","type":"text"},{"code":"makeTrack","type":"codeVoice"},{"type":"text","text":" - Creates the circular track that contains the joystick thumb"},{"type":"text","text":" "},{"type":"text","text":"4   "},{"code":"makeThumb","type":"codeVoice"},{"type":"text","text":" - Creates the part of the joystick the moves when dragging"}],"type":"paragraph"},{"inlineContent":[{"text":"These 3 methods all provide access to the ","type":"text"},{"code":"JoystickConfiguration","type":"codeVoice"},{"text":" .","type":"text"},{"text":" ","type":"text"},{"text":"Make use of the various state values to customize the Joystick to your liking.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["    struct JoystickConfiguration {","        let isDisabled: Bool \/\/ whether or not the slider is current disables","        let isActive: Bool \/\/ True if the joystick thumb is dragging or if the joystick is locked","        let isAtLimit: Bool \/\/ whether the offset of the thumb reached the radius of the circle","        let isLocked: Bool \/\/ Whether the joystick is locked or not","        let angle: Angle \/\/ The angle of the line between the pads center and the thumbs location, measured from the vector pointing in the trailing direction","        let radialOffset: Double \/\/ The current displacement of the thumb from the track's center","     }"]},{"inlineContent":[{"type":"text","text":"Once your custom style has been created, implement it by calling the "},{"code":"joystickStyle(_ :)","type":"codeVoice"},{"type":"text","text":" method on the "},{"code":"Joystick","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"text","text":"a view containing the "},{"code":"Joystick","type":"codeVoice"},{"type":"text","text":" to be styled. To make it easier try using the follow example based upon the "},{"code":"DefaultJoystickStyle","type":"codeVoice"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["     struct <#My Joystick Style#>: JoystickStyle {","         func makeHitBox(configuration: JoystickConfiguration) -> some View {","             Rectangle()","                 .fill(Color.white.opacity(0.05))","         }","         func makeLockBox(configuration: JoystickConfiguration) -> some View {","             Circle()","                 .fill(Color.black)","                 .overlay(Circle().fill(Color.yellow).scaleEffect(0.7))","                 .frame(width: 25, height: 25)","         }","         func makeTrack(configuration: JoystickConfiguration) -> some View {","             Circle()","                 .fill(Color.gray.opacity(0.4))","         }","         func makeThumb(configuration: JoystickConfiguration) -> some View {","             Circle()","                 .fill(Color.blue)","                 .frame(width: 45, height: 45)","","         }","     }"]}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/init(state:radius:)","doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/init(state:radius:canLock:isDisabled:)","doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/init(state:radius:isDisabled:)"],"title":"Initializers","generated":true,"anchor":"Initializers"},{"identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/body","doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/state"],"title":"Instance Properties","generated":true,"anchor":"Instance-Properties"},{"identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/View-Implementations","doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/View-Implementations"],"title":"Default Implementations","generated":true,"anchor":"Default-Implementations"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/sliders\/joystick"]}],"relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/Sliders\/s8SendableP","doc:\/\/Sliders\/s16SendableMetatypeP","doc:\/\/Sliders\/7SwiftUI4ViewP"],"title":"Conforms To","kind":"relationships"}],"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/TrackPad","doc:\/\/Sliders\/documentation\/Sliders\/RadialPad"],"title":"2D Controls","generated":true,"anchor":"2D-Controls"}],"metadata":{"roleHeading":"Structure","title":"Joystick","symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Joystick"}],"navigatorTitle":[{"text":"Joystick","kind":"identifier"}],"modules":[{"name":"Sliders"}],"externalID":"s:7Sliders8JoystickV","role":"symbol"},"references":{"doc://Sliders/documentation/Sliders/Joystick/body":{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/body","role":"symbol","title":"body","url":"\/documentation\/sliders\/joystick\/body","type":"topic","abstract":[],"kind":"symbol","fragments":[{"text":