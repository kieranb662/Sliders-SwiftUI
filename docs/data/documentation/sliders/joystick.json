{"metadata":{"symbolKind":"struct","role":"symbol","title":"Joystick","modules":[{"name":"Sliders"}],"externalID":"s:7Sliders8JoystickV","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Joystick"}],"navigatorTitle":[{"text":"Joystick","kind":"identifier"}],"roleHeading":"Structure"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Joystick"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"state","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"Binding<JoyState>"},{"text":"  you provide a binding to a Joystate  value which allows you to maintain access to all of the Joysticks state values","type":"text"}]}]},{"name":"radius","content":[{"inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"Double"},{"text":" The radius of the track","type":"text"}],"type":"paragraph"}]},{"name":"canLock","content":[{"type":"paragraph","inlineContent":[{"text":"A boolean value describing whether the joystick has locking behavior (","type":"text"},{"type":"strong","inlineContent":[{"text":"default: true","type":"text"}]},{"text":")","type":"text"}]}]},{"name":"isDisabled","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"Bool"},{"type":"text","text":" whether the joystick allows hit testing or not ("},{"inlineContent":[{"text":"default: false","type":"text"}],"type":"strong"},{"type":"text","text":")"}]}]}]},{"kind":"content","content":[{"anchor":"Style","type":"heading","level":2,"text":"Style"},{"inlineContent":[{"type":"text","text":"The Joystick can be themed and styled by making a custom struct conforming to the "},{"type":"codeVoice","code":"JoystickStyle"},{"type":"text","text":" "},{"type":"text","text":"protocol. Conformance requires that you implement 4 methods"},{"type":"text","text":" "},{"type":"text","text":"1.  "},{"type":"codeVoice","code":"makeHitBox"},{"type":"text","text":" - Creates the rectangular region that responds the the users touch"},{"type":"text","text":" "},{"type":"text","text":"2. "},{"type":"codeVoice","code":"makeLockBox"},{"type":"text","text":" - Creates a view such that if the drag gestures location is contained within the lockbox, the joystick goes into the locked state"},{"type":"text","text":" "},{"text":"3.  ","type":"text"},{"code":"makeTrack","type":"codeVoice"},{"text":" - Creates the circular track that contains the joystick thumb","type":"text"},{"text":" ","type":"text"},{"text":"4   ","type":"text"},{"code":"makeThumb","type":"codeVoice"},{"text":" - Creates the part of the joystick the moves when dragging","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"These 3 methods all provide access to the "},{"type":"codeVoice","code":"JoystickConfiguration"},{"type":"text","text":" ."},{"type":"text","text":" "},{"type":"text","text":"Make use of the various state values to customize the Joystick to your liking."}]},{"type":"codeListing","syntax":null,"code":["    struct JoystickConfiguration {","        let isDisabled: Bool \/\/ whether or not the slider is current disables","        let isActive: Bool \/\/ True if the joystick thumb is dragging or if the joystick is locked","        let isAtLimit: Bool \/\/ whether the offset of the thumb reached the radius of the circle","        let isLocked: Bool \/\/ Whether the joystick is locked or not","        let angle: Angle \/\/ The angle of the line between the pads center and the thumbs location, measured from the vector pointing in the trailing direction","        let radialOffset: Double \/\/ The current displacement of the thumb from the track's center","     }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once your custom style has been created, implement it by calling the "},{"type":"codeVoice","code":"joystickStyle(_ :)"},{"type":"text","text":" method on the "},{"type":"codeVoice","code":"Joystick"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"text","text":"a view containing the "},{"type":"codeVoice","code":"Joystick"},{"type":"text","text":" to be styled. To make it easier try using the follow example based upon the "},{"type":"codeVoice","code":"DefaultJoystickStyle"}]},{"type":"codeListing","syntax":null,"code":["     struct <#My Joystick Style#>: JoystickStyle {","         func makeHitBox(configuration: JoystickConfiguration) -> some View {","             Rectangle()","                 .fill(Color.white.opacity(0.05))","         }","         func makeLockBox(configuration: JoystickConfiguration) -> some View {","             Circle()","                 .fill(Color.black)","                 .overlay(Circle().fill(Color.yellow).scaleEffect(0.7))","                 .frame(width: 25, height: 25)","         }","         func makeTrack(configuration: JoystickConfiguration) -> some View {","             Circle()","                 .fill(Color.gray.opacity(0.4))","         }","         func makeThumb(configuration: JoystickConfiguration) -> some View {","             Circle()","                 .fill(Color.blue)","                 .frame(width: 45, height: 45)","","         }","     }"]}]}],"identifier":{"url":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/Sliders\/documentation\/Sliders"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"topicSections":[{"generated":true,"identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/init(state:radius:)","doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/init(state:radius:canLock:isDisabled:)","doc:\/\/Sliders\/documentation\/Sliders\/Joystic