{"hierarchy":{"paths":[["doc:\/\/Sliders\/documentation\/Sliders"]]},"metadata":{"title":"Joystick","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Joystick"}],"externalID":"s:7Sliders8JoystickV","symbolKind":"struct","role":"symbol","modules":[{"name":"Sliders"}],"navigatorTitle":[{"kind":"identifier","text":"Joystick"}],"roleHeading":"Structure"},"sections":[],"abstract":[{"type":"text","text":"Joystick view used to control various activities such as moving a character on the screen."},{"type":"text","text":" "},{"type":"text","text":"The View creates a Rectangular region to act as a hitbox for drag gestures. Once a drag"},{"type":"text","text":" "},{"type":"text","text":"is initiated the joystick appears on screen centered at the start location of the gesture. While"},{"type":"text","text":" "},{"type":"text","text":"dragging, the thumb of the joystick is limited be within the "},{"type":"codeVoice","code":"radius"},{"type":"text","text":" of the sticks background circle."}],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/init(state:radius:)","doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/init(state:radius:canLock:isDisabled:)","doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/init(state:radius:isDisabled:)"],"title":"Initializers","generated":true},{"identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/body","doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/state"],"generated":true,"anchor":"Instance-Properties","title":"Instance Properties"},{"title":"Default Implementations","identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/View-Implementations","doc:\/\/Sliders\/documentation\/Sliders\/Joystick\/View-Implementations"],"anchor":"Default-Implementations","generated":true}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"Joystick","kind":"identifier"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"state","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"Binding<JoyState>"},{"type":"text","text":"  you provide a binding to a Joystate  value which allows you to maintain access to all of the Joysticks state values"}]}]},{"name":"radius","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"Double","type":"codeVoice"},{"text":" The radius of the track","type":"text"}]}]},{"name":"canLock","content":[{"inlineContent":[{"text":"A boolean value describing whether the joystick has locking behavior (","type":"text"},{"type":"strong","inlineContent":[{"text":"default: true","type":"text"}]},{"type":"text","text":")"}],"type":"paragraph"}]},{"name":"isDisabled","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"Bool"},{"type":"text","text":" whether the joystick allows hit testing or not ("},{"inlineContent":[{"text":"default: false","type":"text"}],"type":"strong"},{"type":"text","text":")"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Style","type":"heading","anchor":"Style","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Joystick can be themed and styled by making a custom struct conforming to the "},{"type":"codeVoice","code":"JoystickStyle"},{"text":" ","type":"text"},{"type":"text","text":"protocol. Conformance requires that you implement 4 methods"},{"type":"text","text":" "},{"type":"text","text":"1.  "},{"type":"codeVoice","code":"makeHitBox"},{"type":"text","text":" - Creates the rectangular region that responds the the users touch"},{"type":"text","text":" "},{"type":"text","text":"2. "},{"code":"makeLockBox","type":"codeVoice"},{"type":"text","text":" - Creates a view such that if the drag gestures location is contained within the lockbox, the joystick goes into the locked state"},{"text":" ","type":"text"},{"text":"3.  ","type":"text"},{"type":"codeVoice","code":"makeTrack"},{"type":"text","text":" - Creates the circular track that contains the joystick thumb"},{"text":" ","type":"text"},{"text":"4   ","type":"text"},{"type":"codeVoice","code":"makeThumb"},{"type":"text","text":" - Creates the part of the joystick the moves when dragging"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"These 3 methods all provide access to the "},{"type":"codeVoice","code":"JoystickConfiguration"},{"type":"text","text":" ."},{"text":" ","type":"text"},{"text":"Make use of the various state values to customize the Joystick to your liking.","type":"text"}]},{"syntax":null,"type":"codeListing","code":["    struct JoystickConfiguration {","        let isDisabled: Bool \/\/ whether or not the slider is current disables","        let isActive: Bool \/\/ True if the joystick thumb is dragging or if the joystick is locked","        let isAtLimit: Bool \/\/ whether the offset of the thumb reached the radius of the circle","        let isLocked: Bool \/\/ Whether the joystick is locked or not","        let angle: Angle \/\/ The angle of the line between the pads center and the thumbs location, measured from the vector pointing in the trailing direction","        let radialOffset: Double \/\/ The current displacement of the thumb from the track's center","     }"]},{"inlineContent":[{"type":"text","text":"Once your custom style has been created, implement it by calling the "},{"type":"codeVoice","code":"joystickStyle(_ :)"},{"type":"text","text":" method on the "},{"type":"codeVoice","code":"Joystick"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"text":"a view containing the ","type":"text"},{"type":"codeVoice","code":"Joystick"},{"type":"text","text":" to be styled. To make it easier try using the follow example based upon the "},{"type":"codeVoice","code":"DefaultJoystickStyle"}],"type":"paragraph"},{"syntax":null,"code":["     struct <#My Joystick Style#>: JoystickStyle {","         func makeHitBox(configuration: JoystickConfiguration) -> some View {","             Rectangle()","                 .fill(Color.white.opacity(0.05))","         }","         func makeLockBox(configuration: JoystickConfiguration) -> some View {","             Circle()","                 .fill(Color.black)","                 .overlay(Circle().fill(Color.yellow).scaleEffect(0.7))","                 .frame(width: 25, height: 25)","         }","         func makeTrack(configuration: JoystickConfiguration) -> some View {","             Circle()","                 .fill(Color.gray.opacity(0.4))","         }","         func makeThumb(configuration: JoystickConfiguration) -> some View {","             Circle()","                 .fill(Color.blue)","                 .frame(width: 45, height: 45)","","         }","     }"],"type":"codeListing"}]}],"identifier":{"url":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick","interfaceLanguage":"swift"},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"relationshipsSections":[{"identifiers":["doc:\/\/Sliders\/s8SendableP","doc:\/\/Sliders\/s16SendableMetatypeP","doc:\/\/Sliders\/7SwiftUI4ViewP"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/sliders\/joystick"]}],"references":{"doc://Sliders/documentation/Sliders/Joystick":{"url":"\/documentation\/sliders\/joystick","navigatorTitle":[{"text":"Joystick","kind":"identifier"}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"Joystick","kind":"identifier"}],"abstract":[{"text":"Joystick view used to control various activities such as moving a character on the screen.","type":"text"},{