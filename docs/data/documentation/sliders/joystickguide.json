":"topic","role":"collectionGroup"},"doc://Sliders/documentation/Sliders/OverflowSlider":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OverflowSlider"}],"navigatorTitle":[{"kind":"identifier","text":"OverflowSlider"}],"role":"symbol","abstract":[{"type":"text","text":"A Slider which has a fixed frame but a movable track in the background. Used for values that have a discrete nature to them but would not necessarily fit on screen."},{"type":"text","text":" "},{"text":"Both the thumb and track can be dragged, if the track is dragged and thrown the velocity of the throw is added to the tracks velocity and it slows gradually to a stop.","type":"text"},{"text":" ","type":"text"},{"text":"If the thumb is currently being dragged and reachs the minimum or maximum value of its bounds, velocity is added to the track in the opposite direction of the drag.","type":"text"}],"title":"OverflowSlider","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","type":"topic","kind":"symbol","url":"\/documentation\/sliders\/overflowslider"},"doc://Sliders/documentation/Sliders/RadialPad":{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RadialPad","role":"symbol","type":"topic","kind":"symbol","abstract":[{"text":"A control that constrains the drag gesture of the thumb to be contained within the radius","type":"text"},{"text":" ","type":"text"},{"text":"of a circular track.  Similar to a joystick, except the thumb stays where the drag ended.","type":"text"}],"url":"\/documentation\/sliders\/radialpad","title":"RadialPad","navigatorTitle":[{"text":"RadialPad","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RadialPad","kind":"identifier"}]},"doc://Sliders/documentation/Sliders/LSlider":{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","kind":"symbol","title":"LSlider","type":"topic","role":"symbol","abstract":[{"text":"A fully stylable li