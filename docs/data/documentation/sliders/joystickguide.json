{"sections":[],"kind":"article","metadata":{"role":"collectionGroup","modules":[{"name":"Sliders"}],"roleHeading":"API Collection","title":"Joystick Guide"},"abstract":[{"type":"text","text":"A deep dive into "},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick","isActive":true,"type":"reference"},{"type":"text","text":" — the on-screen joystick that appears wherever the user drags within a hit-box."}],"topicSections":[{"title":"Essentials","identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/Joystick","doc:\/\/Sliders\/documentation\/Sliders\/JoystickStyle","doc:\/\/Sliders\/documentation\/Sliders\/JoystickConfiguration"],"anchor":"Essentials"},{"title":"Tutorials","identifiers":["doc:\/\/Sliders\/tutorials\/Joystick-Tutorials"],"anchor":"Tutorials"}],"primaryContentSections":[{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick","type":"reference"},{"type":"text","text":" is an on-screen joystick control that can appear anywhere the user drags within a defined hit-box. If the drag ends inside a lock-box region, the joystick remains on screen locked in the forward position. If the drag ends outside the lock-box the joystick fades away until the hit-box is dragged again."}]},{"text":"What it does","anchor":"What-it-does","level":3,"type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Creates a "},{"inlineContent":[{"text":"rectangular hit-box","type":"text"}],"type":"strong"},{"type":"text","text":" that responds to drag gestures."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"On drag, the joystick appears centred at the gesture’s start location."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The thumb is constrained to a circle of the given ","type":"text"},{"code":"radius","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"lock-box"}]},{"type":"text","text":" above the start position lets the user lock the joystick in place."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Provides ","type":"text"},{"type":"codeVoice","code":"angle"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"radialOffset"},{"type":"text","text":" through the bound "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/JoyState"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Fully stylable via the "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/JoystickStyle","isActive":true},{"type":"text","text":" protocol."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"Parameters","anchor":"Parameters"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Parameter"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Default","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"state"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Binding<JoyState>"}],"type":"paragraph"}],[{"inlineContent":[{"text":"required","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"A binding to a ","type":"text"},{"code":"JoyState","type":"codeVoice"},{"text":" value that exposes all of the joystick’s state","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"radius"}],"type":"paragraph"}],[{"inlineContent":[{"code":"Double","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"required"}],"type":"paragraph"}],[{"inlineContent":[{"text":"The radius of the circular track","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"canLock","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Bool"}]}],[{"type":"paragraph","inlineContent":[{"code":"true","type":"codeVoice"}]}],[{"inlineContent":[{"type":"text","text":"Whether the joystick has locking behaviour"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"isDisabled"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Bool"}],"type":"paragraph"}],[{"inlineContent":[{"code":"false","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Whether the joystick allows hit testing"}],"type":"paragraph"}]]]},{"type":"heading","anchor":"JoyState","text":"JoyState","level":2},{"type":"paragraph","inlineContent":[{"code":"JoyState","type":"codeVoice"},{"text":" is an enumeration that represents the joystick’s current state:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":".inactive"},{"type":"text","text":" — the joystick is hidden."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":".locked"},{"type":"text","text":" — the joystick is locked in place after a drag ended inside the lock-box."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".dragging(time:translation:startLocation:velocity:acceleration:)"},{"text":" — the user is actively dragging.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Useful computed properties:","type":"text"}]},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Property"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Type","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"isActive"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Bool"}]}],[{"type":"paragraph","inlineContent":[{"code":"true","type":"codeVoice"},{"text":" when dragging or locked","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"isLocked","type":"codeVoice"}]}],[{"inlineContent":[{"type":"codeVoice","code":"Bool"}],"type":"paragraph"}],[{"inlineContent":[{"code":"true","type":"codeVoice"},{"text":" when locked","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"isDragging"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Bool"}],"type":"paragraph"}],[{"inlineContent":[{"code":"true","type":"codeVoice"},{"type":"text","text":" when actively dragging"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"angle","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"Angle","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Direction from centre to thumb"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"radialOffset"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Double"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Distance from centre to thumb"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"translation","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"CGSize","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Current drag translation"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"velocity","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"CGSize"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Current drag velocity"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"acceleration","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"CGSize"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Current drag acceleration"}],"type":"paragraph"}]]]},{"anchor":"Basic-Usage","type":"heading","text":"Basic Usage","level":2},{"syntax":"swift","code":["@State private var joyState: JoyState = .inactive","","Joystick(state: $joyState, radius: 60)","    .frame(width: 300, height: 300)"],"type":"codeListing"},{"anchor":"Disabling-Lock","type":"heading","text":"Disabling Lock","level":3},{"syntax":"swift","code":["Joystick(state: $joyState, radius: 60, canLock: false, isDisabled: false)","    .frame(width: 300, height: 300)"],"type":"codeListing"},{"anchor":"Reading-State","type":"heading","text":"Reading State","level":3},{"syntax":"swift","code":["@State private var joyState: JoyState = .inactive","","VStack {","    Text(\"Angle: \\(joyState.angle.degrees, specifier: \"%.0f\")°\")","    Text(\"Offset: \\(joyState.radialOffset, specifier: \"%.1f\")\")","    Text(\"Locked: \\(joyState.isLocked ? \"Yes\" : \"No\")\")","","    Joystick(state: $joyState, radius: 60)","        .frame(width: 300, height: 300)","}"],"type":"codeListing"},{"anchor":"JoystickConfiguration","type":"heading","text":"JoystickConfiguration","level":2},{"inlineContent":[{"type":"text","text":"All style methods receive a "},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/JoystickConfiguration","type":"reference","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["struct JoystickConfiguration {","    let isDisabled: Bool","    let isActive: Bool","    let isAtLimit: Bool","    let isLocked: Bool","    let angle: Angle","    let radialOffset: Double","}"],"type":"codeListing"},{"anchor":"Styling","type":"heading","text":"Styling","level":2},{"inlineContent":[{"type":"text","text":"Conform to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/JoystickStyle"},{"type":"text","text":" and implement four methods:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":