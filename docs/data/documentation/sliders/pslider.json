xt","text":" "},{"text":"1. ","type":"text"},{"type":"codeVoice","code":"makeThumb"},{"text":": which creates the draggable portion of the slider","type":"text"},{"text":" ","type":"text"},{"text":"2. ","type":"text"},{"code":"makeTrack","type":"codeVoice"},{"text":": which creates the track which fills or emptys as the thumb is dragging within it","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both methods provide access to state values through the "},{"code":"PSliderConfiguration","type":"codeVoice"},{"type":"text","text":" struct"}]},{"syntax":null,"type":"codeListing","code":["struct PSliderConfiguration {","    let isDisabled: Bool \/\/ whether or not  the slider is disabled","    let isActive: Bool \/\/ whether or not the thumb is currently dragging","    let pctFill: Double  \/\/ The percentage of the sliders track that is filled","    let value: Double \/\/ The current value of the slider","    let angle: Angle \/\/ Angle of the thumb","    let min: Double  \/\/ The minimum value of the sliders range","    let max: Double \/\/ The maximum value of the sliders range","}"]},{"inlineContent":[{"type":"text","text":"To make this easier just copy and paste the following style based on the "},{"type":"codeVoice","code":"DefaultPSliderStyle"},{"text":". After creating your custom style","type":"text"},{"type":"text","text":" "},{"type":"text","text":"apply it by calling the "},{"type":"codeVoice","code":"pathSliderStyle"},{"type":"text","text":" method on the "},{"type":"codeVoice","code":"PSlider"},{"type":"text","text":" or a view containing it."}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["    struct <#My PSlider Style#>: PSliderStyle {","        func makeThumb(configuration:  PSliderConfiguration) -> some View {","            Circle()","            .frame(width: 30, height:30)","            .foregroundColor(configuration.isActive ? Color.yellow : Color.white)","        }","","        func makeTrack(configurati