],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Both methods provide access to state values through the "},{"code":"PSliderConfiguration","type":"codeVoice"},{"text":" struct","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["struct PSliderConfiguration {","    let isDisabled: Bool \/\/ whether or not  the slider is disabled","    let isActive: Bool \/\/ whether or not the thumb is currently dragging","    let pctFill: Double  \/\/ The percentage of the sliders track that is filled","    let value: Double \/\/ The current value of the slider","    let angle: Angle \/\/ Angle of the thumb","    let min: Double  \/\/ The minimum value of the sliders range","    let max: Double \/\/ The maximum value of the sliders range","}"]},{"inlineContent":[{"text":"To make this easier just copy and paste the following style based on the ","type":"text"},{"code":"DefaultPSliderStyle","type":"codeVoice"},{"text":". After creating your custom style","type":"text"},{"text":" ","type":"text"},{"text":"apply it by calling the ","type":"text"},{"code":"pathSliderStyle","type":"codeVoice"},{"text":" method on the ","type":"text"},{"code":"PSlider","type":"codeVoice"},{"text":" or a view containing it.","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["    struct <#My PSlider Style#>: PSliderStyle {","        func makeThumb(configuration:  PSliderConfiguration) -> some View {","            Circle()","            .frame(width: 30, height:30)","            .foregroundColor(configuration.isActive ? Color.yellow : Color.white)","        }","","        func makeTrack(configuration:  PSliderConfiguration) -> some View {","            configuration.shape","                .stroke(Color.gray, lineWidth: 8)","                .overlay(","                    configuration.shape","                    .trim(from: 0, to: CGFloat(configuration.pctFill))","                .stroke(Color.purple, lineWidth: 10))","        }","    }