"kind":"symbol","identifier":"doc:\/\/Sliders\/documentation\/Sliders","url":"\/documentation\/sliders","role":"collection","abstract":[{"text":"A collection of fully stylable, drag-based SwiftUI controls — including linear, radial, range, and 2D sliders.","type":"text"}],"type":"topic"},"doc://Sliders/documentation/Sliders/Joystick":{"title":"Joystick","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Joystick"}],"navigatorTitle":[{"kind":"identifier","text":"Joystick"}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick","url":"\/documentation\/sliders\/joystick","role":"symbol","abstract":[{"text":"Joystick view used to control various activities such as moving a character on the screen.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The View creates a Rectangular region to act as a hitbox for drag gestures. Once a drag"},{"text":" ","type":"text"},{"text":"is initiated the joystick appears on screen centered at the start location of the gesture. While","type":"text"},{"type":"text","text":" "},{"type":"text","text":"dragging, the thumb of the joystick is limited be within the "},{"type":"codeVoice","code":"radius"},{"type":"text","text":" of the sticks background circle."}],"type":"topic"}}}