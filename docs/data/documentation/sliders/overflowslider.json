{"metadata":{"role":"symbol","roleHeading":"Structure","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"OverflowSlider","kind":"identifier"}],"title":"OverflowSlider","symbolKind":"struct","externalID":"s:7Sliders14OverflowSliderV","navigatorTitle":[{"text":"OverflowSlider","kind":"identifier"}],"modules":[{"name":"Sliders"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OverflowSlider"}],"platforms":["macOS"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"Binding<Double>"},{"type":"text","text":" The value the slider should control"}]}],"name":"value"},{"content":[{"inlineContent":[{"type":"text","text":""},{"code":"ClosedRange<Double>","type":"codeVoice"},{"text":" The minimum and maximum numbers that ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" can be"}],"type":"paragraph"}],"name":"range"},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"Bool"},{"type":"text","text":" Whether or not the slider should be disabled"}]}],"name":"isDisabled"}],"kind":"parameters"},{"content":[{"level":2,"text":"Styling The Slider","anchor":"Styling-The-Slider","type":"heading"},{"inlineContent":[{"type":"text","text":"To create a custom style for the slider you need to create a "},{"code":"OverflowSliderStyle","type":"codeVoice"},{"text":" conforming struct. Conformnance requires implementation of 2 methods","type":"text"},{"text":" ","type":"text"},{"text":"1. ","type":"text"},{"code":"makeThumb","type":"codeVoice"},{"text":": which creates the draggable portion of the slider","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"2. "},{"code":"makeTrack","type":"codeVoice"},{"type":"text","text":": which creates the draggable background track"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Both methods provide access to the sliders current state thru the ","type":"text"},{"type":"codeVoice","code":"OverflowSliderConfiguration"},{"text":" of the ","type":"text"},{"type":"codeVoice","code":"OverflowSlider "},{"text":"to be styled.","type":"text"}]},{"code":["        struct OverflowSliderConfiguration {","            let isDisabled: Bool \/\/ Whether the control is disabled or not","            let thumbIsActive: Bool \/\/ Whether the thumb is currently dragging or not","            let thumbIsAtLimit: Bool \/\/ Whether the thumb has reached its min\/max displacement","            let trackIsActive: Bool \/\/ Whether of not the track is dragging","            let trackIsAtLimit: Bool \/\/ Whether the track has reached its min\/max position","            let value: Double \/\/ The current value of the slider","            let min: Double \/\/ The minimum value of the sliders range","            let max: Double \/\/ The maximum value of the sliders range","            let tickSpacing: Double \/\/ The spacing of the sliders tick marks","        }"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"type":"text","text":"To make this easier just copy and paste the following style based on the "},{"type":"codeVoice","code":"DefaultOverflowSliderStyle"},{"type":"text","text":". After creating your custom style"},{"type":"text","text":" "},{"type":"text","text":"apply it by calling the "},{"type":"codeVoice","code":"overflowSliderStyle"},{"text":" method on the ","type":"text"},{"type":"codeVoice","code":"OverflowSlider"},{"text":" or a view containing it.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["    struct <#My OverflowSlider Style#>: OverflowSliderStyle {","        func makeThumb(configuration: OverflowSliderConfiguration) -> some View {","            RoundedRectangle(cornerRadius: 5)","                .fill(configuration.thumbIsActive ?  Color.orange : Color.blue)","                .opacity(0.5)","                .frame(width: 20, height: 50)","        }","        func makeTrack(configuration: OverflowSliderConfiguration) -> some View {","            let totalLength = configuration.max-configuration.min","            let spacing = configuration.tickSpacing","","            return TickMarks(spacing: CGFloat(spacing), ticks: Int(totalLength\/Double(spacing)))","                .stroke(Color.gray)","                .frame(width: CGFloat(totalLength))","        }","    }"]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/Sliders\/documentation\/Sliders"]]},"identifier":{"url":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/sliders\/overflowslider"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"A Slider which has a fixed frame but a movable track in the background. Used for values that have a discrete nature to them but would not necessarily fit on screen."},{"type":"text","text":" "},{"text":"Both the thumb and track can be dragged, if the track is dragged and thrown the velocity of the throw is added to the tracks velocity and it slows gradually to a stop.","type":"text"},{"text":" ","type":"text"},{"text":"If the thumb is currently being dragged and reachs the minimum or maximum value of its bounds, velocity is added to the track in the opposite direction of the drag.","type":"text"}],"topicSections":[{"identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider\/init(value:range:spacing:isDisabled:)"],"anchor":"Initializers","generated":true,"title":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider\/body","doc: