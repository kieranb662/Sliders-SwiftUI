ift","url":"doc:\/\/Sliders\/tutorials\/Sliders\/OverflowSlider-Basics"},"metadata":{"categoryPathComponent":"OverflowSlider-Tutorials","category":"OverflowSlider","role":"project","title":"Using OverflowSlider with the Default Style"},"hierarchy":{"paths":[["doc:\/\/Sliders\/tutorials\/OverflowSlider-Tutorials","doc:\/\/Sliders\/tutorials\/OverflowSlider-Tutorials\/$volume","doc:\/\/Sliders\/tutorials\/OverflowSlider-Tutorials\/Using-the-Default-Style"]],"modules":[{"projects":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/OverflowSlider-Basics","sections":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/OverflowSlider-Basics#Basic-Usage","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/OverflowSlider-Basics#Velocity-Gestures","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/OverflowSlider-Basics#Custom-Style","kind":"task"}]}],"reference":"doc:\/\/Sliders\/tutorials\/OverflowSlider-Tutorials\/Using-the-Default-Style"}],"reference":"doc:\/\/Sliders\/tutorials\/OverflowSlider-Tutorials"},"variants":[{"paths":["\/tutorials\/sliders\/overflowslider-basics"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://Sliders/documentation/Sliders/OverflowSliderStyle":{"role":"symbol","title":"OverflowSliderStyle","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSliderStyle","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OverflowSliderStyle","kind":"identifier"}],"url":"\/documentation\/sliders\/overflowsliderstyle","type":"topic","kind":"symbol","abstract":[],"navigatorTitle":[{"text":"OverflowSliderStyle","kind":"identifier"}]},"OverflowSlider_Basics_Step_3.swift":{"fileName":"ContentView.swift","syntax":"swift","identifier":"OverflowSlider_Basics_Step_3.swift","content":["import SwiftUI","","struct ContentView: View {","    @State private var value = 100.0","","    var body: some View {","        VStack {","            Text(\"Value: \\(Int(value))\")","                .font(.headline)","","            Text(\"Drag the track quickly and release to throw it\")","                .font(.caption)","                .foregroundStyle(.secondary)","","            OverflowSlider(value: $value, range: 0...500, spacing: 10, isDisabled: false)","                .frame(height: 60)","        }","        .padding()","    }","}"],"fileType":"swift","type":"file","highlights":[]},"OverflowSlider_Basics_Step_2.png":{"variants":[{"url":"\/images\/Sliders\/OverflowSlider_Basics_Step_2.png","traits":["1x","light"]}],"identifier":"OverflowSlider_Basics_Step_2.png","alt":"OverflowSlider with wider range and finer spacing","type":"image"},"doc://Sliders/tutorials/Sliders/OverflowSlider-Basics#Basic-Usage":{"abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider"},{"text":" is a meter-style slider with a fixed frame but a movable track.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll explore its configuration options — from basic usage to","type":"text"},{"text":" ","type":"text"},{"text":"tick spacing, velocity gestures, and custom styling.","type":"text"}],"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/OverflowSlider-Basics#Basic-Usage","url":"\/tutorials\/sliders\/overflowslider-basics#Basic-Usage","title":"Basic Usage","role":"pseudoSymbol","kind":"section","type":"section"},"OverflowSlider_Basics_Step_4.png":{"alt":"Custom styled OverflowSlider","identifier":"OverflowSlider_Basics_Step_4.png","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/OverflowSlider_Basics_Step_4.png"}]},"doc://Sliders/tutorials/Sliders/OverflowSlider-Basics#Velocity-Gestures":{"url":"\/tutorials\/sliders\/overflowslider-basics#Velocity-Gestures","title":"Velocity Gestures","kind":"section","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/OverflowSlider-Basics#Velocity-Gestures","abstract":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","isActive":true},{"type":"text","text":" is a meter-style slider with a fixed frame but a movable track."},{"type":"text","text":" "},{"text":"In this tutorial you’ll explore its configuration options — from basic usage to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"tick spacing, velocity gestures, and custom styling."}],"type":"section","role":"pseudoSymbol"},"doc://Sliders/tutorials/OverflowSlider-Tutorials":{"url":"\/tutorials\/overflowslider-tutorials","title":"Building Meter Sliders with OverflowSlider","kind":"overview","identifier":"doc:\/\/Sliders\/tutorials\/OverflowSlider-Tutorials","abstract":[{"type":"text","text":"Learn how to add a meter-style overflow slider to your app using the built-in"},{"type":"text","text":" "},{"type":"text","text":"default style and its configuration options."}],"type":"topic","role":"overview"},"OverflowSlider_Basics_Step_1.swift":{"fileName":"ContentView.swift","syntax":"swift","identifier":"OverflowSlider_Basics_Step_1.swift","content":["import SwiftUI","","struct ContentView: View {","    @State private var value = 50.0","","    var body: some View {","        OverflowSlider(value: $value, range: 0...500, spacing: 10, isDisabled: false)","            .frame(height: 60)","            .padding()","    }","}"],"fileType":"swift","type":"file","highlights":[]},"doc://Sliders/tutorials/Sliders/OverflowSlider-Basics#Custom-Style":{"kind":"section","abstract":[{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","type":"reference"},{"type":"text","text":" is a meter-style slider with a fixed frame but a movable track."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore its configuration options — from basic usage to"},{"type":"text","text":" "},{"type":"text","text":"tick spacing, velocity gestures, and custom styling."}],"role":"pseudoSymbol","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/OverflowSlider-Basics#Custom-Style","title":"Custom Style","type":"section","url":"\/tutorials\/sliders\/overflowslider-basics#Custom-Style"},"OverflowSlider_Basics_Step_3.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/OverflowSlider_Basics_Step_3.png"}],"identifier":"OverflowSlider_Basics_Step_3.png","alt":"Track velocity behaviour","type":"image"},"OverflowSlider_Basics_Step_4.swift":{"syntax":"swift","content":["import SwiftUI","","struct MyOverflowSliderStyle: OverflowSliderStyle {","    func makeThumb(configuration: OverflowSliderConfiguration) -> some View {","        RoundedRectangle(cornerRadius: 5)","            .fill(configuration.thumbIsActive ? Color.orange : Color.blue)","            .opacity(0.5)","            .frame(width: 20, height: 50)","    }","","    func makeTrack(configuration: OverflowSliderConfiguration) -> some View {","        let totalLength = configuration.max - configuration.min","        let spacing = configuration.tickSpacing","","        return TickMarks(","            spacing: CGFloat(spacing),","            ticks: Int(totalLength \/ Double(spacing))","        )","        .stroke(Color.orange.opacity(0.6))","        .frame(width: CGFloat(totalLength))","    }","}","","struct ContentView: View {","    @State private var value = 50.0","","    var body: some View {","        OverflowSlider(value: $value, range: 0...500, spacing: 10, isDisabled: false)","            .overflowSliderStyle(MyOverflowSliderStyle())","            .frame(height: 60)","            .padding()","    }","}"],"fileType":"swift","identifier":"OverflowSlider_Basics_Step_4.swift","highlights":[],"fileName":"ContentView.swift","type":"file"},"OverflowSlider_Basics_Step_1.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/OverflowSlider_Basics_Step_1.png"}],"type":"image","identifier":"OverflowSlider_Basics_Step_1.png","alt":"A minimal default OverflowSlider"},"doc://Sliders/documentation/Sliders/OverflowSlider":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OverflowSlider"}],"navigatorTitle":[{"kind":"identifier","text":"OverflowSlider"}],"role":"symbol","abstract":[{"type":"text","text":"A Slider which has a fixed frame but a movable track in the background. Used for values that have a discrete nature to them but would not necessarily fit on screen."},{"type":"text","text":" "},{"text":"Both the thumb and track can be dragged, if the track is dragged and thrown the velocity of the throw is added to the tracks velocity and it slows gradually to a stop.","type":"text"},{"text":" ","type":"text"},{"text":"If the thumb is currently being dragged and reachs the minimum or maximum value of its bounds, velocity is added to the track in the opposite direction of the drag.","type":"text"}],"title":"OverflowSlider","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","type":"topic","kind":"symbol","url":"\/documentation\/sliders\/overflowslider"},"OverflowSlider_Basics_Step_2.swift":{"fileName":"ContentView.swift","syntax":"swift","identifier":"OverflowSlider_Basics_Step_2.swift","content":["import SwiftUI","","struct ContentView: View {","    @State private var value = 250.0","","    var body: some View {","        OverflowSlider(value: $value, range: 0...1000, spacing: 25, isDisabled: false)","            .frame(height: 60)","            .padding()","    }","}"],"fileType":"swift","type":"file","highlights":[{"line":4},{"line":7}]},"doc://Sliders/tutorials/OverflowSlider-Tutorials/Using-the-Default-Style":{"url":"\/tutorials\/overflowslider-tutorials\/using-the-default-style","title":"Using the Default Style","kind":"article","identifier":"doc:\/\/Sliders\/tutorials\/OverflowSlider-Tutorials\/Using-the-Default-Style","abstract":[],"type":"topic","role":"article"},"doc://Sliders/tutorials/Sliders/OverflowSlider-Basics":{"url":"\/tutorials\/sliders\/overflowslider-basics","title":"Using OverflowSlider with the Default Style","estimatedTime":"10min",