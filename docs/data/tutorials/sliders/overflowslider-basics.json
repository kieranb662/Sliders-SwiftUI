estures","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The track responds to velocity-based gestures — throw the track and it"},{"type":"text","text":" "},{"type":"text","text":"decelerates naturally."}]}],"media":"OverflowSlider_Basics_Step_3.png","mediaPosition":"trailing"}]},{"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Create a custom style and apply it with "},{"type":"codeVoice","code":".overflowSliderStyle(_:)"},{"type":"text","text":"."}],"type":"paragraph"}],"caption":[],"runtimePreview":"OverflowSlider_Basics_Step_4.png","media":null,"type":"step","code":"OverflowSlider_Basics_Step_4.swift"}],"anchor":"Custom-Style","title":"Custom Style","contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"Conform to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSliderStyle"},{"type":"text","text":" to customise the thumb and track appearance."}],"type":"paragraph"}],"mediaPosition":"trailing","media":"OverflowSlider_Basics_Step_4.png","kind":"contentAndMedia"}]}],"kind":"tasks"}],"references":{"doc://Sliders/tutorials/OverflowSlider-Tutorials":{"abstract":[{"type":"text","text":"Learn how to add a meter-style overflow slider to your app using the built-in"},{"type":"text","text":" "},{"type":"text","text":"default style and its configuration options."}],"role":"overview","identifier":"doc:\/\/Sliders\/tutorials\/OverflowSlider-Tutorials","title":"Building Meter Sliders with OverflowSlider","url":"\/tutorials\/overflowslider-tutorials","kind":"overview","type":"topic"},"OverflowSlider_Basics_Step_1.png":{"identifier":"OverflowSlider_Basics_Step_1.png","alt":"A minimal default OverflowSlider","variants":[{"url":"\/images\/Sliders\/OverflowSlider_Basics_Step_1.png","traits":["1x","light"]}],"type":"image"},"OverflowSlider_Basics_Step_4.swift":{"identifier":"OverflowSlider_Basics_Step_4.swift","type":"file","syntax":"swift","fileName":"ContentView.swift","highlights":[],"content":["import SwiftUI","","struct MyOverflowSliderStyle: OverflowSliderStyle {","    func makeThumb(configuration: OverflowSliderConfiguration) -> some View {","        RoundedRectangle(cornerRadius: 5)","            .fill(configuration.thumbIsActive ? Color.orange : Color.blue)","            .opacity(0.5)","            .frame(width: 20, height: 50)","    }","","    func makeTrack(configuration: OverflowSliderConfiguration) -> some View {","        let totalLength = configuration.max - configuration.min","        let spacing = configuration.tickSpacing","","        return TickMarks(","            spacing: CGFloat(spacing),","            ticks: Int(totalLength \/ Double(spacing))","        )","        .stroke(Color.orange.opacity(0.6))","        .frame(width: CGFloat(totalLength))","    }","}","","struct ContentView: View {","    @State private var value = 50.0","","    var body: some View {","        OverflowSlider(value: $value, range: 0...500, spacing: 10, isDisabled: false)","            .overflowSliderStyle(MyOverflowSliderStyle())","            .frame(height: 60)","            .padding()","    }","}"],"fileType":"swift"},"doc://Sliders/tutorials/Sliders/OverflowSlider-Basics":{"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/OverflowSlider-Basics","kind":"project","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","type":"reference","isActive":true},{"type":"text","text":" is a meter-style slider with a fixed frame but a movable track."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore its configuration options — from basic usage to"},{"type":"text","text":" "},{"type":"text","text":"tick spacing, velocity gestures, and custom styling."}],"url":"\/tutorials\/sliders\/overflowslider-basics","type":"topic","role":"project","estimatedTime":"10min","title":"Using OverflowSlider with the Default Style"},"doc://Sliders/tutorials/Overfl