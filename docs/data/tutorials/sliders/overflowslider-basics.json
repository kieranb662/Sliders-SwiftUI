cumentation/Sliders/OverflowSlider":{"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OverflowSlider"}],"kind":"symbol","abstract":[{"type":"text","text":"A Slider which has a fixed frame but a movable track in the background. Used for values that have a discrete nature to them but would not necessarily fit on screen."},{"type":"text","text":" "},{"type":"text","text":"Both the thumb and track can be dragged, if the track is dragged and thrown the velocity of the throw is added to the tracks velocity and it slows gradually to a stop."},{"type":"text","text":" "},{"type":"text","text":"If the thumb is currently being dragged and reachs the minimum or maximum value of its bounds, velocity is added to the track in the opposite direction of the drag."}],"role":"symbol","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","url":"\/documentation\/sliders\/overflowslider","navigatorTitle":[{"text":"OverflowSlider","kind":"identifier"}],"type":"topic","title":"OverflowSlider"},"doc://Sliders/tutorials/Sliders/OverflowSlider-Basics#Velocity-Gestures":{"url":"\/tutorials\/sliders\/overflowslider-basics#Velocity-Gestures","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/OverflowSlider-Basics#Velocity-Gestures","title":"Velocity Gestures","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider"},{"type":"text","text":" is a meter-style slider with a fixed frame but a movable track."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore its configuration options — from basic usage to"},{"type":"text","text":" "},{"type":"text","text":"tick spacing, velocity gestures, and custom styling."}],"kind":"section","type":"section","role":"pseudoSymbol"},"doc://Sliders/tutorials/Sliders/OverflowSlider-Basics#Basic-Usage":{"url":"\/tutorials\/sliders\/overflowslider-basics#Basic-Usage","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/OverflowSlider-Basics#Basic-Usage","title":"Basic Usage","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider"},{"type":"text","text":" is a meter-style slider with a fixed frame but a movable track."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore its configuration options — from basic usage to"},{"type":"text","text":" "},{"type":"text","text":"tick spacing, velocity gestures, and custom styling."}],"kind":"section","type":"section","role":"pseudoSymbol"},"OverflowSlider_Basics_Step_3.png":{"type":"image","identifier":"OverflowSlider_Basics_Step_3.png","alt":"Track velocity behaviour","variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/OverflowSlider_Basics_Step_3.png"}]},"doc://Sliders/tutorials/Sliders/OverflowSlider-Basics":{"abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","isActive":true,"type":"reference"},{"text":" is a meter-style slider with a fixed frame but a movable track.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll explore its configuration options — from basic usage to","type":"text"},{"text":" ","type":"text"},{"text":"tick spacing, velocity gestures, and custom styling.","type":"text"}],"title":"Using OverflowSlider with the Default Style","url":"\/tutorials\/sliders\/overflowslider-basics","estimatedTime":"10min","type":"topic","role":"project","kind":"project","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/OverflowSlider-Basics"},"OverflowSlider_Basics_Step_1.png":{"identifier":"OverflowSlider_Basics_Step_1.png","alt":"A minimal default OverflowSlider","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/OverflowSlider_Basics_Step_1.png"}]},"doc://Sliders/tutorials/Sliders/OverflowSlider-Basics#Custom-Style":{"abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider"},{"type":"text","text":" is a meter-style slider with a fixed frame but a movable track."},{"type":"text","text":" "},{"text":"In this tutorial you’ll explore its configuration options — from basic usage to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"tick spacing, velocity gestures, and custom styling."}],"title":"Custom Style","url":"\/tutorials\/sliders\/overflowslider-basics#Custom-Style","type":"section","role":"pseudoSymbol","kind":"section","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/OverflowSlider-Basics#Custom-Style"},"doc://Sliders/tutorials/OverflowSlider-Tutorials":{"kind":"overview","abstract":[{"type":"text","text":"Learn how to add a meter-style overflow slider to your app using the built-in"},{"text":" ","type":"text"},{"text":"default style and its configuration options.","type":"text"}],"identifier":"doc:\/\/Sliders\/tutorials\/OverflowSlider-Tutorials","title":"Building Meter Sliders with OverflowSlider","url":"\/tutorials\/overflowslider-tutorials","role":"overview","type":"topic"},"OverflowSlider_Basics_Step_4.swift":{"content":["import SwiftUI","","struct MyOverflowSliderStyle: OverflowSliderStyle {","    func makeThumb(configuration: OverflowSliderConfiguration) -> some View {","        RoundedRectangle(cornerRadius: 5)","            .fill(configuration.thumbIsActive ? Color.orange : Color.blue)","            .opacity(0.5)","            .frame(width: 20, height: 50)","    }","","    func makeTrack(configuration: OverflowSliderConfiguration) -> some View {","        let totalLength = configuration.max - configuration.min","        let spacing = configuration.tickSpacing","","        return TickMarks(","            spacing: CGFloat(spacing),","            ticks: Int(totalLength \/ Double(spacing))","        )","        .stroke(Color.orange.opacity(0.6))","        .frame(width: CGFloat(totalLength))","    }","}","","struct ContentView: View {","    @State private var value = 50.0","","    var body: some View {","        OverflowSlider(value: $value, range: 0...500, spacing: 10, isDisabled: false)","            .overflowSliderStyle(MyOverflowSliderStyle())","            .frame(height: 60)","            .padding()","    }","}"],"highlights":[],"fileName":"ContentView.swift","type":"file","identifier":"OverflowSlider_Basics_Step_4.swift","fileType":"swift","syntax":"swift"},"OverflowSlider_Basics_Step_2.png":{"identifier":"OverflowSlider_Basics_Step_2.png","type":"image","alt":"OverflowSlider with wider range and finer spacing","variants":[{"url":"\/images\/Sliders\/OverflowSlider_Basics_Step_2.png","traits":["1x","light"]}]},"OverflowSlider_Basics_Step_2.swift":{"fileType":"swift","highlights":[{"line":4},{"line":7}],"identifier":"OverflowSlider_Basics_Step_2.swift","content":["import SwiftUI","","struct ContentView: View {","    @State private var value = 250.0","","    var body: some View {","        OverflowSlider(value: $value, range: 0...1000, spacing: 25, isDisabled: false)","            .frame(height: 60)","            .padding()","    }","}"],"syntax":"swift","fileName":"ContentView.swift","type":"file"},"doc://Sliders/documentation/Sliders/OverflowSliderStyle":{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSliderStyle","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"OverflowSliderStyle","kind":"identifier"}],"navigatorTitle":[{"text":"OverflowSliderStyle","kind":"identifier"}],"url":"\/documentation\/sliders\/overflowsliderstyle","title":"OverflowSliderStyle","kind":"symbol","type":"topic","role":"symbol","abstract":[]},"OverflowSlider_Basics_Step_3.swift":{"identifier":"OverflowSlider_Basics_Step_3.swift","fileName":"ContentView.swift","fileType":"swift","content":["import SwiftUI","","struct ContentView: View {","    @State private var value = 100.0","","    var body: some View {","        VStack {","            Text(\"Value: \\(Int(value))\")","                .font(.headline)","","            Text(\"Drag the track quickly and release to throw it\")","                .font(.caption)","                .foregroundStyle(.secondary)","","            OverflowSlider(value: $value, range: 0...500, spacing: 10, isDisabled: false)","                .frame(height: 60)","        }","        .padding()","    }","}"],"syntax":"swift","type":"file","highlights":[]},"OverflowSlider_Basics_Step_4.png":{"identifier":"OverflowSlider_Basics_Step_4.png","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/OverflowSlider_Basics_Step_4.png"}],"alt":"Custom styled OverflowSlider"}}}