asics_Step_2.swift","fileType":"swift","type":"file"},"OverflowSlider_Basics_Step_2.png":{"alt":"OverflowSlider with wider range and finer spacing","identifier":"OverflowSlider_Basics_Step_2.png","type":"image","variants":[{"url":"\/images\/Sliders\/OverflowSlider_Basics_Step_2.png","traits":["1x","light"]}]},"OverflowSlider_Basics_Step_4.png":{"identifier":"OverflowSlider_Basics_Step_4.png","variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/OverflowSlider_Basics_Step_4.png"}],"alt":"Custom styled OverflowSlider","type":"image"},"doc://Sliders/tutorials/Sliders/OverflowSlider-Basics#Custom-Style":{"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/OverflowSlider-Basics#Custom-Style","kind":"section","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","type":"reference","isActive":true},{"type":"text","text":" is a meter-style slider with a fixed frame but a movable track."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore its configuration options — from basic usage to"},{"type":"text","text":" "},{"type":"text","text":"tick spacing, velocity gestures, and custom styling."}],"url":"\/tutorials\/sliders\/overflowslider-basics#Custom-Style","type":"section","role":"pseudoSymbol","title":"Custom Style"},"doc://Sliders/tutorials/Sliders/OverflowSlider-Basics#Basic-Usage":{"abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider"},{"type":"text","text":" is a meter-style slider with a fixed frame but a movable track."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore its configuration options — from basic usage to"},{"type":"text","text":" "},{"type":"text","text":"tick spacing, velocity gestures, and custom styling."}],"role":"pseudoSymbol","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/OverflowSlider-Basics#Basic-Usage","title":"Basic Usage","url":"\/tutorials\/sliders\/overflowslider-basics#Basic-Usage","kind":"section","type":"section"},"OverflowSlider_Basics_Step_3.swift":{"identifier":"OverflowSlider_Basics_Step_3.swift","type":"file","syntax":"swift","fileName":"ContentView.swift","highlights":[],"fileType":"swift","content":["import SwiftUI","","struct ContentView: View {","    @State private var value = 100.0","","    var body: some View {","        VStack {","            Text(\"Value: \\(Int(value))\")","                .font(.headline)","","            Text(\"Drag the track quickly and release to throw it\")","                .font(.caption)","                .foregroundStyle(.secondary)","","            OverflowSlider(value: $value, range: 0...500, spacing: 10, isDisabled: false)","                .frame(height: 60)","        }","        .padding()","    }","}"]},"doc://Sliders/documentation/Sliders/OverflowSlider":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OverflowSlider","kind":"identifier"}],"type":"topic","url":"\/documentation\/sliders\/overflowslider","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/OverflowSlider","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"OverflowSlider","kind":"identifier"}],"title":"OverflowSlider","abstract":[{"type":"text","text":"A Slider which has a fixed frame but a movable track in the background. Used for values that have a discrete nature to them but would not necessarily fit on screen."},{"type":"text","text":" "},{"type":"text","text":"Both the thumb and track can be dragged, if the track is dragged and thrown the velocity of the throw is added to the tracks velocity and it slows gradually to a stop."},{"type":"text","text":" "},{"type":"text","text":"If the thumb is currently being dragged and reachs the minimum or maximum value of its bounds, velocity is added to the track in the opposite direction of the drag."}]},"OverflowSlider_Basics_Step_3.png":{"alt":"Track velocity behaviour","identifier":"OverflowSlider_Basics_Step_3.png","type":"image","v