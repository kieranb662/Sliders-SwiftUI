epsSection":[{"type":"step","media":null,"caption":[],"content":[{"inlineContent":[{"type":"text","text":"Display the joystick’s angle, radial offset, and lock status alongside"},{"type":"text","text":" "},{"type":"text","text":"the control."}],"type":"paragraph"}],"runtimePreview":"Joystick_Basics_Step_3.png","code":"Joystick_Basics_Step_3.swift"}]},{"contentSection":[{"kind":"contentAndMedia","media":"Joystick_Basics_Step_4.png","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Conform to "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/JoystickStyle","isActive":true},{"type":"text","text":" to customise the hit-box, lock-box, track, and"},{"type":"text","text":" "},{"type":"text","text":"thumb."}]}]}],"anchor":"Custom-Style","stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a custom style implementing all four protocol methods and apply it"},{"type":"text","text":" "},{"type":"text","text":"with "},{"type":"codeVoice","code":".joystickStyle(_:)"},{"type":"text","text":"."}]}],"media":null,"code":"Joystick_Basics_Step_4.swift","runtimePreview":"Joystick_Basics_Step_4.png","caption":[],"type":"step"}],"title":"Custom Style"},{"contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"Disable the joystick to prevent user interaction."}],"type":"paragraph"}],"media":"Joystick_Basics_Step_5.png","mediaPosition":"trailing"}],"anchor":"Disabled-State","stepsSection":[{"runtimePreview":"Joystick_Basics_Step_5.png","content":[{"inlineContent":[{"type":"text","text":"Pass "},{"type":"codeVoice","code":"isDisabled: true"},{"type":"text","text":" to put the joystick into a non-interactive state."}],"type":"paragraph"}],"caption":[],"media":null,"type":"step","code":"Joystick_Basics_Step_5.swift"}],"title":"Disabled State"}],"kind":"tasks"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Sliders\/tutorials\/Sliders\/Joystick-Basics"},"references":{"doc://Sliders/documentation/Sliders/JoystickStyle":{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/JoystickStyle","role":"symbol","type":"topic","kind":"symbol","abstract":[],"url":"\/documentation\/sliders\/joystickstyle","title":"JoystickStyle","navigatorTitle":[{"kind":"identifier","text":"JoystickStyle"}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"JoystickStyle"}]},"Joystick_Basics_Step_4.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/Joystick_Basics_Step_4.png"}],"type":"image","alt":"Custom styled Joystick","identifier":"Joystick_Basics_Step_4.png"},"Joystick_Basics_Step_4.swift":{"type":"file","highlights":[],"fileType":"swift","identifier":"Joystick_Basics_Step_4.swift","syntax":"swift","fileName":"ContentView.swift","content":["import SwiftUI","","struct MyJoystickStyle: JoystickStyle {","    func makeHitBox(configuration: JoystickConfiguration) -> some View {","        Rectangle()","            .fill(Color.green.opacity(0.05))","    }","","    func makeLockBox(configuration: JoystickConfiguration) -> some View {","        ZStack {","            Circle().fill(Color.black)","            Image(systemName: \"lock.fill\")","                .foregroundColor(.green)","                .font(.caption)","        }","        .frame(width: 30, height: 30)","    }","","    func makeTrack(configuration: JoystickConfiguration) -> some View {","        Circle()","            .fill(Color.green.opacity(0.2))","            .overlay(","                Circle().strokeBorder(Color.green.opacity(0.5), lineWidth: 2)","            )","    }","","    func makeThumb(configuration: JoystickConfiguration) -> some View {","        Circle()","            .fill(configuration.isActive ? Color.green : Color.green.opacity(0.6))","            .frame(width: 45, height: 45)","            .shadow(color: .green.opacity(0.4), radius: configuration.isActive ? 8 : 0)","    }","}","","struct ContentView: View {","    @State private var joyState: JoyState = .inactive","","    var body: some View {","        Joystick(state: $joyState, radius: 60)","            .joystickStyle(MyJoystickStyle())","            .frame(width: 300, height: 300)","            .padding()","    }","}"]},"Joystick_Basics_Step_5.swift":{"fileName":"ContentView.swift","type":"file","highlights":[],"syntax":"swift","fileType":"swift","content":["import SwiftUI","","struct ContentView: View {","    @State private var joyState: JoyState = .inactive","","    var body: some View {","        VStack(spacing: 20) {","            Joystick(state: $joyState, radius: 60)","                .frame(width: 300, height: 300)","","            Joystick(state: .constant(.inactive), radius: 60, isDisabled: true)","                .frame(width: 300, height: 300)","                .opacity(0.5)","        }","        .padding()","    }","}"],"identifier":"Joystick_Basics_Step_5.swift"},"Joystick_Basics_Step_1.png":{"alt":"A minimal default Joystick","identifier":"Joystick_Basics_Step_1.png","variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/Joystick_Basics_Step_1.png"}],"type":"image"},"doc://Sliders/tutorials/Sliders/Joystick-Basics#Basic-Usage":{"type":"section","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/Joystick-Basics#Basic-Usage","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick"},{"type":"text","text":" is an on-screen joystick that appears wherever the user drags within"},{"type":"text","text":" "},{"type":"text","text":"a defined hit-box. In this tutorial you’ll explore its configuration options — from"},{"type":"text","text":" "},{"type":"text","text":"basic placement to lock behaviour, reading state, and custom styling."}],"role":"pseudoSymbol","kind":"section","url":"\/tutorials\/sliders\/joystick-basics#Basic-Usage","title":"Basic Usage"},"Joystick_Basics_Step_5.png":{"variants":[{"url":"\/images\/Sliders\/Joystick_Basics_Step_5.png","traits":["1x","light"]}],"type":"image","alt":"Joystick in disabled state","identifier":"Joystick_Basics_Step_5.png"},"doc://Sliders/documentation/Sliders/Joystick":{"role":"symbol","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick","title":"Joystick","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Joystick","kind":"identifier"}],"url":"\/documentation\/sliders\/joystick","type":"topic","kind":"symbol","abstract":[{"text":"Joystick view used to control various activities such as moving a character on the screen.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The View creates a Rectangular region to act as a hitbox for drag gestures. Once a drag"},{"type":"text","text":" "},{"text":"is initiated the joystick appears on screen centered at the start location of the gesture. While","type":"text"},{"type":"text","text":" "},{"text":"dragging, the thumb of the joystick is limited be within the ","type":"text"},{"type":"codeVoice","code":"radius"},{"text":" of the sticks background circle.","type":"text"}],"navigatorTitle":[{"text":"Joystick","kind":"identifier"}]},"Joystick_Basics_Step_2.swift":{"fileName":"ContentView.swift","identifier":"Joystick_Basics_Step_2.swift","highlights":[{"line":7}],"syntax":"swift","fileType":"swift","content":["import SwiftUI","","struct ContentView: View {","    @State private var joyState: JoyState = .inactive","","    var body: some View {","        Joystick(state: $joyState, radius: 60, canLock: false, isDisabled: false)","            .frame(width: 300, height: 300)","            .padding()","    }","}"],"type":"file"},"doc://Sliders/tutorials/Joystick-Tutorials":{"title":"Building On-Screen Joysticks","kind":"overview","abstract":[{"type":"text","text":"Learn how to add an on-screen joystick to your app using the built-in default"},{"type":"text","text":" "},{"type":"text","text":"style and its configuration options."}],"url":"\/tutorials\/joystick-tutorials","identifier":"doc:\/\/Sliders\/tutorials\/Joystick-Tutorials","role":"overview","type":"topic"},"doc://Sliders/tutorials/Sliders/Joystick-Basics":{"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/Joystick-Basics","role":"project","type":"topic","estimatedTime":"10min","kind":"project","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick","isActive":true,"type":"reference"},{"text":" is an on-screen joystick that appears wherever the user drags within","type":"text"},{"text":" ","type":"text"},{"text":"a defined hit-box. In this tutorial you’ll explore its configuration options — from","type":"text"},{"text":" ","type":"text"},{"text":"basic placement to lock behaviour, reading state, and custom styling.","type":"text"}],"url":"\/tutorials\/sliders\/joystick-basics","title":"Using Joystick with the Default Style"},"Joystick_Basics_Step_3.swift":{"type":"file","highlights":[],"fileType":"swift","identifier":"Joystick_Basics_Step_3.swift","content":["import SwiftUI","","struct ContentView: View {","    @State private var joyState: JoyState = .inactive","","    var body: some View {","        VStack(spacing: 20) {","            VStack(alignment: .leading) {","                Text(\"Angle: \\(joyState.angle.degrees, specifier: \"%.0f\")°\")","                Text(\"Offset: \\(joyState.radialOffset, specifier: \"%.1f\")\")","                Text(\"Locked: \\(joyState.isLocked ? \"Yes\" : \"No\")\")","                Text(\"Active: \\(joyState.isActive ? \"Yes\" : \"No\")\")","            }","            .font(.system(.body, design: .monospaced))","","            Joystick(state: $joyState, radius: 60)","                .frame(width: 300, height: 300)","        }","        .padding()","    }","}"],"fileName":"ContentView.swift","syntax":"swift"},"doc://Sliders/documentation/Sliders/JoyState":{"abstract":[{"text":"An Enumeration used to represent the state of a ","type":"text"},{"code":"Joystick","type":"codeVoice