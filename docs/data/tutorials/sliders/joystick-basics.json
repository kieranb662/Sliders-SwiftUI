":"paragraph"}],"caption":[],"code":"Joystick_Basics_Step_4.swift","runtimePreview":"Joystick_Basics_Step_4.png"}]},{"stepsSection":[{"code":"Joystick_Basics_Step_5.swift","type":"step","caption":[],"content":[{"inlineContent":[{"type":"text","text":"Pass "},{"code":"isDisabled: true","type":"codeVoice"},{"type":"text","text":" to put the joystick into a non-interactive state."}],"type":"paragraph"}],"media":null,"runtimePreview":"Joystick_Basics_Step_5.png"}],"contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Disable the joystick to prevent user interaction."}]}],"kind":"contentAndMedia","mediaPosition":"trailing","media":"Joystick_Basics_Step_5.png"}],"title":"Disabled State","anchor":"Disabled-State"}]}],"hierarchy":{"reference":"doc:\/\/Sliders\/tutorials\/Joystick-Tutorials","paths":[["doc:\/\/Sliders\/tutorials\/Joystick-Tutorials","doc:\/\/Sliders\/tutorials\/Joystick-Tutorials\/$volume","doc:\/\/Sliders\/tutorials\/Joystick-Tutorials\/Using-the-Default-Style"]],"modules":[{"reference":"doc:\/\/Sliders\/tutorials\/Joystick-Tutorials\/Using-the-Default-Style","projects":[{"sections":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/Joystick-Basics#Basic-Usage","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/Joystick-Basics#Reading-State","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/Joystick-Basics#Custom-Style","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/Joystick-Basics#Disabled-State","kind":"task"}],"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/Joystick-Basics"}]}]},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"category":"Joystick","categoryPathComponent":"Joystick-Tutorials","role":"project","title":"Using Joystick with the Default Style"},"kind":"project","variants":[{"paths":["\/tutorials\/sliders\/joystick-basics"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Sliders\/tutorials\/Sliders\/Joystick-Basics"},"references":{"Joystick_Basics_Step_5.png":{"type":"image","identifier":"Joystick_Basics_Step_5.png","alt":"Joystick in disabled state","variants":[{"url":"\/images\/Sliders\/Joystick_Basics_Step_5.png","traits":["1x","light"]}]},"doc://Sliders/tutorials/Sliders/Joystick-Basics#Reading-State":{"kind":"section","title":"Reading State","role":"pseudoSymbol","url":"\/tutorials\/sliders\/joystick-basics#Reading-State","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/Joystick-Basics#Reading-State","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick"},{"type":"text","text":" is an on-screen joystick that appears wherever the user drags within"},{"type":"text","text":" "},{"type":"text","text":"a defined hit-box. In this tutorial you’ll explore its configuration options — from"},{"type":"text","text":" "},{"type":"text","text":"basic placement to lock behaviour, reading state, and custom styling."}],"type":"section"},"Joystick_Basics_Step_2.png":{"alt":"Joystick with locking disabled","identifier":"Joystick_Basics_Step_2.png","variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/Joystick_Basics_Step_2.png"}],"type":"image"},"doc://Sliders/tutorials/Joystick-Tutorials/Using-the-Default-Style":{"kind":"article","title":"Using the Default Style","role":"article","url":"\/tutorials\/joystick-tutorials\/using-the-default-style","identifier":"doc:\/\/Sliders\/tutorials\/Joystick-Tutorials\/Using-the-Default-Style","abstract":[],"type":"topic"},"Joystick_Basics_Step_3.png":{"identifier":"Joystick_Basics_Step_3.png","alt":"State readout alongside the Joystick","variants":[{"url":"\/images\/Sliders\/Joystick_Basics_Step_3.png","traits":["1x","light"]}],"type":"image"},"Joystick_Basics_Step_4.swift":{"highlights":[],"fileType":"swift","syntax":"swift","type":"file","identifier":"Joystick_Basics_Step_4.swift","fileName":"ContentView.swift","content":["import SwiftUI","","struct MyJoystickStyle: JoystickStyle {","    func makeHitBox(configuration: JoystickConfiguration) -> some View {","        Rectangle()","            .fill(Color.green.opacity(0.05))","    }","","    func makeLockBox(configuration: JoystickConfiguration) -> some View {","        ZStack {","            Circle().fill(Color.black)","            Image(systemName: \"lock.fill\")","                .foregroundColor(.green)","                .font(.caption)","        }","        .frame(width: 30, height: 30)","    }","","    func makeTrack(configuration: JoystickConfiguration) -> some View {","        Circle()","            .fill(Color.green.opacity(0.2))","            .overlay(","                Circle().strokeBorder(Color.green.opacity(0.5), lineWidth: 2)","            )","    }","","    func makeThumb(configuration: JoystickConfiguration) -> some View {","        Circle()","            .fill(configuration.isActive ? Color.green : Color.green.opacity(0.6))","            .frame(width: 45, height: 45)","            .shadow(color: .green.opacity(0.4), radius: configuration.isActive ? 8 : 0)","    }","}","","struct ContentView: View {","    @State private var joyState: JoyState = .inactive","","    var body: some View {","        Joystick(state: $joyState, radius: 60)","            .joystickStyle(MyJoystickStyle())","            .frame(width: 300, height: 300)","            .padding()","    }","}"]},"doc://Sliders/documentation/Sliders/Joystick":{"title":"Joystick","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Joystick"}],"navigatorTitle":[{"kind":"identifier","text":"Joystick"}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick","url":"\/documentation\/sliders\/joystick","role":"symbol","abstract":[{"text":"Joystick view used to control various activities such as moving a character on the screen.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The View creates a Rectangular region to act as a hitbox for drag gestures. Once a drag"},{"text":" ","type":"text"},{"text":"is initiated the joystick appears on screen centered at the start location of the gesture. While","type":"text"},{"type":"text","text":" "},{"type":"text","text":"dragging, the thumb of the joystick is limited be within the "},{"type":"codeVoice","code":"radius"},{"type":"text","text":" of the sticks background circle."}],"type":"topic"},"Joystick_Basics_Step_4.png":{"type":"image","variants":[{"url":"\/images\/Sliders\/Joystick_Basics_Step_4.png","traits":["1x","light"]}],"identifier":"Joystick_Basics_Step_4.png","alt":"Custom styled Joystick"},"doc://Sliders/tutorials/Sliders/Joystick-Basics#Custom-Style":{"kind":"section","title":"Custom Style","role":"pseudoSymbol","url":"\/tutorials\/sliders\/joystick-basics#Custom-Style","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/Joystick-Basics#Custom-Style","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick","type":"reference","isActive":true},{"text":" is an on-screen joystick that appears wherever the user drags within","type":"text"},{"text":" ","type":"text"},{"text":"a defined hit-box. In this tutorial you’ll explore its configuration options — from","type":"text"},{"text":" ","type":"text"},{"text":"basic placement to lock behaviour, reading state, and custom styling.","type":"text"}],"type":"section"},"doc://Sliders/tutorials/Joystick-Tutorials":{"role":"overview","kind":"overview","identifier":"doc:\/\/Sliders\/tutorials\/Joystick-Tutorials","abstract":[{"type":"text","text":"Learn how to add an on-screen joystick to your app using the built-in default"},{"type":"text","text":" "},{"type":"text","text":"style and its configuration options."}],"title":"Building On-Screen Joysticks","url":"\/tutorials\/joystick-tutorials","type":"topic"},"doc://Sliders/tutorials/Sliders/Joystick-Basics#Disabled-State":{"role":"pseudoSymbol","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick"},{"type":"text","text":" is an on-screen joystick that appears wherever the user drags within"},{"type":"text","text":" "},{"type":"text","text":"a defined hit-box. In this tutorial you’ll explore its configuration options — from"},{"type":"text","text":" "},{"type":"text","text":"basic placement to lock behaviour, reading state, and custom styling."}],"type":"section","url":"\/tutorials\/sliders\/joystick-basics#Disabled-State","title":"Disabled State","kind":"section","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/Joystick-Basics#Disabled-State"},"Joystick_Basics_Step_3.swift":{"highlights":[],"content":["import SwiftUI","","struct ContentView: View {","    @State private var joyState: JoyState = .inactive","","    var body: some View {","        VStack(spacing: 20) {","            VStack(alignment: .leading) {","                Text(\"Angle: \\(joyState.angle.degrees, specifier: \"%.0f\")°\")","                Text(\"Offset: \\(joyState.radialOffset, specifier: \"%.1f\")\")","                Text(\"Locked: \\(joyState.isLocked ? \"Yes\" : \"No\")\")","                Text(\"Active: \\(joyState.isActive ? \"Yes\" : \"No\")\")","            }","            .font(.system(.body, design: .monospaced))","","            Joystick(state: $joyState, radius: 60)","                .frame(width: 300, height: 300)","        }","        .padding()","    }","}"],"fileName":"ContentView.swift","identifier":"Joystick_Basics_Step_3.swift","syntax":"swift","fileType":"swift","type":"file"},"doc://Sliders/documentation/Sliders/JoystickStyle":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"JoystickStyle"}],"kind":"symbol","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/JoystickStyle","abstract":[],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"JoystickStyle","kind":"identifier"}],"title":"JoystickStyle","url":"\/documentation\/sliders\/joystickstyle","type":"topic"},"doc://Sliders/tutorial