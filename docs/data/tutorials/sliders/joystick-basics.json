: View {","    @State private var joyState: JoyState = .inactive","","    var body: some View {","        Joystick(state: $joyState, radius: 60)","            .joystickStyle(MyJoystickStyle())","            .frame(width: 300, height: 300)","            .padding()","    }","}"],"highlights":[],"syntax":"swift","identifier":"Joystick_Basics_Step_4.swift","fileType":"swift","type":"file"},"doc://Sliders/documentation/Sliders/Joystick":{"title":"Joystick","abstract":[{"text":"Joystick view used to control various activities such as moving a character on the screen.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The View creates a Rectangular region to act as a hitbox for drag gestures. Once a drag"},{"type":"text","text":" "},{"text":"is initiated the joystick appears on screen centered at the start location of the gesture. While","type":"text"},{"text":" ","type":"text"},{"text":"dragging, the thumb of the joystick is limited be within the ","type":"text"},{"type":"codeVoice","code":"radius"},{"text":" of the sticks background circle.","type":"text"}],"kind":"symbol","type":"topic","navigatorTitle":[{"text":"Joystick","kind":"identifier"}],"url":"\/documentation\/sliders\/joystick","role":"symbol","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Joystick"}]},"doc://Sliders/tutorials/Sliders/Joystick-Basics#Disabled-State":{"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/Joystick-Basics#Disabled-State","title":"Disabled State","url":"\/tutorials\/sliders\/joystick-basics#Disabled-State","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/Joystick","isActive":true,"type":"reference"},{"type":"text","text":" is an on-screen joystick that appears wherever the user drags within"},{"type":"text","text":" "},{"type":"text","text":"a defined hit-box. In this tutorial you’ll explore its configuration options — from"},{"typ