t":"Joystick-Tutorials"},"references":{"Joystick_Basics_Step_3.swift":{"identifier":"Joystick_Basics_Step_3.swift","type":"file","syntax":"swift","fileName":"ContentView.swift","highlights":[],"fileType":"swift","content":["import SwiftUI","","struct ContentView: View {","    @State private var joyState: JoyState = .inactive","","    var body: some View {","        VStack(spacing: 20) {","            VStack(alignment: .leading) {","                Text(\"Angle: \\(joyState.angle.degrees, specifier: \"%.0f\")°\")","                Text(\"Offset: \\(joyState.radialOffset, specifier: \"%.1f\")\")","                Text(\"Locked: \\(joyState.isLocked ? \"Yes\" : \"No\")\")","                Text(\"Active: \\(joyState.isActive ? \"Yes\" : \"No\")\")","            }","            .font(.system(.body, design: .monospaced))","","            Joystick(state: $joyState, radius: 60)","                .frame(width: 300, height: 300)","        }","        .padding()","    }","}"]},"Joystick_Basics_Step_5.swift":{"identifier":"Joystick_Basics_Step_5.swift","syntax":"swift","fileType":"swift","highlights":[],"content":["import SwiftUI","","struct ContentView: View {","    @State private var joyState: JoyState = .inactive","","    var body: some View {","        VStack(spacing: 20) {","            Joystick(state: $joyState, radius: 60)","                .frame(width: 300, height: 300)","","            Joystick(state: .constant(.inactive), radius: 60, isDisabled: true)","                .frame(width: 300, height: 300)","                .opacity(0.5)","        }","        .padding()","    }","}"],"type":"file","fileName":"ContentView.swift"},"Joystick_Basics_Step_2.swift":{"identifier":"Joystick_Basics_Step_2.swift","type":"file","syntax":"swift","fileName":"ContentView.swift","highlights":[{"line":7}],"fileType":"swift","content":["import SwiftUI","","struct ContentView: View {","    @State private var joyState: JoyState = .inactive","","    var body: some View {","        Joystick(s