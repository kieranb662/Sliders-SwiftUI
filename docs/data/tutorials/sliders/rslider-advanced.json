 the current value.","type":"text"}],"type":"paragraph"}],"media":"RSlider_Advanced_Step_2.png","mediaPosition":"trailing","kind":"contentAndMedia"}],"stepsSection":[{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Replace the stub ","type":"text"},{"code":"makeTrack","type":"codeVoice"},{"text":" body. Layer a ","type":"text"},{"type":"codeVoice","code":"Circle"},{"type":"text","text":" stroke for the"},{"type":"text","text":" "},{"type":"text","text":"background and a "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/CircularArc","isActive":true},{"type":"text","text":" for the fill."}]}],"caption":[],"runtimePreview":"RSlider_Advanced_Step_2.png","code":"RSlider_Advanced_Step_2.swift","media":null}],"anchor":"Implementing-makeTrack","title":"Implementing makeTrack"},{"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Replace the stub "},{"type":"codeVoice","code":"makeThumb"},{"type":"text","text":" body. Use "},{"type":"codeVoice","code":"configuration.isActive"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"code":"configuration.isDisabled","type":"codeVoice"},{"text":" to drive color and shadow.","type":"text"}],"type":"paragraph"}],"runtimePreview":"RSlider_Advanced_Step_3.png","caption":[],"type":"step","media":null,"code":"RSlider_Advanced_Step_3.swift"}],"title":"Implementing makeThumb","contentSection":[{"media":"RSlider_Advanced_Step_3.png","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The thumb should change appearance based on "},{"type":"codeVoice","code":"isActive"},{"type":"text","text":" and "},{"code":"isDisabled","type":"codeVoice"},{"text":".","type":"text"}]}],"mediaPosition":"trailing"}],"anchor":"Implementing-makeThumb"},{"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"text":"Tick marks react to the thumb’s proximity — growing and brightening as the","type":"text"},{"type":"text","text":" "},{"text":"thumb approaches.","type":"text"}],"type":"paragraph"}],"media":"RSlider_Advanced_Step_4.png"}],"stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Replace the stub ","type":"text"},{"code":"makeTickMark","type":"codeVoice"},{"text":" body. Compute a normalised ","type":"text"},{"code":"proximity","type":"codeVoice"},{"text":" ","type":"text"},{"text":"between the thumb and each tick mark, then interpolate size and opacity.","type":"text"}]}],"code":"RSlider_Advanced_Step_4.swift","media":null,"type":"step","runtimePreview":"RSlider_Advanced_Step_4.png","caption":[]}],"anchor":"Implementing-makeTickMark","title":"Implementing makeTickMark"},{"title":"Applying the Finished Style","stepsSection":[{"runtimePreview":"RSlider_Advanced_Step_5.png","type":"step","content":[{"inlineContent":[{"type":"text","text":"Apply "},{"code":".radialSliderStyle(MyRSliderStyle())","type":"codeVoice"},{"type":"text","text":" to sliders with tick marks"},{"type":"text","text":" "},{"type":"text","text":"and affinity to confirm everything works together."}],"type":"paragraph"}],"media":null,"caption":[],"code":"RSlider_Advanced_Step_5.swift"}],"contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"Apply the finished style to sliders with different configurations."}],"type":"paragraph"}],"media":"RSlider_Advanced_Step_5.png","kind":"contentAndMedia","mediaPosition":"trailing"}],"anchor":"Applying-the-Finished-Style"}],"kind":"tasks"}],"identifier":{"url":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Advanced","interfaceLanguage":"swift"},"references":{"RSlider_Advanced_Step_4.png":{"type":"image","alt":"Proximity-based tick marks","variants":[{"url":"\/images\/Sliders\/RSlider_Advanced_Step_4.png","traits":["1x","light"]}],"identifier":"RSlider_Advanced_Step_4.png"},"doc://Sliders/tutorials/Sliders/RSlider-Advanced#Applying-the-Finished-Style":{"type":"section","url":"\/tutorials\/sliders\/rslider-advanced#Apply