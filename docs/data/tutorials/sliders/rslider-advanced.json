d_Step_5.png","media":null}]}],"kind":"tasks"}],"hierarchy":{"modules":[{"projects":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Basics","sections":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Basics#Basic-Usage","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Basics#Tick-Marks","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Basics#Affinity-Snapping","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Basics#Labels-Disabled-State","kind":"task"}]}],"reference":"doc:\/\/Sliders\/tutorials\/RSlider-Tutorials\/Using-the-Default-Style"},{"projects":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Advanced","sections":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Advanced#Declaring-the-Style","kind":"task"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Advanced#Implementing-makeTrack"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Advanced#Implementing-makeThumb","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Advanced#Implementing-makeTickMark","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Advanced#Applying-the-Finished-Style","kind":"task"}]}],"reference":"doc:\/\/Sliders\/tutorials\/RSlider-Tutorials\/Creating-a-Custom-Style"}],"reference":"doc:\/\/Sliders\/tutorials\/RSlider-Tutorials","paths":[["doc:\/\/Sliders\/tutorials\/RSlider-Tutorials","doc:\/\/Sliders\/tutorials\/RSlider-Tutorials\/$volume","doc:\/\/Sliders\/tutorials\/RSlider-Tutorials\/Creating-a-Custom-Style"]]},"references":{"doc://Sliders/tutorials/Sliders/RSlider-Basics#Labels-Disabled-State":{"type":"section","abstract":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSlider","isActive":true},{"text":" is a circular slider whose thumb travels around a configurable arc.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll explore every configuration option the default style","type":"text"},{"text":" ","type":"text"},{"text":"offers — from a minimal setup to winds, tick marks, affinity snapping, and","type":"text"},{"text":" ","type":"text"},{"text":"custom labels.","type":"text"}],"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Basics#Labels-Disabled-State","title":"Labels & Disabled State","url":"\/tutorials\/sliders\/rslider-basics#Labels-Disabled-State","role":"pseudoSymbol","kind":"section"},"doc://Sliders/documentation/Sliders/RSlider":{"url":"\/documentation\/sliders\/rslider","title":"RSlider","abstract":[{"type":"text","text":"A circular slider whose thumb is dragged around the track of a circle, controlling a"},{"type":"text","text":" "},{"type":"text","text":"single value. The slider can span multiple full revolutions using the "},{"type":"codeVoice","code":"maxWinds"},{"type":"text","text":" parameter."}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSlider","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"RSlider","kind":"identifier"}],"navigatorTitle":[{"text":"RSlider","kind":"identifier"}],"kind":"symbol","type":"topic","role":"symbol"},"doc://Sliders/documentation/Sliders/RSliderStyle":{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSliderStyle","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"RSliderStyle"}],"navigatorTitle":[{"kind":"identifier","text":"RSliderStyle"}],"url":"\/documentation\/sliders\/rsliderstyle","title":"RSliderStyle","kind":"symbol","type":"topic","role":"symbol","abstract":[{"text":"A style that defines the appearance of an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSlider","type":"reference"},{"type":"text","text":"."}]},"RSlider_Advanced_Step_4.swift":{"fileName":"MyRSliderStyle.swift","fileType":"swift","highlights":[],"syntax":"swift","content":["import SwiftUI","","struct MyRSliderStyle: RSliderStyle {","","    func makeThumb(configuration: RSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled ? .gray :","            (configuration.isActive ? .cyan : .white)","        let shadowRadius: Double = configuration.isActive ? 8 : 3","","        return Circle()","            .fill(color)","            .frame(width: 28, height: 28)","            .shadow(radius: shadowRadius)","            .animation(.easeOut(duration: 0.15), value: configuration.isActive)","    }","","    func makeTrack(configuration: RSliderConfiguration) -> some View {","        ZStack {","            Circle()","                .stroke(Color.gray.opacity(0.3), lineWidth: 18)","","            CircularArc(percent: configuration.withinWind)","                .stroke(Color.cyan, style: StrokeStyle(lineWidth: 18, lineCap: .round))","        }","        .padding(9)","    }","","    func makeTickMark(configuration: RSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let proximity = max(0, 1 - abs(thumbPct - tickPct) \/ 0.20)","        let size    = 4.0 + 6.0 * proximity","        let opacity = 0.35 + 0.65 * proximity","","        return Circle()","            .fill(Color.cyan.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        RSlider($value, range: 0...1, tickSpacing: .count(11))","            .radialSliderStyle(MyRSliderStyle())","            .frame(width: 220, height: 220)","            .padding()","    }","}"],"type":"file","identifier":"RSlider_Advanced_Step_4.swift"},"doc://Sliders/tutorials/Sliders/RSlider-Basics#Affinity-Snapping":{"type":"section","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSlider","type":"reference","isActive":true},{"text":" is a circular slider whose thumb travels around a configurable arc.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll explore every configuration option the default style","type":"text"},{"text":" ","type":"text"},{"text":"offers — from a minimal setup to winds, tick marks, affinity snapping, and","type":"text"},{"text":" ","type":"text"},{"text":"custom labels.","type":"text"}],"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Basics#Affinity-Snapping","title":"Affinity Snapping","url":"\/tutorials\/sliders\/rslider-basics#Affinity-Snapping","role":"pseudoSymbol","kind":"section"},"RSlider_Advanced_Step_4.png":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/RSlider_Advanced_Step_4.png"}],"identifier":"RSlider_Advanced_Step_4.png","alt":"Proximity-based tick marks"},"RSlider_Advanced_Step_5.png":{"type":"image","identifier":"RSlider_Advanced_Step_5.png","alt":"Multiple RSliders using the custom style","variants":[{"url":"\/images\/Sliders\/RSlider_Advanced_Step_5.png","traits":["1x","light"]}]},"doc://Sliders/tutorials/RSlider-Tutorials/Using-the-Default-Style":{"title":"Using the Default Style","url":"\/tutorials\/rslider-tutorials\/using-the-default-style","abstract":[],"role":"article","kind":"article","type":"topic","identifier":"doc:\/\/Sliders\/tutorials\/RSlider-Tutorials\/Using-the-Default-Style"},"doc://Sliders/tutorials/Sliders/RSlider-Advanced#Declaring-the-Style":{"title":"Declaring the Style","url":"\/tutorials\/sliders\/rslider-advanced#Declaring-the-Style","abstract":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSliderStyle","isActive":true},{"text":" lets you take full control of every visual element of the circular","type":"text"},{"text":" ","type":"text"},{"text":"slider. In this tutoria