"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Basics#Labels-Disabled-State","type":"section","kind":"section","url":"\/tutorials\/sliders\/rslider-basics#Labels-Disabled-State"},"doc://Sliders/tutorials/Sliders/RSlider-Basics#Basic-Usage":{"kind":"section","abstract":[{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSlider","type":"reference"},{"type":"text","text":" is a circular slider whose thumb travels around a configurable arc."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore every configuration option the default style"},{"type":"text","text":" "},{"type":"text","text":"offers — from a minimal setup to winds, tick marks, affinity snapping, and"},{"text":" ","type":"text"},{"text":"custom labels.","type":"text"}],"title":"Basic Usage","url":"\/tutorials\/sliders\/rslider-basics#Basic-Usage","role":"pseudoSymbol","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Basics#Basic-Usage","type":"section"},"RSlider_Advanced_Step_4.swift":{"identifier":"RSlider_Advanced_Step_4.swift","highlights":[],"syntax":"swift","content":["import SwiftUI","","struct MyRSliderStyle: RSliderStyle {","","    func makeThumb(configuration: RSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled ? .gray :","            (configuration.isActive ? .cyan : .white)","        let shadowRadius: Double = configuration.isActive ? 8 : 3","","        return Circle()","            .fill(color)","            .frame(width: 28, height: 28)","            .shadow(radius: shadowRadius)","            .animation(.easeOut(duration: 0.15), value: configuration.isActive)","    }","","    func makeTrack(configuration: RSliderConfiguration) -> some View {","        ZStack {","            Circle()","                .stroke(Color.gray.opacity(0.3), lineWidth: 18)","","            CircularArc(percent: configuration.withinWind)","                .stroke(Color.cyan, style: StrokeStyle(lineWidth: 18, lineCap: .round))","        }","        .padding(9)","    }","","    func makeTickMark(configuration: RSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let proximity = max(0, 1 - abs(thumbPct - tickPct) \/ 0.20)","        let size    = 4.0 + 6.0 * proximity","        let opacity = 0.35 + 0.65 * proximity","","        return Circle()","            .fill(Color.cyan.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        RSlider($value, range: 0...1, tickSpacing: .count(11))","            .radialSliderStyle(MyRSliderStyle())","            .frame(width: 220, height: 220)","            .padding()","    }","}"],"type":"file","fileType":"swift","fileName":"MyRSliderStyle.swift"},"doc://Sliders/documentation/Sliders/RSliderStyle":{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSliderStyle","url":"\/documentation\/sliders\/rsliderstyle","navigatorTitle":[{"text":"RSliderStyle","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RSliderStyle","kind":"identifier"}],"type":"topic","title":"RSliderStyle","role":"symbol","abstract":[{"type":"text","text":"A style that defines the appearance of an "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSlider","isActive":true},{"type":"text","text":"."}]},"doc://Sliders/tutorials/Sliders/RSlider-Advanced":{"role":"project","url":"\/tutorials\/sliders\/rslider-advanced","estimatedTime":"20min","title":"Building a Custom RSlider Style","abstract":[{"type":"reference","isActive":true,"identif