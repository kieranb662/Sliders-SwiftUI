idth: 4, height: 4)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        RSlider($value, range: 0...1, tickSpacing: .count(11))","            .radialSliderStyle(MyRSliderStyle())","            .frame(width: 220, height: 220)","            .padding()","    }","}"],"identifier":"RSlider_Advanced_Step_3.swift"},"doc://Sliders/tutorials/RSlider-Tutorials/Using-the-Default-Style":{"identifier":"doc:\/\/Sliders\/tutorials\/RSlider-Tutorials\/Using-the-Default-Style","role":"article","type":"topic","kind":"article","abstract":[],"url":"\/tutorials\/rslider-tutorials\/using-the-default-style","title":"Using the Default Style"},"doc://Sliders/tutorials/Sliders/RSlider-Basics":{"kind":"project","abstract":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSlider","isActive":true},{"type":"text","text":" is a circular slider whose thumb travels around a configurable arc."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore every configuration option the default style"},{"type":"text","text":" "},{"type":"text","text":"offers — from a minimal setup to winds, tick marks, affinity snapping, and"},{"type":"text","text":" "},{"type":"text","text":"custom labels."}],"title":"Using RSlider with the Default Style","url":"\/tutorials\/sliders\/rslider-basics","role":"project","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Basics","estimatedTime":"20min","type":"topic"},"doc://Sliders/tutorials/Sliders/RSlider-Advanced#Implementing-makeTrack":{"role":"pseudoSymbol","url":"\/tutorials\/sliders\/rslider-advanced#Implementing-makeTrack","kind":"section","title":"Implementing makeTrack","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Advanced#Implementing-makeTrack","type":"section","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSliderStyle"},{"type":"text","text":" lets you take full con