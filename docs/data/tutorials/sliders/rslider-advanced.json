identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSliderStyle","type":"reference","isActive":true},{"type":"text","text":" lets you take full control of every visual element of the circular"},{"type":"text","text":" "},{"type":"text","text":"slider. In this tutorial you’ll build a custom style from scratch."}],"role":"pseudoSymbol","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Advanced#Implementing-makeTickMark","title":"Implementing makeTickMark","url":"\/tutorials\/sliders\/rslider-advanced#Implementing-makeTickMark","kind":"section","type":"section"},"doc://Sliders/tutorials/Sliders/RSlider-Basics#Tick-Marks":{"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Basics#Tick-Marks","title":"Tick Marks","url":"\/tutorials\/sliders\/rslider-basics#Tick-Marks","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSlider"},{"type":"text","text":" is a circular slider whose thumb travels around a configurable arc."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore every configuration option the default style"},{"type":"text","text":" "},{"type":"text","text":"offers — from a minimal setup to winds, tick marks, affinity snapping, and"},{"type":"text","text":" "},{"type":"text","text":"custom labels."}],"role":"pseudoSymbol","type":"section","kind":"section"},"doc://Sliders/tutorials/Sliders/RSlider-Advanced#Implementing-makeTrack":{"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Advanced#Implementing-makeTrack","title":"Implementing makeTrack","url":"\/tutorials\/sliders\/rslider-advanced#Implementing-makeTrack","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSliderStyle","type":"reference","isActive":true},{"type":"text","text":" lets you take full control of every visual element of the circular"},{"type":"text","text":" "},{"type":"text","text":"slider. In this tutorial you’ll build a custom style from scratch."}],"role":"pseudoSymbol","type":"section","kind":"section"},"doc://Sliders/tutorials/RSlider-Tutorials":{"type":"topic","identifier":"doc:\/\/Sliders\/tutorials\/RSlider-Tutorials","url":"\/tutorials\/rslider-tutorials","role":"overview","kind":"overview","title":"Building Circular Sliders with RSlider","abstract":[{"type":"text","text":"Learn how to add a circular slider to your app — starting with the built-in default"},{"type":"text","text":" "},{"type":"text","text":"style and its configuration options, then advancing to building a custom style."}]},"RSlider_Advanced_Step_3.swift":{"fileName":"MyRSliderStyle.swift","fileType":"swift","identifier":"RSlider_Advanced_Step_3.swift","type":"file","highlights":[],"content":["import SwiftUI","","struct MyRSliderStyle: RSliderStyle {","","    func makeThumb(configuration: RSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled ? .gray :","            (configuration.isActive ? .cyan : .white)","        let shadowRadius: Double = configuration.isActive ? 8 : 3","","        return Circle()","            .fill(color)","            .frame(width: 28, height: 28)","            .shadow(radius: shadowRadius)","            .animation(.easeOut(duration: 0.15), value: configuration.isActive)","    }","","    func makeTrack(configuration: RSliderConfiguration) -> some View {","        ZStack {","            Circle()","                .stroke(Color.gray.opacity(0.3), lineWidth: 18)","","            CircularArc(percent: configuration.withinWind)","                .stroke(Color.cyan, style: StrokeStyle(lineWidth: 18, lineCap: .round))","        }","        .padding(9)","    }","","    func makeTickMark(configuration: RSliderConfiguration, tickValue: Double) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(width: 4, height: 4)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        RSlider($value, range: 0...1, tickSpacing: .count(11))","            .radialSliderStyle(MyRSliderStyle())","            .frame(width: 220, height: 220)","            .padding()","    }","}"],"syntax":"swift"},"doc://Sliders/documentation/Sliders/RSlider":{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSlider","abstract":[{"text":"A circular slider whose thumb is dragged around the track of a circle, controlling a","type":"text"},{"type":"text","text":" "},{"text":"single value. The slider can span multiple full revolutions using the ","type":"text"},{"code":"maxWinds","type":"codeVoice"},{"type":"text","text":" parameter."}],"role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"RSlider"}],"navigatorTitle":[{"text":"RSlider","kind":"identifier"}],"kind":"symbol","title":"RSlider","url":"\/documentation\/sliders\/rslider"},"RSlider_Advanced_Step_4.png":{"alt":"Proximity-based tick marks","variants":[{"url":"\/images\/Sliders\/RSlider_Advanced_Step_4.png","traits":["1x","light"]}],"identifier":"RSlider_Advanced_Step_4.png","type":"image"},"RSlider_Advanced_Step_5.swift":{"highlights":[],"identifier":"RSlider_Advanced_Step_5.swift","type":"file","fileType":"swift","fileName":"ContentView.swift","syntax":"swift","content":["import SwiftUI","","struct MyRSliderStyle: RSliderStyle {","","    func makeThumb(configuration: RSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled ? .gray :","            (configuration.isActive ? .cyan : .white)","        let shadowRadius: Double = configuration.isActive ? 8 : 3","","        return Circle()","            .fill(color)","            .frame(width: 28, height: 28)","            .shadow(radius: shadowRadius)","            .animation(.easeOut(duration: 0.15), value: configuration.isActive)","    }","","    func makeTrack(configuration: RSliderConfiguration) -> some View {","        ZStack {","            Circle()","                .stroke(Color.gray.opacity(0.3), lineWidth: 18)","","            CircularArc(percent: configuration.withinWind)","                .stroke(Color.cyan, style: StrokeStyle(lineWidth: 18, lineCap: .round))","        }","        .padding(9)","    }","","    func makeTickMark(configuration: RSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let proximity = max(0, 1 - abs(thumbPct - tickPct) \/ 0.20)","        let size    = 4.0 + 6.0 * proximity","        let opacity = 0.35 + 0.65 * proximity","","        return Circle()","            .fill(Color.cyan.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","}","","struct ContentView: View {","    @State private var value1 = 0.4","    @State private var value2 = 0.6","","    var body: some View {","        VStack(spacing: 30) {","            RSlider(","                $value1,","                range: 0...1,","                tickSpacing: .count(11),","                affinityEnabled: true","            )","            .frame(width: 220, height: 220)","","            RSlider($value2, range: 0...1, originAngle: .degrees(-90))","                .frame(width: 180, height: 180)","        }","        .radialSliderStyle(MyRSliderStyle())","        .padding()","    }","}"]},"doc://Sliders/tutorials/Sliders/RSlider-Basics#Labels-Disabled-State":{"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Basics#Labels-Disabled-State","title":"Labels & Disabled State","url":"\/tutorials\/sliders\/rslider-basics#Labels-Disabled-State","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSlider"},{"type":"text","text":" is a circular slider whose thumb travels around a configurable arc."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore every configuration option the default style"},{"type":"text","text":" "},{"type":"text","text":"offers — from a minimal setup to winds, tick marks, affinity snapping, and"},{"type":"text","text":" "},{"type":"text","text":"custom labels."}],"role":"pseudoSymbol","type":"section","kind":"section"},"doc://Sliders/tutorials/Sliders/RSlider-Advanced":{"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/RSlider-Advanced","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/RSliderStyle"},{"type":"text","text":" lets you take full control of every visual element of the circular"},{"type":"text","text":" "},{"type":"text","text":"slider. In this tutorial you’ll build a custom style from scratch."}],"url":"\/tutorials\/sliders\/rslider-advanced","type":"topic","title":"Building a Custom RSlider Style","role":"project","estimatedTime":"20min","kind":"project"},"RSlider_Advanced_Step_1.swift":{"identifier":"RSlider_Advanced_Step_1.swift","type":"file","syntax":"swift","content":["import SwiftUI","","struct MyRSliderStyle: RSliderStyle {","","    func makeThumb(configuration: RSliderConfiguration) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(width: 28, height: 28)","    }","","    func makeTrack(configuration: RSliderConfiguration) -> some View {","        Circle()","            .stroke(Color.gray.opacity(0.4), lineWidth: 18)","            .padding(9)","    }","","    func makeTickMark(configuration: RSliderConfiguration, tickValue: Double) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(width: 4, height: 4)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        RSlider($value, range: 0...1, tickSpacing: .count(11))","            .radialSliderStyle(MyRSliderStyle())","            .fram