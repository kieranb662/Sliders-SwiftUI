"text":", ","type":"text"},{"code":"configuration.isUpperActive","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"code":"configuration.isRangeActive","type":"codeVoice"},{"text":" to drive visual feedback.","type":"text"}],"type":"paragraph"}],"caption":[],"runtimePreview":"DoubleLSlider_Advanced_Step_3.png"}],"title":"Implementing the Thumbs"},{"anchor":"Applying-the-Finished-Style","title":"Applying the Finished Style","contentSection":[{"media":"DoubleLSlider_Advanced_Step_4.png","content":[{"inlineContent":[{"text":"Apply the finished style to both horizontal and diagonal range sliders.","type":"text"}],"type":"paragraph"}],"mediaPosition":"trailing","kind":"contentAndMedia"}],"stepsSection":[{"runtimePreview":"DoubleLSlider_Advanced_Step_4.png","media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apply "},{"type":"codeVoice","code":".doubleLSliderStyle(MyDoubleLSliderStyle())"},{"type":"text","text":" to sliders with"},{"type":"text","text":" "},{"text":"tick marks and affinity to confirm everything works together.","type":"text"}]}],"caption":[],"type":"step","code":"DoubleLSlider_Advanced_Step_4.swift"}]}],"kind":"tasks"}],"references":{"DoubleLSlider_Advanced_Step_3.png":{"identifier":"DoubleLSlider_Advanced_Step_3.png","type":"image","alt":"Thumbs highlighting when active","variants":[{"url":"\/images\/Sliders\/DoubleLSlider_Advanced_Step_3.png","traits":["1x","light"]}]},"DoubleLSlider_Advanced_Step_4.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/DoubleLSlider_Advanced_Step_4.png"}],"type":"image","identifier":"DoubleLSlider_Advanced_Step_4.png","alt":"Horizontal and diagonal range sliders using the custom style"},"DoubleLSlider_Advanced_Step_3.swift":{"fileType":"swift","type":"file","identifier":"DoubleLSlider_Advanced_Step_3.swift","highlights":[],"syntax":"swift","content":["import SwiftUI","","struct MyDoubleLSliderStyle: DoubleLSliderStyle {","","    func makeLowerThumb(configuration: DoubleLSliderConfiguration) -> some View {","        let active = configuration.isLowerActive || configuration.isRangeActive","        return RoundedRectangle(cornerRadius: 6)","            .fill(active ? Color.teal : Color.white)","            .frame(width: 28, height: 28)","            .shadow(color: .black.opacity(0.25), radius: active ? 6 : 2)","    }","","    func makeUpperThumb(configuration: DoubleLSliderConfiguration) -> some View {","        let active = configuration.isUpperActive || configuration.isRangeActive","        return RoundedRectangle(cornerRadius: 6)","            .fill(active ? Color.teal : Color.white)","            .frame(width: 28, height: 28)","            .shadow(color: .black.opacity(0.25), radius: active ? 6 : 2)","    }","","    func makeTrack(configuration: DoubleLSliderConfiguration) -> some View {","        ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color(white: 0.2))","","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.upperPercent,","                cap: .square,","                adjustmentForThumb: 0","            )","            .fill(Color.teal)","            .mask(","                AdaptiveLine(","                    thickness: configuration.trackThickness,","                    angle: configuration.angle,","                    percentFilled: 1 - configuration.lowerPercent,","                    from: .end,","                    cap: .square,","                    adjustmentForThumb: 0","                )","            )","            .mask(AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle))","        }","    }","}","","struct ContentView: View {","    @State private var lower = 0.25","    @State private var upper = 0.75","","    var body: some View {","        DoubleLSlider(","            lowerValue: $lower,","            upperValue: $upper,","            range: 0...1,","            keepThumbInTrack: true,","            trackThickness: 20","        )","        .doubleLSliderStyle(MyDoubleLSliderStyle())","        .frame(height: 60)","        .padding()","    }","}"],"fileName":"MyDoubleLSliderStyle.swift"},"DoubleLSlider_Advanced_Step_1.swift":{"highlights":[],"identifier":"DoubleLSlider_Advanced_Step_1.swift","type":"file","fileType":"swift","fileName":"MyDoubleLSliderStyle.swift","syntax":"swift","content":["import SwiftUI","","struct MyDoubleLSliderStyle: DoubleLSliderStyle {","","    func makeLowerThumb(configuration: DoubleLSliderConfiguration) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(width: 30, height: 30)","    }","","    func makeUpperThumb(configuration: DoubleLSliderConfiguration) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(width: 30, height: 30)","    }","","    func makeTrack(configuration: DoubleLSliderConfiguration) -> some View {","        AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            .fill(Color.gray.opacity(0.4))","    }","}","","struct ContentView: View {","    @State private var lower = 0.25","    @State private var upper = 0.75","","    var body: some View {","        DoubleLSlider(","            lowerValue: $lower,","            upperValue: $upper,","            range: 0...1,","            keepThumbInTrack: true,","            trackThickness: 20","        )","        .doubleLSliderStyle(MyDoubleLSliderStyle())","        .frame(height: 60)","        .padding()","    }","}"]},"doc://Sliders/tutorials/DoubleLSlider-Tutorials":{"title":"Building Range Sliders with DoubleLSlider","role":"overview","identifier":"doc:\/\/Sliders\/tutorials\/DoubleLSlider-Tutorials","type":"topic","url":"\/tutorials\/doublelslider-tutorials","kind":"overview","abstract":[{"type":"text","text"