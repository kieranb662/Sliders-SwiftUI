ing the Finished Style"},"DoubleLSlider_Advanced_Step_1.swift":{"highlights":[],"fileType":"swift","fileName":"MyDoubleLSliderStyle.swift","type":"file","content":["import SwiftUI","","struct MyDoubleLSliderStyle: DoubleLSliderStyle {","","    func makeLowerThumb(configuration: DoubleLSliderConfiguration) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(width: 30, height: 30)","    }","","    func makeUpperThumb(configuration: DoubleLSliderConfiguration) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(width: 30, height: 30)","    }","","    func makeTrack(configuration: DoubleLSliderConfiguration) -> some View {","        AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            .fill(Color.gray.opacity(0.4))","    }","}","","struct ContentView: View {","    @State private var lower = 0.25","    @State private var upper = 0.75","","    var body: some View {","        DoubleLSlider(","            lowerValue: $lower,","            upperValue: $upper,","            range: 0...1,","            keepThumbInTrack: true,","            trackThickness: 20","        )","        .doubleLSliderStyle(MyDoubleLSliderStyle())","        .frame(height: 60)","        .padding()","    }","}"],"identifier":"DoubleLSlider_Advanced_Step_1.swift","syntax":"swift"},"doc://Sliders/documentation/Sliders/DoubleLSlider":{"navigatorTitle":[{"text":"DoubleLSlider","kind":"identifier"}],"abstract":[{"type":"text","text":"A spatially adaptive linear range slider with a lower thumb, an upper thumb,"},{"type":"text","text":" "},{"text":"and a draggable active-track segment between them.","type":"text"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"DoubleLSlider"}],"title":"DoubleLSlider","role":"symbol","type":"topic","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/DoubleLSlider","url":"\/documentation\/sliders\/doublelslider"},"doc://Sliders/tutorials/Sliders/DoubleLSlider-Advanced":{"role":"project","abstract":[{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/DoubleLSliderStyle","type":"reference"},{"text":" lets you take full control of every visual element of the","type":"text"},{"text":" ","type":"text"},{"text":"range slider. In this tutorial you’ll build a custom style from scratch — implementing","type":"text"},{"type":"text","text":" "},{"type":"text","text":"each protocol method one at a time."}],"type":"topic","estimatedTime":"20min","url":"\/tutorials\/sliders\/doublelslider-advanced","title":"Building a Custom DoubleLSlider Style","kind":"project","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/DoubleLSlider-Advanced"},"doc://Sliders/tutorials/DoubleLSlider-Tutorials/Creating-a-Custom-Style":{"kind":"article","abstract":[],"role":"article","identifier":"doc:\/\/Sliders\/tutorials\/DoubleLSlider-Tutorials\/Creating-a-Custom-Style","url":"\/tutorials\/doublelslider-tutorials\/creating-a-custom-style","type":"topic","title":"Creating a Custom Style"},"doc://Sliders/tutorials/Sliders/DoubleLSlider-Basics#Affinity-Snapping":{"kind":"section","url":"\/tutorials\/sliders\/doublelslider-basics#Affinity-Snapping","role":"pseudoSymbol","type":"section","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/DoubleLSlider","isActive":true,"type":"reference"},{"text":" is a linear range slider with two independent thumbs and a","type":"text"},{"text":" ","type":"text"},{"text":"draggable active-track segment. In this tutorial you’ll explore every configuration","type":"text"},{"text":" ","type":"text"},{"text":"option the default style offers — from a minimal setup to tick marks, affinity","type":"text"},{"text":" ","type":"text"},{"text":"snapping, and custom labels.","type":"text"}],"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/DoubleLSlider-Basics#Affinity-Snapping","title":"Affinity Snapping"},"DoubleLSlider_Advanced_Step_4.swift":{"fileType":"swift","syntax":"swift","fileName":"ContentView.swift","identifier":"DoubleLSlider_Advanced_Step_4.swift","content":["import SwiftUI","","struct MyDoubleLSliderStyle: DoubleLSliderStyle {","","    func makeLowerThumb(configuration: DoubleLSliderConfiguration) -> some View {","        let active = configuration.isLowerActive || configuration.isRangeActive","        return RoundedRectangle(cornerRadius: 6)","            .fill(active ? Color.teal : Color.white)","            .frame(width: 28, height: 28)","            .shadow(color: .black.opacity(0.25), radius: active ? 6 : 2)","    }","","    func makeUpperThumb(configuration: DoubleLSliderConfiguration) -> some View {","        let active = configuration.isUpperActive || configuration.isRangeActive","        return RoundedRectangle(cornerRadius: 6)","            .fill(active ? Color.teal : Color.white)","            .frame(width: 28, height: 28)","            .shadow(color: .black.opacity(0.25), radius: active ? 6 : 2)","    }","","    func makeTrack(configuration: DoubleLSliderConfiguration) -> some View {","        ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color(white: 0.2))","","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.upperPercent,","                cap: .square,","                adjustmentForThumb: 0","            )","            .fill(Color.teal)","            .mask(","                AdaptiveLine(","                    thickness: configuration.trackThickness,","                    angle: configuration.angle,","                    percentFilled: 1 - configuration.lowerPercent,","                    from: .end,","                    cap: .square,","                    adjustmentForThumb: 0","                )","            )","            .mask(AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle))","        }","    }","}","","struct ContentView: View {","    @State private var lowerH = 0.2","    @State private var upperH = 0.8","    @State private var lowerD = 0.3","    @State private var upperD = 0.7","","    var body: some View {","        VStack(spacing: 40) {","            DoubleLSlider(","                lowerValue: $lowerH,","                upperValue: $upperH,","                range: 0...1,","                keepThumbInTrack: true,","                trackThickness: 20,","                tickMarkSpacing: .count(11),","                affinityEnabled: true","            )","            .frame(height: 60)","","            DoubleLSlider(","                lowerValue: $lowerD,","                upperValue: $upperD,","                range: 0...1,","                angle: .degrees(30),","                keepThumbInTrack: true,","                trackThickness: 20","            )","            .frame(width: 300, height: 120)","        }","        .doubleLSliderStyle(MyDoubleLSliderStyle())","        .padding()","    }","}"],"highlights":[],"type":"file"},"DoubleLSlider_Advanced_Step_4.png":{"type":"image","identifier":"DoubleLSlider_Advanced_Step_4.png","variants":[{"url":"\/images\/Sliders\/DoubleLSlider_Advanced_Step_4.png","traits":["1x","light"]}],"alt":"Horizontal and diagonal range sliders using the custom style"},"doc://Sliders/tutorials/Sliders/DoubleLSlider-Basics#Custom-Labels-Disabled-State":{"kind":"section","abstract":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/DoubleLSlider","isActive":true},{"type":"text","text":" is a linear range slider with two independent thumbs and a"},{"type":"text","text":" "},{"type":"text","text":"draggable active-track segment. In this tutorial you’ll explore every configuration"},{"text":" ","type":"text"},{"type":"text","text":"option the default style offers — from a minimal setup to tick marks, affinity"},{"type":"text",