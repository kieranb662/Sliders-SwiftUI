{"metadata":{"category":"LSlider","title":"Using LSlider with the Default Style","categoryPathComponent":"LSlider-Tutorials","role":"project"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/sliders\/lslider-basics"]}],"sections":[{"backgroundImage":"LSlider_Basics_Step_1.png","content":[{"inlineContent":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true,"type":"reference"},{"text":" is a fully stylable linear slider that can be placed at any angle.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll explore every configuration option the default style offers —","type":"text"},{"text":" ","type":"text"},{"text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with","type":"text"},{"text":" ","type":"text"},{"text":"custom labels.","type":"text"}],"type":"paragraph"}],"image":"LSlider_Basics_Step_1.png","chapter":"Using the Default Style","kind":"hero","estimatedTimeInMinutes":20,"title":"Using LSlider with the Default Style"},{"kind":"tasks","tasks":[{"contentSection":[{"content":[{"inlineContent":[{"text":"Start with the simplest possible ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"text":", then gradually add the most","type":"text"},{"text":" ","type":"text"},{"text":"commonly used parameters: a custom range, a larger track, and constrained","type":"text"},{"text":" ","type":"text"},{"text":"thumb travel.","type":"text"}],"type":"paragraph"}],"media":"LSlider_Basics_Step_1.png","kind":"contentAndMedia","mediaPosition":"trailing"}],"stepsSection":[{"code":"LSlider_Basics_Step_1.swift","runtimePreview":"LSlider_Basics_Step_1.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"type":"text","text":" to your view by passing a "},{"type":"codeVoice","code":"@State"},{"type":"text","text":" binding.  Without any"},{"type":"text","text":" "},{"type":"text","text":"additional arguments it defaults to "},{"type":"codeVoice","code":"range: 0...1"},{"type":"text","text":", a horizontal angle, and"},{"type":"text","text":" "},{"type":"codeVoice","code":"trackThickness: 20"},{"type":"text","text":"."}]}],"type":"step","media":null,"caption":[]},{"content":[{"inlineContent":[{"text":"Specify a custom ","type":"text"},{"code":"range","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"trackThickness","type":"codeVoice"},{"text":" to scale the slider to your","type":"text"},{"text":" ","type":"text"},{"text":"use case.  Here the slider controls a value from ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"10","type":"codeVoice"},{"text":" and uses a","type":"text"},{"text":" ","type":"text"},{"text":"thicker ","type":"text"},{"code":"28","type":"codeVoice"},{"text":"-point track.","type":"text"}],"type":"paragraph"}],"media":null,"code":"LSlider_Basics_Step_2.swift","caption":[],"runtimePreview":"LSlider_Basics_Step_2.png","type":"step"},{"content":[{"inlineContent":[{"text":"Pass an ","type":"text"},{"type":"codeVoice","code":"angle"},{"text":" to rotate the track.  Any ","type":"text"},{"type":"codeVoice","code":"Angle"},{"type":"text","text":" is valid — here "},{"type":"codeVoice","code":"315°"},{"type":"text","text":" "},{"type":"text","text":"produces a diagonal slider.  Give the view enough space so the angled track"},{"type":"text","text":" "},{"type":"text","text":"can expand to fill it."}],"type":"paragraph"}],"media":null,"code":"LSlider_Basics_Step_3.swift","caption":[],"runtimePreview":"LSlider_Basics_Step_3.png","type":"step"},{"type":"step","media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enable "},{"type":"codeVoice","code":"keepThumbInTrack"},{"type":"text","text":" so the thumb’s centre stays within the visual"},{"type":"text","text":" "},{"type":"text","text":"extent of the capsule.  Compare the two sliders — note that the filled"},{"type":"text","text":" "},{"type":"text","text":"portion of the track always reaches the centre of the thumb."}]}],"code":"LSlider_Basics_Step_4.swift","runtimePreview":"LSlider_Basics_Step_4.png","caption":[]}],"anchor":"Basic-Usage","title":"Basic Usage"},{"title":"Tick Marks","stepsSection":[{"code":"LSlider_Basics_Step_5.swift","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":".count(N)","type":"codeVoice"},{"text":" to distribute exactly ","type":"text"},{"code":"N","type":"codeVoice"},{"text":" tick marks evenly across the","type":"text"},{"text":" ","type":"text"},{"text":"range, always including the endpoints.  Set ","type":"text"},{"type":"codeVoice","code":"hapticFeedbackEnabled: true"},{"type":"text","text":" to"},{"text":" ","type":"text"},{"text":"feel a light tap as the thumb crosses each mark.","type":"text"}]}],"type":"step","caption":[],"runtimePreview":"LSlider_Basics_Step_5.png","media":null},{"media":null,"code":"LSlider_Basics_Step_6.swift","type":"step","caption":[],"content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":".spacing(step)"},{"type":"text","text":" to place a tick mark every "},{"type":"codeVoice","code":"step"},{"type":"text","text":" units in the value"},{"type":"text","text":" "},{"type":"text","text":"domain.  A "},{"type":"codeVoice","code":"range: 0...10"},{"type":"text","text":" slider with "},{"type":"codeVoice","code":".spacing(1)"},{"type":"text","text":" produces 11 ticks at"},{"type":"text","text":" "},{"type":"text","text":"0, 1, 2, …, 10."}],"type":"paragraph"}],"runtimePreview":"LSlider_Basics_Step_6.png"},{"media":null,"code":"LSlider_Basics_Step_7.swift","type":"step","caption":[],"content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":".values([...])"},{"type":"text","text":" to place tick marks at specific, arbitrary positions in"},{"type":"text","text":" "},{"type":"text","text":"the value domain.  Values outside the slider’s "},{"type":"codeVoice","code":"range"},{"type":"text","text":" are silently ignored."},{"type":"text","text":" "},{"type":"text","text":"Pass "},{"type":"codeVoice","code":"hapticFeedbackEnabled: false"},{"type":"text","text":" to opt out of haptic feedback."}],"type":"paragraph"}],"runtimePreview":"LSlider_Basics_Step_7.png"}],"anchor":"Tick-Marks","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"type":"text","text":" supports three strategies for placing tick marks along the track,"},{"type":"text","text":" "},{"type":"text","text":"controlled by the "},{"type":"codeVoice","code":"tickMarkSpacing"},{"type":"text","text":" parameter.  Each strategy maps to a case of"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TickMarkSpacing"},{"type":"text","text":"."}]}],"kind":"contentAndMedia","mediaPosition":"trailing","media":"LSlider_Basics_Step_5.png"}]},{"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Enable "},{"code":"affinityEnabled","type":"codeVoice"},{"type":"text","text":" and pair it with "},{"code":"affinityRadius","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"affinityResistance","type":"codeVoice"},{"type":"text","text":".  "},{"code":"affinityRadius","type":"codeVoice"},{"type":"text","text":" (as a fraction of the total range)"},{"type":"text","text":" "},{"type":"text","text":"defines how close the thumb must be before it snaps in; once snapped, the"},{"type":"text","text":" "},{"type":"text","text":"thumb won’t escape until the drag moves "},{"code":"affinityRadius + affinityResistance","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"away."}],"type":"paragraph"}],"t