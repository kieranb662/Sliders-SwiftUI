xt","text":"continuously as the thumb moves."}],"type":"paragraph"}],"caption":[]},{"code":"LSlider_Basics_Step_11.swift","type":"step","media":null,"runtimePreview":"LSlider_Basics_Step_11.png","content":[{"inlineContent":[{"type":"text","text":"Apply "},{"code":".disabled(true)","type":"codeVoice"},{"type":"text","text":" to put the slider into a non-interactive state."},{"type":"text","text":" "},{"type":"text","text":"The default style dims the thumb and track automatically.  Compare the"},{"type":"text","text":" "},{"type":"text","text":"enabled and disabled sliders side-by-side."}],"type":"paragraph"}],"caption":[]}]}],"kind":"tasks"},{"abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","isActive":true,"type":"reference"},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"text":" ","type":"text"},{"text":"In this tutorial you’ll build ","type":"text"},{"type":"codeVoice","code":"MyLSliderStyle"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"protocol method one at a time — and applying the finished style to both horizontal"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"featuredEyebrow":"Tutorial","action":{"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced","type":"reference","isActive":true,"overridingTitle":"Get started","overridingTitleInlineContent":[{"text":"Get started","type":"text"}]},"kind":"callToAction","title":"Building a Custom LSlider Style"}],"metadata":{"categoryPathComponent":"LSlider-Tutorials","category":"LSlider","role":"project","title":"Using LSlider with the Default Style"},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"project","hierarchy":{"modules":[{"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Using-the-Default-Style","projects":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics","sections":[{"reference":"doc:\/\/S