graph","inlineContent":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true,"type":"reference"},{"text":" is a fully stylable linear slider that can be placed at any angle.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll explore every configuration option the default style offers —","type":"text"},{"text":" ","type":"text"},{"text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with","type":"text"},{"text":" ","type":"text"},{"text":"custom labels.","type":"text"}]}],"kind":"hero","title":"Using LSlider with the Default Style","backgroundImage":"LSlider_Basics_Step_1.png","estimatedTimeInMinutes":20,"image":"LSlider_Basics_Step_1.png","chapter":"Using the Default Style"},{"kind":"tasks","tasks":[{"contentSection":[{"mediaPosition":"trailing","media":"LSlider_Basics_Step_1.png","kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"Start with the simplest possible "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"type":"text","text":", then gradually add the most"},{"type":"text","text":" "},{"type":"text","text":"commonly used parameters: a custom range, a larger track, and constrained"},{"type":"text","text":" "},{"type":"text","text":"thumb travel."}],"type":"paragraph"}]}],"stepsSection":[{"runtimePreview":"LSlider_Basics_Step_1.png","caption":[],"type":"step","media":null,"code":"LSlider_Basics_Step_1.swift","content":[{"inlineContent":[{"type":"text","text":"Add "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true},{"type":"text","text":" to your view by passing a "},{"code":"@State","type":"codeVoice"},{"type":"text","text":" binding.  Without any"},{"type":"text","text":" "},{"type":"text","text":"additional arguments it defaults to "},{"code":"range: 0...1","type":"codeVoice"},{"type":"text","text":", a horizontal angle, and"},{"type":"text","text":" "},{"type":"codeVoice","code":"trackThickness: 20"},{"type":"text","text":"."}],"type":"paragraph"}]},{"media":null,"type":"step","caption":[],"code":"LSlider_Basics_Step_2.swift","content":[{"inlineContent":[{"type":"text","text":"Specify a custom "},{"type":"codeVoice","code":"range"},{"text":" and ","type":"text"},{"code":"trackThickness","type":"codeVoice"},{"text":" to scale the slider to your","type":"text"},{"text":" ","type":"text"},{"text":"use case.  Here the slider controls a value from ","type":"text"},{"type":"codeVoice","code":"0"},{"type":"text","text":" to "},{"type":"codeVoice","code":"10"},{"type":"text","text":" and uses a"},{"type":"text","text":" "},{"type":"text","text":"thicker "},{"type":"codeVoice","code":"28"},{"type":"text","text":"-point track."}],"type":"paragraph"}],"runtimePreview":"LSlider_Basics_Step_2.png"},{"runtimePreview":"LSlider_Basics_Step_3.png","code":"LSlider_Basics_Step_3.swift","caption":[],"media":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pass an "},{"type":"codeVoice","code":"angle"},{"type":"text","text":" to rotate the track.  Any "},{"code":"Angle","type":"codeVoice"},{"text":" is valid — here ","type":"text"},{"code":"315°","type":"codeVoice"},{"text":" ","type":"text"},{"text":"produces a diagonal slider.  Give the view enough space so the angled track","type":"text"},{"text":" ","type":"text"},{"text":"can expand to fill it.","type":"text"}]}]},{"runtimePreview":"LSlider_Basics_Step_4.png","code":"LSlider_Basics_Step_4.swift","caption":[],"media":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Enable ","type":"text"},{"code":"keepThumbInTrack","type":"codeVoice"},{"text":" so the thumb’s centre stays within the visual","type":"text"},{"text":" ","type":"text"},{"text":"extent of the capsule.  Compare the two sliders — note that the filled","type":"text"},{"text":" ","type":"text"},{"text":"portion of the track always reaches the centre of the thumb.","type":"text"}]}]}],"anchor":"Basic-Usage","title":"Basic Usage"},{"title":"Tick Marks","contentSection":[{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true},{"text":" supports three strategies for placing tick marks along the track,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"controlled by the "},{"code":"tickMarkSpacing","type":"codeVoice"},{"text":" parameter.  Each strategy maps to a case of","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TickMarkSpacing","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}],"media":"LSlider_Basics_Step_5.png","mediaPosition":"trailing","kind":"contentAndMedia"}],"anchor":"Tick-Marks","stepsSection":[{"caption":[],"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"code":".count(N)","type":"codeVoice"},{"type":"text","text":" to distribute exactly "},{"code":"N","type":"codeVoice"},{"text":" tick marks evenly across the","type":"text"},{"text":" ","type":"text"},{"text":"range, always including the endpoints.  Set ","type":"text"},{"type":"codeVoice","code":"hapticFeedbackEnabled: true"},{"text":" to","type":"text"},{"type":"text","text":" "},{"text":"feel a light tap as the thumb crosses each mark.","type":"text"}]}],"code":"LSlider_Basics_Step_5.swift","runtimePreview":"LSlider_Basics_Step_5.png","media":null},{"caption":[],"content":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":".spacing(step)"},{"text":" to place a tick mark every ","type":"text"},{"type":"codeVoice","code":"step"},{"text":" units in the value","type":"text"},{"type":"text","text":" "},{"text":"domain.  A ","type":"text"},{"code":"range: 0...10","type":"codeVoice"},{"text":" slider with ","type":"text"},{"type":"codeVoice","code":".spacing(1)"},{"text":" produces 11 ticks at","type":"text"},{"text":" ","type":"text"},{"text":"0, 1, 2, …, 10.","type":"text"}],"type":"paragraph"}],"media":null,"type":"step","runtimePreview":"LSlider_Basics_Step_6.png","code":"LSlider_Basics_Step_6.swift"},{"caption":[],"code":"LSlider_Basics_Step_7.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":".values([...])"},{"text":" to place tick marks at specific, arbitrary positions in","type":"text"},{"text":" ","type":"text"},{"text":"the value domain.  Values outside the slider’s ","type":"text"},{"code":"range","type":"codeVoice"},{"type":"text","text":" are silently ignored."},{"type":"text","text":" "},{"type":"text","text":"Pass "},{"code":"hapticFeedbackEnabled: false","type":"codeVoice"},{"type":"text","text":" to opt out of haptic feedback."}]}],"media":null,"runtimePreview":"LSlider_Basics_Step_7.png","type":"step"}]},{"contentSection":[{"content":[{"inlineContent":[{"text":"When ","type":"text"},{"code":"affinityEnabled","type":"codeVoice"},{"type":"text","text":" is "},{"code":"true","type":"codeVoice"},{"type":"text","text":", the thumb magnetically snaps to nearby tick"},{"type":"text","text":" "},{"text":"marks.  Two parameters let you tune how easy it is to snap in and break free.","type":"text"}],"type":"paragraph"}],"kind":"contentAndMedia","mediaPosition":"trailing","media":"LSlider_Basics_Step_8.png"}],"anchor":"Affinity-Snapping","stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Enable "},{"type":"codeVoice","code":"affinityEnabled"},{"type":"text","text":" and pair it with "},{"type":"codeVoice","code":"affinityRadius"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"affinityResistance","type":"codeVoice"},{"text":".  ","type":"text"},{"code":"affinityRadius","type":"codeVoice"},{"type":"text","text":" (as a fraction of the total range)"},{"type":"text","text":" "},{"type":"text","text":"defines how close the thumb must be before it snaps in; once snapped, the"},{"text":" ","type":"text"},{"type":"text","text":"thumb won’t escape until the drag moves "},{"code":"affinityRadius + affinityResistance","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"away."}],"type":"paragraph"}],"code":"LSlider_Basics_Step_8.swift","type":"step","runtimePreview":"LSlider_Basics_Step_8.png","caption":[],"media":null}],"title":"Affinity Snapping"},{"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","media":"LSlider_Basics_Step_9.png","content":[{"type":"paragraph","inlineContent":[{"text":"Fine-tune how users interact with the slider: allow tap-to-jump placement,","type":"text"},{"text":" ","type":"text"},{"text":"supply a fully custom floating label, and gracefully handle the disabled state.","type":"text"}]}]}],"anchor":"Interaction-Labels-Accessibility","stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Call ","type":"text"},{"code":".allowsSingleTapSelect(true)","type":"codeVoice"},{"text":" on the slider to let users tap anywhere","type":"text"},{"type":"text","text":" "},{"text":"on the track to instantly move the thumb to that position — no drag required.","type":"text"}]}],"caption":[],"media":null,"code":"LSlider_Basics_Step_9.swift","runtimePreview":"LSlider_Basics_Step_9.png","type":"step"},{"media":null,"code":"LSlider_Basics_Step_10.swift","runtimePreview":"LSlider_Basics_Step_10.png","type":"step","content":[{"inlineContent":[{"type":"text","text":"Provide a custom "},{"type":"codeVoice","code":"label"},{"type":"text","text":" closure to replace the default numeric readout with"},{"type":"text","text":" "},{"type":"text","text":"any view.  The closure receives the current "},{"code":"Double","type":"codeVoice"},{"text":" value and is called","type":"text"},{"text":" ","type":"text"},{"text":"continuously as the thumb moves.","type":"text"}],"type":"paragraph"}],"caption":[]},{"type":"step","caption":[],"media":null,"content":[{"type":"paragraph","inlineContent":[