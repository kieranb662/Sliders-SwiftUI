{"identifier":{"url":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics","interfaceLanguage":"swift"},"sections":[{"title":"Using LSlider with the Default Style","image":"LSlider_Basics_Step_1.png","chapter":"Using the Default Style","backgroundImage":"LSlider_Basics_Step_1.png","content":[{"inlineContent":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true,"type":"reference"},{"text":" is a fully stylable linear slider that can be placed at any angle.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll explore every configuration option the default style offers —","type":"text"},{"text":" ","type":"text"},{"text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with","type":"text"},{"text":" ","type":"text"},{"text":"custom labels.","type":"text"}],"type":"paragraph"}],"kind":"hero","estimatedTimeInMinutes":20},{"tasks":[{"title":"Basic Usage","contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"Start with the simplest possible "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"type":"text","text":", then gradually add the most"},{"type":"text","text":" "},{"type":"text","text":"commonly used parameters: a custom range, a larger track, and constrained"},{"type":"text","text":" "},{"type":"text","text":"thumb travel."}],"type":"paragraph"}],"mediaPosition":"trailing","media":"LSlider_Basics_Step_1.png","kind":"contentAndMedia"}],"stepsSection":[{"content":[{"inlineContent":[{"text":"Add ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","type":"reference"},{"text":" to your view by passing a ","type":"text"},{"code":"@State","type":"codeVoice"},{"text":" binding.  Without any","type":"text"},{"text":" ","type":"text"},{"text":"additional arguments it defaults to ","type":"text"},{"code":"range: 0...1","type":"codeVoice"},{"text":", a horizontal angle, and","type":"text"},{"text":" ","type":"text"},{"code":"trackThickness: 20","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"runtimePreview":"LSlider_Basics_Step_1.png","caption":[],"type":"step","media":null,"code":"LSlider_Basics_Step_1.swift"},{"content":[{"inlineContent":[{"text":"Specify a custom ","type":"text"},{"type":"codeVoice","code":"range"},{"type":"text","text":" and "},{"type":"codeVoice","code":"trackThickness"},{"type":"text","text":" to scale the slider to your"},{"type":"text","text":" "},{"type":"text","text":"use case.  Here the slider controls a value from "},{"type":"codeVoice","code":"0"},{"type":"text","text":" to "},{"type":"codeVoice","code":"10"},{"type":"text","text":" and uses a"},{"text":" ","type":"text"},{"text":"thicker ","type":"text"},{"code":"28","type":"codeVoice"},{"text":"-point track.","type":"text"}],"type":"paragraph"}],"runtimePreview":"LSlider_Basics_Step_2.png","caption":[],"type":"step","media":null,"code":"LSlider_Basics_Step_2.swift"},{"runtimePreview":"LSlider_Basics_Step_3.png","caption":[],"code":"LSlider_Basics_Step_3.swift","type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Pass an ","type":"text"},{"code":"angle","type":"codeVoice"},{"text":" to rotate the track.  Any ","type":"text"},{"code":"Angle","type":"codeVoice"},{"text":" is valid — here ","type":"text"},{"code":"315°","type":"codeVoice"},{"text":" ","type":"text"},{"text":"produces a diagonal slider.  Give the view enough space so the angled track","type":"text"},{"text":" ","type":"text"},{"text":"can expand to fill it.","type":"text"}]}],"media":null},{"runtimePreview":"LSlider_Basics_Step_4.png","caption":[],"code":"LSlider_Basics_Step_4.swift","type":"step","content":[{"inlineContent":[{"text":"Enable ","type":"text"},{"code":"keepThumbInTrack","type":"codeVoice"},{"text":" so the thumb’s centre stays within the visual","type":"text"},{"text":" ","type":"text"},{"text":"extent of the capsule.  Compare the two sliders — note that the filled","type":"text"},{"text":" ","type":"text"},{"text":"portion of the track always reaches the centre of the thumb.","type":"text"}],"type":"paragraph"}],"media":null}],"anchor":"Basic-Usage"},{"title":"Tick Marks","anchor":"Tick-Marks","contentSection":[{"media":"LSlider_Basics_Step_5.png","content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"type":"text","text":" supports three strategies for placing tick marks along the track,"},{"type":"text","text":" "},{"text":"controlled by the ","type":"text"},{"type":"codeVoice","code":"tickMarkSpacing"},{"text":" parameter.  Each strategy maps to a case of","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TickMarkSpacing"},{"type":"text","text":"."}],"type":"paragraph"}],"mediaPosition":"trailing","kind":"contentAndMedia"}],"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":".count(N)"},{"type":"text","text":" to distribute exactly "},{"type":"codeVoice","code":"N"},{"type":"text","text":" tick marks evenly across the"},{"type":"text","text":" "},{"type":"text","text":"range, always including the endpoints.  Set "},{"type":"codeVoice","code":"hapticFeedbackEnabled: true"},{"type":"text","text":" to"},{"type":"text","text":" "},{"text":"feel a light tap as the thumb crosses each mark.","type":"text"}],"type":"paragraph"}],"caption":[],"code":"LSlider_Basics_Step_5.swift","type":"step","media":null,"runtimePreview":"LSlider_Basics_Step_5.png"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":".spacing(step)"},{"type":"text","text":" to place a tick mark every "},{"type":"codeVoice","code":"step"},{"type":"text","text":" units in the value"},{"text":" ","type":"text"},{"text":"domain.  A ","type":"text"},{"code":"range: 0...10","type":"codeVoice"},{"text":" slider with ","type":"text"},{"code":".spacing(1)","type":"codeVoice"},{"text":" produces 11 ticks at","type":"text"},{"type":"text","text":" "},{"text":"0, 1, 2, …, 10.","type":"text"}]}],"media":null,"code":"LSlider_Basics_Step_6.swift","runtimePreview":"LSlider_Basics_Step_6.png","caption":[],"type":"step"},{"runtimePreview":"LSlider_Basics_Step_7.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":".values([...])"},{"type":"text","text":" to place tick marks at specific, arbitrary positions in"},{"text":" ","type":"text"},{"text":"the value domain.  Values outside the slider’s ","type":"text"},{"code":"range","type":"codeVoice"},{"text":" are silently ignored.","type":"text"},{"text":" ","type":"text"},{"text":"Pass ","type":"text"},{"code":"hapticFeedbackEnabled: false","type":"codeVoice"},{"text":" to opt out of haptic feedback.","type":"text"}]}],"media":null,"type":"step","caption":[],"code":"LSlider_Basics_Step_7.swift"}]},{"stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Enable ","type":"text"},{"type":"codeVoice","code":"affinityEnabled"},{"text":" and pair it with ","type":"text"},{"type":"codeVoice","code":"affinityRadius"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"affinityResistance","type":"codeVoice"},{"text":".  ","type":"text"},{"code":"affinityRadius","type":"codeVoice"},{"text":" (as a fraction of the total range)","type":"text"},{"text":" ","type":"text"},{"text":"defines how close the thumb must be before it snaps in; once snapped, the","type":"text"},{"text":" ","type":"text"},{"text":"thumb won’t escape until the drag moves ","type":"text"},{"type":"codeVoice","code":"affinityRadius + affinityResistance"},{"type":"text","text":" "},{"type":"text","text":"away."}]}],"code":"LSlider_Basics_Step_8.swift","media":null,"type":"step","runtimePreview":"LSlider_Basics_Step_8.png","caption":[]}],"anchor":"Affinity-Snapping","title":