" and uses a"},{"type":"text","text":" "},{"text":"thicker ","type":"text"},{"type":"codeVoice","code":"28"},{"type":"text","text":"-point track."}]}],"caption":[],"runtimePreview":"LSlider_Basics_Step_2.png","type":"step","media":null,"code":null},{"type":"step","runtimePreview":"LSlider_Basics_Step_3.png","caption":[],"media":null,"code":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pass an "},{"type":"codeVoice","code":"angle"},{"text":" to rotate the track.  Any ","type":"text"},{"type":"codeVoice","code":"Angle"},{"text":" is valid — here ","type":"text"},{"type":"codeVoice","code":"315°"},{"type":"text","text":" "},{"type":"text","text":"produces a diagonal slider.  Give the view enough space so the angled track"},{"type":"text","text":" "},{"type":"text","text":"can expand to fill it."}]}]},{"code":null,"runtimePreview":"LSlider_Basics_Step_4.png","type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Enable ","type":"text"},{"type":"codeVoice","code":"keepThumbInTrack"},{"text":" so the thumb’s centre stays within the visual","type":"text"},{"type":"text","text":" "},{"type":"text","text":"extent of the capsule.  Compare the two sliders — note that the filled"},{"text":" ","type":"text"},{"type":"text","text":"portion of the track always reaches the centre of the thumb."}]}],"caption":[],"media":null}],"contentSection":[{"media":"LSlider_Basics_Step_1.png","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Start with the simplest possible "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"text":", then gradually add the most","type":"text"},{"type":"text","text":" "},{"text":"commonly used parameters: a custom range, a larger track, and constrained","type":"text"},{"text":" ","type":"text"},{"text":"thumb travel.","type":"text"}]}],"kind":"contentAndMedia"}]},{"title":"Tick Marks","anchor":"Tick-Marks","stepsSection":[{"caption":[],"type":"step","content":[{"inlineContent":[{"type":"text","text":"Use "},{"code":".count(N)","type":"codeVoice"},{"type":"text","text":" to distribute exactly "},{"type":"codeVoice","code":"N"},{"type":"text","text":" tick marks evenly across the"},{"type":"text","text":" "},{"type":"text","text":"range, always including the endpoints.  Set "},{"type":"codeVoice","code":"hapticFeedbackEnabled: true"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"feel a light tap as the thumb crosses each mark."}],"type":"paragraph"}],"media":null,"code":null,"runtimePreview":"LSlider_Basics_Step_5.png"},{"media":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"Use "},{"code":".spacing(step)","type":"codeVoice"},{"type":"text","text":" to place a tick mark every "},{"type":"codeVoice","code":"step"},{"type":"text","text":" units in the value"},{"type":"text","text":" "},{"type":"text","text":"domain.  A "},{"type":"codeVoice","code":"range: 0...10"},{"text":" slider with ","type":"text"},{"code":".spacing(1)","type":"codeVoice"},{"type":"text","text":" produces 11 ticks at"},{"type":"text","text":" "},{"type":"text","text":"0, 1, 2, …, 10."}],"type":"paragraph"}],"caption":[],"runtimePreview":"LSlider_Basics_Step_6.png","code":null},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":".values([...])","type":"codeVoice"},{"text":" to place tick marks at specific, arbitrary positions in","type":"text"},{"type":"text","text":" "},{"text":"the value domain.  Values outside the slider’s ","type":"text"},{"type":"codeVoice","code":"range"},{"text":" are silently ignored.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Pass "},{"code":"hapticFeedbackEnabled: false","type":"codeVoice"},{"type":"text","text":" to opt out of haptic feedback."}]}],"code":null,"runtimePreview":"LSlider_Basics_Step_7.png","type":"step","caption":[],"media":null}],"contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","type":"reference","isActive":true},{"type":"text","text":" supports three strategies for placing tick marks along the track,"},{"type":"text","text":" "},{"type":"text","text":"controlled by the "},{"code":"tickMarkSpacing","type":"codeVoice"},{"text":" parameter.  Each strategy maps to a case of","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TickMarkSpacing","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}],"mediaPosition":"trailing","media":"LSlider_Basics_Step_5.png"}]},{"title":"Affinity Snapping","stepsSection":[{"runtimePreview":"LSlider_Basics_Step_8.png","caption":[],"content":[{"inlineContent":[{"type":"text","text":"Enable "},{"type":"codeVoice","code":"affinityEnabled"},{"type":"text","text":" and pair it with "},{"type":"codeVoice","code":"affinityRadius"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"affinityResistance","type":"codeVoice"},{"text":".  ","type":"text"},{"type":"codeVoice","code":"affinityRadius"},{"type":"text","text":" (as a fraction of the total range)"},{"text":" ","type":"text"},{"text":"defines how close the thumb must be before it snaps in; once snapped, the","type":"text"},{"text":" ","type":"text"},{"text":"thumb won’t escape until the drag moves ","type":"text"},{"type":"codeVoice","code":"affinityRadius + affinityResistance"},{"text":" ","type":"text"},{"text":"away.","type":"text"}],"type":"paragraph"}],"type":"step","media":null,"code":null}],"contentSection":[{"media":"LSlider_Basics_Step_8.png","mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"code":"affinityEnabled","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":", the thumb magnetically snaps to nearby tick","type":"text"},{"te