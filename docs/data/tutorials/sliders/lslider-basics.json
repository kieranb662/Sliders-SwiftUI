{"hierarchy":{"modules":[{"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Using-the-Default-Style","projects":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics","sections":[{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Basic-Usage"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Tick-Marks"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Affinity-Snapping"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Interaction-Labels-Accessibility"}]}]},{"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Creating-a-Custom-Style","projects":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced","sections":[{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Declaring-the-Style"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTrack"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeThumb"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTickMark"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeLabel"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Applying-the-Finished-Style"}]}]}],"paths":[["doc:\/\/Sliders\/tutorials\/LSlider-Tutorials","doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/$volume","doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Using-the-Default-Style"]],"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials"},"sections":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","type":"reference","isActive":true},{"type":"text","text":" is a fully stylable linear slider that can be placed at any angle."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore every configuration option the default style offers —"},{"type":"text","text":" "},{"type":"text","text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with"},{"type":"text","text":" "},{"type":"text","text":"custom labels."}]}],"title":"Using LSlider with the Default Style","image":"LSlider_Basics_Step_1.png","chapter":"Using the Default Style","estimatedTimeInMinutes":20,"kind":"hero","backgroundImage":"LSlider_Basics_Step_1.png"},{"kind":"tasks","tasks":[{"contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Start with the simplest possible "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true},{"type":"text","text":", then gradually add the most"},{"type":"text","text":" "},{"type":"text","text":"commonly used parameters: a custom range, a larger track, and constrained"},{"type":"text","text":" "},{"type":"text","text":"thumb travel."}]}],"media":"LSlider_Basics_Step_1.png","kind":"contentAndMedia","mediaPosition":"trailing"}],"title":"Basic Usage","anchor":"Basic-Usage","stepsSection":[{"runtimePreview":"LSlider_Basics_Step_1.png","content":[{"inlineContent":[{"type":"text","text":"Add "},{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","type":"reference"},{"type":"text","text":" to your view by passing a "},{"type":"codeVoice","code":"@State"},{"type":"text","text":" binding.  Without any"},{"type":"text","text":" "},{"type":"text","text":"additional arguments it defaults to "},{"type":"codeVoice","code":"range: 0...1"},{"type":"text","text":", a horizontal angle, and"},{"type":"text","text":" "},{"type":"codeVoice","code":"trackThickness: 20"},{"type":"text","text":"."}],"type":"paragraph"}],"caption":[],"type":"step","media":null,"code":"LSlider_Basics_Step_1.swift"},{"code":"LSlider_Basics_Step_2.swift","runtimePreview":"LSlider_Basics_Step_2.png","content":[{"type":"paragraph","inlineContent":[{"text":"Specify a custom ","type":"text"},{"code":"range","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"trackThickness","type":"codeVoice"},{"text":" to scale the slider to your","type":"text"},{"text":" ","type":"text"},{"text":"use case.  Here the slider controls a value from ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"10","type":"codeVoice"},{"text":" and uses a","type":"text"},{"text":" ","type":"text"},{"text":"thicker ","type":"text"},{"code":"28","type":"codeVoice"},{"text":"-point track.","type":"text"}]}],"type":"step","media":null,"caption":[]},{"code":"LSlider_Basics_Step_3.swift","runtimePreview":"LSlider_Basics_Step_3.png","content":[{"inlineContent":[{"type":"text","text":"Pass an "},{"code":"angle","type":"codeVoice"},{"type":"text","text":" to rotate the track.  Any "},{"code":"Angle","type":"codeVoice"},{"type":"text","text":" is valid — here "},{"type":"codeVoice","code":"315°"},{"type":"text","text":" "},{"type":"text","text":"produces a diagonal slider.  Give the view enough space so the angled track"},{"type":"text","text":" "},{"type":"text","text":"can expand to fill it."}],"type":"paragraph"}],"type":"step","media":null,"caption":[]},{"content":[{"inlineContent":[{"type":"text","text":"Enable "},{"type":"codeVoice","code":"keepThumbInTrack"},{"type":"text","text":" so the thumb’s centre stays within the visual"},{"type":"text","text":" "},{"type":"text","text":"extent of the capsule.  Compare the two sliders — note that the filled"},{"type":"text","text":" "},{"type":"text","text":"portion of the track always reaches the centre of the thumb."}],"type":"paragraph"}],"caption":[],"media":null,"runtimePreview":"LSlider_Basics_Step_4.png","code":"LSlider_Basics_Step_4.swift","type":"step"}]},{"contentSection":[{"media":"LSlider_Basics_Step_5.png","mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true},{"text":" supports three strategies for placing tick marks along the track,","type":"text"},{"text":" ","type":"text"},{"text":"controlled by the ","type":"text"},{"type":"codeVoice","code":"tickMarkSpacing"},{"text":" parameter.  Each strategy maps to a case of","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TickMarkSpacing","isActive":true},{"type":"text","text":"."}]}]}],"title":"Tick Marks","stepsSection":[{"runtimePreview":"LSlider_Basics_Step_5.png","media":null,"caption":[],"code":"LSlider_Basics_Step_5.swift","type":"step","content":[{"inlineContent":[{"type":"text","text":"Use "},{"code":".count(N)","type":"codeVoice"},{"type":"text","text":" to distribute exactly "},{"type":"codeVoice","code":"N"},{"text":" tick marks evenly across the","type":"text"},{"text":" ","type":"text"},{"text":"range, always including the endpoints.  Set ","type":"text"},{"type":"codeVoice","code":"hapticFeedbackEnabled: true"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"text":"feel a light tap as the thumb crosses each mark.","type":"text"}],"type":"paragraph"}]},{"type":"step","caption":[],"code":"LSlider_Basics_Step_6.swift","media":null,"runtimePreview":"LSlider_Basics_Step_6.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"code":".spacing(step)","type":"codeVoice"},{"type":"text","text":" to place a tick mark every "},{"type":"codeVoice","code":"step"},{"text":" units in the value","type":"text"},{"type":"text","text":" "},{"type":"text","text":"domain.  A "},{"type":"codeVoice","code":"range: 0...10"},{"type":"text","text":" slider with "},{"code":".spacing(1)","type":"codeVoice"},{"text":" produces 11 ticks at","type":"text"},{"text":" ","type":"text"},{"text":"0, 1, 2, …, 10.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":".values([...])","type":"codeVoice"},{"text":" to place tick marks at specific, arbitrary positions in","type":"text"},{"text":" ","type":"text"},{"text":"the value domain.  Values outside the slider’s ","type":"text"},{"code":"range","type":"codeVoice"},{"text":" are silently ignored.","type":"text"},{"text":" ","type":"text"},{"text":"Pass ","type":"text"},{"code":"hapticFeedbackEnabled: false","type":"codeVoice"},{"type":"text","text":" to opt out of haptic feedback."}]}],"code":"LSlider_Basics_Step_7.swift","type":"step","caption":[],"media":null,"runtimePreview":"LSlider_Basics_Step_7.png"}],"anchor":"Tick-Marks"},{"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","media":"LSlider_Basics_Step_8.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"affinityEnabled"},{"type":"text","text":" is "},{"code":"true","type":"codeVoice"},{"type":"text","text":", the thumb magnetically snaps to nearby tick"},{"text":" ","type":"text"},{"type":"text","text":"marks.  Two parameters let you tune how easy it is to snap in and break free."}]}]}],"title":"Affinity Snapping","stepsSection":[{"type":"step","runtimePreview":"LSlider_Basics_Step_8.png","code":"LSlider_Basics_Step_8.swift","caption":[],"content":[{"inlineContent":[{"type":"text","text":"Enable "},{"code":"affinityEnabled","type":"codeVoice"},{"type":"text","text":" and pair it with "},{"code":"affinityRadius","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"affinityResistance","type":"codeVoice"},{"type":"text","text":".  "},{"code":"affinityRadius","type":"codeVoice"},{"type":"text","text":" (as a fraction of the total range)"},{"type":"text","text":" "},{"text":"defines how close the thumb must be before it snaps in; once snapped, the","type":"text"},{"type":"text","text":" "},{"text":"thumb won’t escape until the drag moves ","type":"text"},{"code":"affinityRadius + affinityResistance","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"away."}],"type":"paragraph"}],"media":null}],"anchor":"Affinity-Snapping"},{"contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Fine-tune how users interact with the slider: allow tap-to-jump placement,"},{"type":"text","text":" "},{"type":"text","text":"supply a fully custom floating label, and gracefully handle the disabled state."}]}],"kind":"contentAndMedia","mediaPosition":"trailing","media":"LSlider_Basics_Step_9.png"}],"title":"Interaction, Labels & Accessibility","anchor":"Interaction-Labels-Accessibility","stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Call "},{"type":"codeVoice","code":".allowsSingleTapSelect(true)"},{"type":"text","text":" on the slider to let users tap anywhere"},{"type":"text","text":" "},{"type":"text","text":"on the track to instantly move the thumb to that position — no drag required."}]}],"caption":[],"type":"step","code":"LSlider_Basics_Step_9.swift","runtimePreview":"LSlider_Basics_Step_9.png","media":null},{"caption":[],"code":"LSlider_Basics_Step_10.swift","content":[{"inlineContent":[{"type":"text","text":"Provide a custom "},{"type":"codeVoice","code":"label"},{"type":"text","text":" closure to replace the default numeric readout with"},{"type":"text","text":" "},{"type":"text","text":"any view.  The closure receives the current "},{"type":"codeVoice","code":"Double"},{"type":"text","text":" value and is called"},{"type":"text","text":" "},{"type":"text","text":"continuously as the thumb moves."}],"type":"paragraph"}],"type":"step","media":null,"runtimePreview":"LSlider_Basics_Step_10.png"},{"runtimePreview":"LSlider_Basics_Step_11.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apply "},{"type":"codeVoice","code":".disabled(true)"},{"type":"text","text":" to put the slider into a non-interactive state."},{"type":"text","text":" "},{"type":"text","text":"The default style dims the thumb and track automatically.  Compare the"},{"text":" ","type":"text"},{"type":"text","text":"enabled and disabled sliders side-by-side."}]}],"type":"step","code":"LSlider_Basics_Step_11.swift","caption":[],"media":null}]}]},{"abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","type":"reference","isActive":true},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll build "},{"code":"MyLSliderStyle","type":"codeVoice"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"kind":"callToAction","title":"Building a Custom LSlider Style","action":{"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced","overridingTitle":"Get started","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"isActive":true,"type":"reference"},"featuredEyebrow":"Tutorial"}],"kind":"project","variants":[{"paths":["\/tutorials\/sliders\/lslider-basics"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics"},"metadata":{"category":"LSlider","title":"Using LSlider with the Default Style","categoryPathComponent":"LSlider-Tutorials","role":"project"},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"LSlider_Basics_Step_2.swift":{"content":["import SwiftUI","","struct ContentView: View {","    @State private var value = 5.0","","    var body: some View {","        VStack(spacing: 8) {","            LSlider($value, range: 0...10, trackThickness: 28)","                .frame(height: 72)","            Text(\"Value: \\(value, specifier: \"%.1f\")\")","                .font(.caption)","        }","        .paddin