        }","        }","    }","}","","struct ContentView: View {","    @State private var point = CGPoint(x: 0.5, y: 0.5)","","    var body: some View {","        TrackPad($point)","            .trackPadStyle(MyTrackPadStyle())","            .frame(height: 260)","            .padding()","    }","}"],"syntax":"swift","type":"file","fileName":"MyTrackPadStyle.swift","fileType":"swift"},"doc://Sliders/tutorials/Sliders/TrackPad-Advanced#Implementing-makeThumb":{"abstract":[{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TrackPadStyle","type":"reference"},{"text":" lets you take full control of every visual element of the 2-D","type":"text"},{"text":" ","type":"text"},{"text":"slider. In this tutorial you’ll build a custom style from scratch.","type":"text"}],"title":"Implementing makeThumb","type":"section","url":"\/tutorials\/sliders\/trackpad-advanced#Implementing-makeThumb","kind":"section","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/TrackPad-Advanced#Implementing-makeThumb","role":"pseudoSymbol"},"doc://Sliders/tutorials/Sliders/TrackPad-Advanced#Declaring-the-Style":{"abstract":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TrackPadStyle","isActive":true},{"type":"text","text":" lets you take full control of every visual element of the 2-D"},{"type":"text","text":" "},{"type":"text","text":"slider. In this tutorial you’ll build a custom style from scratch."}],"title":"Declaring the Style","type":"section","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/TrackPad-Advanced#Declaring-the-Style","kind":"section","url":"\/tutorials\/sliders\/trackpad-advanced#Declaring-the-Style","role":"pseudoSymbol"},"doc://Sliders/tutorials/TrackPad-Tutorials":{"abstract":[{"type":"text","text":"Learn how to add a 2-D slider to your app — starting with the built-in default"},{"type":"text","text":" "},{"type":"text","text":"style and its configuration options, then advancing to building a custom style."}],"title":"Buildi