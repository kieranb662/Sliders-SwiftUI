ed-State":{"abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TrackPad"},{"type":"text","text":" is the 2-D equivalent of a slider — a draggable thumb moves freely"},{"type":"text","text":" "},{"type":"text","text":"inside a rectangular area, controlling independent x and y values. In this tutorial"},{"type":"text","text":" "},{"type":"text","text":"you’ll explore every configuration option the default style offers."}],"title":"Labels & Disabled State","url":"\/tutorials\/sliders\/trackpad-basics#Labels-Disabled-State","type":"section","role":"pseudoSymbol","kind":"section","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/TrackPad-Basics#Labels-Disabled-State"},"doc://Sliders/tutorials/Sliders/TrackPad-Advanced#Implementing-makeTrack":{"url":"\/tutorials\/sliders\/trackpad-advanced#Implementing-makeTrack","title":"Implementing makeTrack","abstract":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TrackPadStyle","isActive":true},{"type":"text","text":" lets you take full control of every visual element of the 2-D"},{"type":"text","text":" "},{"type":"text","text":"slider. In this tutorial you’ll build a custom style from scratch."}],"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/TrackPad-Advanced#Implementing-makeTrack","kind":"section","type":"section","role":"pseudoSymbol"},"TrackPad_Advanced_Step_5.swift":{"highlights":[],"content":["import SwiftUI","","struct MyTrackPadStyle: TrackPadStyle {","","    func makeThumb(configuration: TrackPadConfiguration) -> some View {","        ZStack {","            Circle()","                .fill(configuration.isActive ? Color.blue.opacity(0.8) : Color.blue)","                .frame(width: 20, height: 20)","            Circle()","                .fill(Color.white)","                .frame(width: 6, height: 6)","        }","        .shadow(color: .black.opacity(0.25), radius: configuration.isActive ? 8 : 3)","        .animation(.easeOut(duration: 0.1), value: configuration.isActive)","    }","","    func makeTrack(configuration: TrackPadConfiguration) -> some View {","        ZStack {","            RoundedRectangle(cornerRadius: 12)","                .fill(Color.blue.opacity(0.12))","                .overlay(","                    RoundedRectangle(cornerRadius: 12)","                        .strokeBorder(Color.blue.opacity(0.4), lineWidth: 1)","                )","            GeometryReader { geo in","                let cols = 4; let rows = 4","                ForEach(0..<cols, id: \\.self) { col in","                    ForEach(0..<rows, id: \\.self) { row in","                        Circle()","                            .fill(Color.blue.opacity(0.3))","                            .frame(width: 3, height: 3)","                            .position(","                                x: geo.size.width  * CGFloat(col + 1) \/ CGFloat(cols + 1),","                                y: geo.size.height * CGFloat(row + 1) \/ CGFloat(rows + 1)","                            )","                    }","                }","            }","        }","    }","","    func makePreviousValueIndicator(configuration: TrackPadConfiguration) -> some View {","        let snapped = configuration.isSnappedToPrevious","        let size: Double = snapped ? 14 : 9","        return Rectangle()","            .fill(Color.blue.opacity(snapped ? 0.85 : 0.40))","            .frame(width: size, height: size)","            .rotationEffect(.degrees(45))","            .animation(.easeOut(duration: 0.15), value: snapped)","    }","}","","struct ContentView: View {","    @State private var pointA = CGPoint(x: 0.5, y: 0.5)","    @State private var pointB = CGPoint(x: 0.5, y: 0.5)","","    var body: some View {","        VStack(spacing: 20) {","            TrackPad($pointA)","                .showPreviousValue(true)","                .tickCount(4)","                .frame(height: 260)","","            TrackPad($pointB, rangeX: -1...1, rangeY: -1...1)","                .frame(height: 200)","        }","        .trackPadStyle(MyTrackPadStyle())","        .padding()","    }","}"],"fileName":"ContentView.swift","identifier":"TrackPad_Advanced_Step_5.swift","syntax":"swift","type":"file","fileType":"swift"},"TrackPad_Advanced_Step_4.png":{"identifier":"TrackPad_Advanced_Step_4.png","variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/TrackPad_Advanced_Step_4.png"}],"alt":"Diamond previous-value indicator","type":"image"},"TrackPad_Advanced_Step_1.png":{"alt":"Gray stub TrackPad","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/TrackPad_Advanced_Step_1.png"}],"identifier":"TrackPad_Advanced_Step_1.png"},"doc://Sliders/tutorials/TrackPad-Tutorials/Using-the-Default-Style":{"abstract":[],"title":"Using the Default Style","url":"\/tutorials\/trackpad-tutorials\/using-the-default-style","type":"topic","role":"article","kind":"article","identifier":"doc:\/\/Sliders\/tutorials\/TrackPad-Tutorials\/Using-the-Default-Style"},"doc://Sliders/tutorials/Sliders/TrackPad-Advanced#Applying-the-Finished-Style":{"abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TrackPadStyle"},{"type":"text","text":" lets you take full control of every visual element of the 2-D"},{"type":"text","text":" "},{"type":"text","text":"slider. In this tutorial you’ll build a custom style from scratch."}],"role":"pseudoSymbol","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/TrackPad-Advanced#Applying-the-Finished-Style","title":"Applying the Finished Style","url":"\/tutorials\/sliders\/trackpad-advanced#Applying-the-Finished-Style","type":"section","kind":"section"},"doc://Sliders/tutorials/Sliders/TrackPad-Advanced#Declaring-the-Style":{"abstract":[{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/TrackPadStyle","type":"reference"},{"text":" lets you take full control of every visual element of the 2-D","type":"text"},{"text":" ","type