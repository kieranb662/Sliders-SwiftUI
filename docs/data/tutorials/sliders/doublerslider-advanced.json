      let active = configuration.isUpperActive || configuration.isRangeActive","        return RoundedRectangle(cornerRadius: 6)","            .fill(active ? Color.teal : Color.white)","            .frame(width: 28, height: 28)","            .shadow(color: .black.opacity(0.25), radius: active ? 6 : 2)","    }","","    func makeTrack(configuration: DoubleRSliderConfiguration) -> some View {","        let arcLength = configuration.upperPercent - configuration.lowerPercent","        return ZStack {","            Circle()","                .stroke(Color.gray.opacity(0.3), lineWidth: 18)","","            CircularArc(percent: arcLength)","                .stroke(Color.teal, style: StrokeStyle(lineWidth: 18, lineCap: .round))","                .padding(9)","        }","    }","}","","struct ContentView: View {","    @State private var lower = 0.25","    @State private var upper = 0.75","","    var body: some View {","        DoubleRSlider(","            lowerValue: $lower,","            upperValue: $upper,","            range: 0...1","        )","        .doubleRadialSliderStyle(MyDoubleRSliderStyle())","        .frame(width: 220, height: 220)","        .padding()","    }","}"],"type":"file"},"doc://Sliders/documentation/Sliders/CircularArc":{"title":"CircularArc","kind":"symbol","abstract":[],"url":"\/documentation\/sliders\/circulararc","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CircularArc","kind":"identifier"}],"navigatorTitle":[{"text":"CircularArc","kind":"identifier"}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/CircularArc","role":"symbol","type":"topic"},"doc://Sliders/tutorials/Sliders/DoubleRSlider-Advanced#Implementing-the-Thumbs":{"abstract":[{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/DoubleRSliderStyle","type":"reference"},{"text":" lets you take full control of every visual element of the","type":"text"},{"text":" ","type":"text"},{"text":"circular range slider. In this tutorial