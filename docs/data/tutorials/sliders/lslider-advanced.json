{"hierarchy":{"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials","paths":[["doc:\/\/Sliders\/tutorials\/LSlider-Tutorials","doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/$volume","doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Creating-a-Custom-Style"]],"modules":[{"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Using-the-Default-Style","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Basic-Usage"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Tick-Marks"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Affinity-Snapping"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Interaction-Labels-Accessibility","kind":"task"}],"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics"}]},{"projects":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced","sections":[{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Declaring-the-Style"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTrack","kind":"task"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeThumb"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTickMark"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeLabel","kind":"task"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Applying-the-Finished-Style"}]}],"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Creating-a-Custom-Style"}]},"metadata":{"categoryPathComponent":"LSlider-Tutorials","title":"Building a Custom LSlider Style","role":"project","category":"LSlider"},"kind":"project","schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/sliders\/lslider-advanced"]}],"sections":[{"title":"Building a Custom LSlider Style","estimatedTimeInMinutes":20,"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","type":"reference"},{"text":" lets you take full control of every visual element of the slider.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll build ","type":"text"},{"code":"MyLSliderStyle","type":"codeVoice"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}]}],"image":"LSlider_Advanced_Step_6.png","kind":"hero","chapter":"Creating a Custom Style","backgroundImage":"LSlider_Advanced_Step_6.png"},{"tasks":[{"anchor":"Declaring-the-Style","contentSection":[{"content":[{"inlineContent":[{"text":"Start by creating a struct that conforms to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","type":"reference"},{"text":".  The protocol","type":"text"},{"text":" ","type":"text"},{"text":"requires four methods; you’ll add stub implementations first to make the code","type":"text"},{"text":" ","type":"text"},{"text":"compile, then flesh each one out in the following sections.","type":"text"}],"type":"paragraph"}],"kind":"contentAndMedia","mediaPosition":"trailing","media":"LSlider_Advanced_Step_1.png"}],"stepsSection":[{"code":"LSlider_Advanced_Step_1.swift","type":"step","content":[{"inlineContent":[{"type":"text","text":"Create a new Swift file and declare "},{"code":"MyLSliderStyle","type":"codeVoice"},{"type":"text","text":" as a "},{"code":"struct","type":"codeVoice"},{"type":"text","text":" that"},{"type":"text","text":" "},{"type":"text","text":"conforms to "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"type":"text","text":".  Provide placeholder bodies for all four"},{"type":"text","text":" "},{"type":"text","text":"required methods — "},{"type":"codeVoice","code":"makeThumb"},{"type":"text","text":", "},{"type":"codeVoice","code":"makeTrack"},{"type":"text","text":", "},{"type":"codeVoice","code":"makeTickMark"},{"type":"text","text":", and"},{"type":"text","text":" "},{"type":"codeVoice","code":"makeLabel"},{"type":"text","text":" — so the project compiles while you iterate."}],"type":"paragraph"}],"runtimePreview":"LSlider_Advanced_Step_1.png","caption":[{"inlineContent":[{"type":"text","text":"Apply the style with "},{"type":"codeVoice","code":".linearSliderStyle(MyLSliderStyle())"},{"type":"text","text":" to see it"},{"type":"text","text":" "},{"type":"text","text":"immediately in the preview."}],"type":"paragraph"}],"media":null}],"title":"Declaring the Style"},{"contentSection":[{"media":"LSlider_Advanced_Step_2.png","mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The track is the backbone of the slider.  It consists of two layered"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine"},{"type":"text","text":" shapes: a dim background and a filled foreground that"},{"type":"text","text":" "},{"type":"text","text":"grows with "},{"code":"pctFill","type":"codeVoice"},{"type":"text","text":"."}]}]}],"title":"Implementing makeTrack","stepsSection":[{"runtimePreview":"LSlider_Advanced_Step_2.png","media":null,"caption":[{"inlineContent":[{"text":"Use ","type":"text"},{"code":"configuration.pctFill","type":"codeVoice"},{"text":" for the fill percentage and","type":"text"},{"text":" ","type":"text"},{"code":"configuration.keepThumbInTrack","type":"codeVoice"},{"text":" to compute the correct ","type":"text"},{"code":"adjustmentForThumb","type":"codeVoice"},{"text":" ","type":"text"},{"text":"so the fill always ends under the thumb’s centre.","type":"text"}],"type":"paragraph"}],"code":"LSlider_Advanced_Step_2.swift","type":"step","content":[{"inlineContent":[{"type":"text","text":"Replace the stub "},{"code":"makeTrack","type":"codeVoice"},{"type":"text","text":" body.  Layer two "},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine","type":"reference","isActive":true},{"type":"text","text":" shapes in a"},{"text":" ","type":"text"},{"code":"ZStack","type":"codeVoice"},{"text":": one as the empty background and one as the filled foreground.","type":"text"},{"text":" ","type":"text"},{"text":"Mask the filled portion so it stays within the capsule.","type":"text"}],"type":"paragraph"}]}],"anchor":"Implementing-makeTrack"},{"contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"The thumb needs to communicate three states visually: normal, active (while"},{"type":"text","text":" "},{"text":"dragging), and disabled.  Use ","type":"text"},{"code":"configuration.isActive","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"configuration.isDisabled"},{"type":"text","text":" to drive color and shadow changes."}],"type":"paragraph"}],"media":"LSlider_Advanced_Step_3.png","mediaPosition":"trailing","kind":"contentAndMedia"}],"anchor":"Implementing-makeThumb","title":"Implementing makeThumb","stepsSection":[{"caption":[{"inlineContent":[{"type":"text","text":"Pick the fill color based on "},{"code":"isDisabled","type":"codeVoice"},{"type":"text","text":" → "},{"code":"isActive","type":"codeVoice"},{"text":", and add a shadow","type":"text"},{"text":" ","type":"text"},{"text":"whose radius expands when the thumb is active to give a lifted feel.  Wrap","type":"text"},{"text":" ","type":"text"},{"text":"the color and shadow in an ","type":"text"},{"code":".animation","type":"codeVoice"},{"type":"text","text":" so the transition is smooth."}],"type":"paragraph"}],"content":[{"inlineContent":[{"type":"text","text":"Replace the stub "},{"type":"codeVoice","code":"makeThumb"},{"type":"text","text":" body.  Size the "},{"type":"codeVoice","code":"Circle"},{"type":"text","text":" from"},{"type":"text","text":" "},{"type":"codeVoice","code":"configuration.trackThickness"},{"type":"text","text":" (double it for a standard thumb diameter)."}],"type":"paragraph"}],"media":null,"code":"LSlider_Advanced_Step_3.swift","type":"step","runtimePreview":"LSlider_Advanced_Step_3.png"}]},{"stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Replace the stub ","type":"text"},{"code":"makeTickMark","type":"codeVoice"},{"type":"text","text":" body.  Compute the normalised positions of"},{"type":"text","text":" "},{"text":"the thumb (","type":"text"},{"code":"thumbPct","type":"codeVoice"},{"type":"text","text":") and the tick mark ("},{"type":"codeVoice","code":"tickPct"},{"type":"text","text":") in the "},{"type":"codeVoice","code":"0…1"},{"type":"text","text":" space,"},{"type":"text","text":" "},{"type":"text","text":"then derive a "},{"type":"codeVoice","code":"proximity"},{"type":"text","text":" value between "},{"type":"codeVoice","code":"0"},{"type":"text","text":" (far) and "},{"type":"codeVoice","code":"1"},{"type":"text","text":" (on top)."}]}],"caption":[{"inlineContent":[{"type":"text","text":"Use "},{"code":"proximity","type":"codeVoice"},{"type":"text","text":" to interpolate both the circle’s "},{"type":"codeVoice","code":"size"},{"type":"text","text":" and its "},{"type":"codeVoice","code":"opacity"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and wrap the result in "},{"type":"codeVoice","code":".animation(.easeOut)"},{"type":"text","text":" so it feels responsive."}],"type":"paragraph"}],"media":null,"type":"step","code":"LSlider_Advanced_Step_4.swift","runtimePreview":"LSlider_Advanced_Step_4.png"}],"anchor":"Implementing-makeTickMark","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Tick marks should react to the thumb’s proximity — growing and brightening as","type":"text"},{"text":" ","type":"text"},{"text":"the thumb approaches.  ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderConfiguration"},{"text":" provides ","type":"text"},{"type":"codeVoice","code":"value"},{"text":", ","type":"text"},{"type":"codeVoice","code":"min"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"max"},{"text":" so you can compute a normalised distance.","type":"text"}]}],"kind":"contentAndMedia","media":"LSlider_Advanced_Step_4.png","mediaPosition":"trailing"}],"title":"Implementing makeTickMark"},{"title":"Implementing makeLabel","contentSection":[{"kind":"contentAndMedia","media":"LSlider_Advanced_Step_5.png","mediaPosition":"trailing","content":[{"inlineContent":[{"type":"text","text":"The floating label container wraps the caller-provided content view.  Override"},{"type":"text","text":" "},{"code":"makeLabel","type":"codeVoice"},{"type":"text","text":" to brand it with the same indigo palette and give it a spring"},{"type":"text","text":" "},{"type":"text","text":"entrance\/exit animation tied to "},{"type":"codeVoice","code":"isActive"},{"type":"text","text":"."}],"type":"paragraph"}]}],"stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement "},{"type":"codeVoice","code":"makeLabel(configuration:content:)"},{"type":"text","text":".  Wrap the "},{"type":"codeVoice","code":"content"},{"type":"text","text":" view in"},{"type":"text","text":" "},{"type":"text","text":"horizontal and vertical padding, then apply a "},{"type":"codeVoice","code":"RoundedRectangle"},{"text":" background","type":"text"},{"text":" ","type":"text"},{"text":"filled with indigo and a drop shadow.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Drive ","type":"text"},{"type":"codeVoice","code":"scaleEffect"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"opacity"},{"text":" from ","type":"text"},{"type":"codeVoice","code":"configuration.isActive"},{"type":"text","text":" — the label"},{"type":"text","text":" "},{"type":"text","text":"springs in when the user starts dragging and fades away when they lift their"},{"type":"text","text":" "},{"type":"text","text":"finger."}]}],"media":null,"code":"LSlider_Advanced_Step_5.swift","runtimePreview":"LSlider_Advanced_Step_5.png","type":"step"}],"anchor":"Implementing-makeLabel"},{"title":"Applying the Finished Style","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","media":"LSlider_Advanced_Step_6.png","content":[{"inlineContent":[{"type":"text","text":"With all four methods complete, apply "},{"code":"MyLSliderStyle","type":"codeVoice"},{"type":"text","text":" to a range of sliders —"},{"text":" ","type":"text"},{"type":"text","text":"horizontal, diagonal, with tick marks and affinity — to confirm everything works"},{"text":" ","type":"text"},{"text":"together.","type":"text"}],"type":"paragraph"}]}],"anchor":"Applying-the-Finished-Style","stepsSection":[{"media":null,"runtimePreview":"LSlider_Advanced_Step_6.png","type":"step","content":[{"inlineContent":[{"text":"Apply ","type":"text"},{"type":"codeVoice","code":".linearSliderStyle(MyLSliderStyle())"},{"type":"text","text":" to both a horizontal slider"},{"text":" ","type":"text"},{"type":"text","text":"(with tick marks and affinity) and a diagonal slider.  The style adapts"},{"type":"text","text":" "},{"type":"text","text":"automatically to any angle and thickness thanks to "},{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine","type":"reference"},{"type":"text","text":"."}],"type":"paragraph"}],"code":"LSlider_Advanced_Step_6.swift","caption":[]}]}],"kind":"tasks"}],"identifier":{"url":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced","interfaceLanguage":"swift"},"references":{"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Implementing-makeThumb":{"type":"section","title":"Implementing makeThumb","role":"pseudoSymbol","url":"\/tutorials\/sliders\/lslider-advanced#Implementing-makeThumb","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeThumb","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","type":"reference","isActive":true},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"text":"In this tutorial you’ll build ","type":"text"},{"code":"MyLSliderStyle","type":"codeVoice"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"kind":"section"},"LSlider_Advanced_Step_1.swift":{"type":"file","fileType":"swift","highlights":[],"content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            .fill(Color.gray.opacity(0.4))","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(width: 4, height: 4)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        LSlider($value, range: 0...1, keepThumbInTrack: true, trackThickness: 20)","            .linearSliderStyle(MyLSliderStyle())","            .frame(height: 60)","            .padding()","    }","}"],"identifier":"LSlider_Advanced_Step_1.swift","fileName":"MyLSliderStyle.swift","syntax":"swift"},"LSlider_Advanced_Step_5.swift":{"syntax":"swift","fileType":"swift","highlights":[],"content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled","            ? Color.gray","            : (configuration.isActive ? Color.white : Color.indigo)","        return Circle()","            .fill(color)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","            .shadow(","                color: .black.opacity(configuration.isDisabled ? 0 : 0.2),","                radius: configuration.isActive ? 6 : 2","            )","            .animation(.easeOut(duration: 0.12), value: configuration.isActive)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let distance  = abs(thumbPct - tickPct)","        let proximity = max(0, 1 - distance \/ 0.15)","","        let size    = 5.0 + 7.0 * proximity","        let opacity = 0.3 + 0.7 * proximity","","        return Circle()","            .fill(Color.indigo.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","","    func makeLabel(configuration: LSliderConfiguration, content: AnyView) -> some View {","        content","            .padding(.horizontal, 10)","            .padding(.vertical, 5)","            .background(","                RoundedRectangle(cornerRadius: 8)","                    .fill(Color.indigo)","                    .shadow(color: .black.opacity(0.25), radius: 4, y: 2)","            )","            .foregroundStyle(.white)","            .scaleEffect(configuration.isActive ? 1.0 : 0.75)","            .opacity(configuration.isActive ? 1.0 : 0.0)","            .animation(.spring(response: 0.3, dampingFraction: 0.7), value: configuration.isActive)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        LSlider(","            $value,","            range: 0...1,","            keepThumbInTrack: true,","            trackThickness: 20,","            tickMarkSpacing: .count(11)","        )","        .linearSliderStyle(MyLSliderStyle())","        .frame(height: 80)","        .padding()","    }","}"],"identifier":"LSlider_Advanced_Step_5.swift","fileName":"MyLSliderStyle.swift","type":"file"},"doc://Sliders/tutorials/LSlider-Tutorials":{"url":"\/tutorials\/lslider-tutorials","role":"overview","kind":"overview","abstract":[{"text":"Learn how to add a spatially adaptive linear slider to your app — starting with the","type":"text"},{"text":" ","type":"text"},{"text":"built-in default style and its full range of configuration options, then advancing to","type":"text"},{"text":" ","type":"text"},{"text":"building a completely custom style from scratch.","type":"text"}],"identifier":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials","title":"Building Sliders with LSlider","type":"topic"},"doc://Sliders/documentation/Sliders/LSliderConfiguration":{"url":"\/documentation\/sliders\/lsliderconfiguration","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderConfiguration","role":"symbol","title":"LSliderConfiguration","abstract":[{"type":"text","text":"A value type describing the current state of an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"type":"text","text":"."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LSliderConfiguration","kind":"identifier"}],"type":"topic","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"LSliderConfiguration"}]},"LSlider_Advanced_Step_6.swift":{"fileName":"ContentView.swift","content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled","            ? Color.gray","            : (configuration.isActive ? Color.white : Color.indigo)","        return Circle()","            .fill(color)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","            .shadow(","                color: .black.opacity(configuration.isDisabled ? 0 : 0.2),","                radius: configuration.isActive ? 6 : 2","            )","            .animation(.easeOut(duration: 0.12), value: configuration.isActive)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let distance  = abs(thumbPct - tickPct)","        let proximity = max(0, 1 - distance \/ 0.15)","","        let size    = 5.0 + 7.0 * proximity","        let opacity = 0.3 + 0.7 * proximity","","        return Circle()","            .fill(Color.indigo.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","","    func makeLabel(configuration: LSliderConfiguration, content: AnyView) -> some View {","        content","            .padding(.horizontal, 10)","            .padding(.vertical, 5)","            .background(","                RoundedRectangle(cornerRadius: 8)","                    .fill(Color.indigo)","                    .shadow(color: .black.opacity(0.25), radius: 4, y: 2)","            )","            .foregroundStyle(.white)","            .scaleEffect(configuration.isActive ? 1.0 : 0.75)","            .opacity(configuration.isActive ? 1.0 : 0.0)","            .animation(.spring(response: 0.3, dampingFraction: 0.7), value: configuration.isActive)","    }","}","","struct ContentView: View {","    @State private var value1 = 0.5","    @State private var value2 = 0.5","","    var body: some View {","        VStack(spacing: 20) {","            LSlider(","                $value1,","                range: 0...1,","                keepThumbInTrack: true,","                trackThickness: 20,","                tickMarkSpacing: .count(11),","                affinityEnabled: true","            )","            .linearSliderStyle(MyLSliderStyle())","            .frame(height: 80)","","            LSlider(","                $value2,","                range: 0...1,","                angle: Angle(degrees: 315),","                keepThumbInTrack: true,","                trackThickness: 20,","                tickMarkSpacing: .count(5),","                affinityEnabled: true","            )","            .linearSliderStyle(MyLSliderStyle())","            .frame(width: 200, height: 200)","        }","        .padding()","    }","}"],"identifier":"LSlider_Advanced_Step_6.swift","type":"file","syntax":"swift","highlights":[],"fileType":"swift"},"doc://Sliders/documentation/Sliders/LSlider":{"url":"\/documentation\/sliders\/lslider","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"LSlider","kind":"identifier"}],"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"A fully stylable linear slider that can be placed at any angle.  Tick marks can be"},{"text":" ","type":"text"},{"type":"text","text":"added via the "},{"type":"codeVoice","code":"tickMarkSpacing"},{"type":"text","text":" parameter and will optionally play haptic feedback"},{"type":"text","text":" "},{"type":"text","text":"when the thumb passes over them."}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","title":"LSlider","type":"topic","navigatorTitle":[{"text":"LSlider","kind":"identifier"}]},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Implementing-makeTickMark":{"type":"section","title":"Implementing makeTickMark","role":"pseudoSymbol","url":"\/tutorials\/sliders\/lslider-advanced#Implementing-makeTickMark","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTickMark","abstract":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","isActive":true},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll build "},{"code":"MyLSliderStyle","type":"codeVoice"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"kind":"section"},"doc://Sliders/tutorials/Sliders/LSlider-Basics#Affinity-Snapping":{"role":"pseudoSymbol","title":"Affinity Snapping","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"text":" is a fully stylable linear slider that can be placed at any angle.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll explore every configuration option the default style offers —","type":"text"},{"type":"text","text":" "},{"text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"custom labels."}],"url":"\/tutorials\/sliders\/lslider-basics#Affinity-Snapping","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Affinity-Snapping","type":"section","kind":"section"},"doc://Sliders/tutorials/LSlider-Tutorials/Creating-a-Custom-Style":{"url":"\/tuto