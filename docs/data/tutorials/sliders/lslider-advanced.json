ion.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(width: 4, height: 4)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        VStack(spacing: 20) {","            LSlider($value, range: 0...1, keepThumbInTrack: true, trackThickness: 20)","                .linearSliderStyle(MyLSliderStyle())","                .frame(height: 60)","            LSlider($value, range: 0...1, keepThumbInTrack: true, trackThickness: 20)","                .linearSliderStyle(MyLSliderStyle())","                .disabled(true)","                .frame(height: 60)","        }","        .padding()","    }","}"],"syntax":"swift","type":"file"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced":{"abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll build "},{"type":"codeVoice","code":"MyLSliderStyle"},{"type":"text","text":" from scratch — implementing each"},{"type":"text","text":" "},{"type":"text","text":"protocol method one at a time — and applying the finished style to both horizontal"},{"type":"text","text":" "},{"type":"text","text":"and diagonal sliders."}],"estimatedTime":"20min","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced","role":"project","type":"topic","url":"\/tutorials\/sliders\/lslider-advanced","title":"Building a Custom LSlider Style","kind":"project"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Applying-the-Finished-Style":{"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Applying-the-Finished-Style","kind":"section","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"text":" lets you take full control of every visual element of the slider.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll build ","type":"text"},{"code":"MyLSliderStyle","type":"codeVoice"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"role":"pseudoSymbol","title":"Applying the Finished Style","url":"\/tutorials\/sliders\/lslider-advanced#Applying-the-Finished-Style","type":"section"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Declaring-the-Style":{"abstract":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","isActive":true},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll build "},{"type":"codeVoice","code":"MyLSliderStyle"},{"type":"text","text":" from scratch — implementing each"},{"type":"text","text":" "},{"type":"text","text":"protocol method one at a time — and applying the finished style to both horizontal"},{"type":"text","text":" "},{"type":"text","text":"and diagonal sliders."}],"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Declaring-the-Style","role":"pseudoSymbol","type":"section","url":"\/tutorials\/sliders\/lslider-advanced#Declaring-the-Style","title":"Declaring the Style","kind":"section"},"doc://Sliders/documentation/Sliders/AdaptiveLine":{"url":"\/documentation\/sliders\/adaptiveline","abstract":[],"navigatorTitle":[{"text":"AdaptiveLine","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine","type":"topic","title":"AdaptiveLine","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"AdaptiveLine","kind":"identifier"}],"role":"symbol"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Implementing-makeThumb":{"kind":"section","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","type":"reference","isActive":true},{"text":" lets you take full control of every visual element of the slider.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll build ","type":"text"},{"type":"codeVoice","code":"MyLSliderStyle"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeThumb","role":"pseudoSymbol","title":"Implementing makeThumb","url":"\/tutorials\/sliders\/lslider-advanced#Implementing-makeThumb","type":"section"},"LSlider_Advanced_Step_5.swift":{"identifier":"LSlider_Advanced_Step_5.swift","type":"file","content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled","            ? Color.gray","            : (configuration.isActive ? Color.white : Color.indigo)","        return Circle()","            .fill(color)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","            .shadow(","                color: .black.opacity(configuration.isDisabled ? 0 : 0.2),","                radius: configuration.isActive ? 6 : 2","            )","            .animation(.easeOut(duration: 0.12), value: configuration.isActive)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let distance  = abs(thumbPct - tickPct)","        let proximity = max(0, 1 - distance \/ 0.15)","","        let size    = 5.0 + 7.0 * proximity","        let opacity = 0.3 + 0.7 * proximity","","        return Circle()","            .fill(Color.indigo.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","","    func makeLabel(configuration: LSliderConfiguration, content: AnyView) -> some View {","        content","            .padding(.horizontal, 10)","            .padding(.vertical, 5)","            .background(","                RoundedRectangle(cornerRadius: 8)","                    .fill(Color.indigo)","                    .shadow(color: .black.opacity(0.25), radius: 4, y: 2)","            )","            .foregroundStyle(.white)","            .scaleEffect(configuration.isActive ? 1.0 : 0.75)","            .opacity(configuration.isActive ? 1.0 : 0.0)","            .animation(.spring(response: 0.3, dampingFraction: 0.7), value: configuration.isActive)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        LSlider(","            $value,","            range: 0...1,","            keepThumbInTrack: true,","            trackThickness: 20,","            tickMarkSpacing: .count(11)","        )","        .linearSliderStyle(MyLSliderStyle())","        .frame(height: 80)","        .padding()","    }","}"],"fileName":"MyLSliderStyle.swift","syntax":"swift","fileType":"swift","highlights":[]},"LSlider_Advanced_Step_6.swift":{"identifier":"LSlider_Advanced_Step_6.swift","fileName":"ContentView.swift","fileType":"swift","highlights":[],"content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled","            ? Color.gray","            : (configuration.isActive ? Color.white : Color.indigo)","        return Circle()","            .fill(color)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","            .shadow(","                color: .black.opacity(configuration.isDisabled ? 0 : 0.2),","                radius: configuration.isActive ? 6 : 2","            )","            .animation(.easeOut(duration: 0.12), value: configuration.isActive)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let distance  = abs(thumbPct - tickPct)","        let proximity = max(0, 1 - distance \/ 0.15)","","        let size    = 5.0 + 7.0 * proximity","        let opacity = 0.3 + 0.7 * proximity","","        return Circle()","            .fill(Color.indigo.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","","    func makeLabel(configuration: LSliderConfiguration, content: AnyView) -> some View {","        content","            .padding(.horizontal, 10)","            .padding(.vertical, 5)","            .background(","                RoundedRectangle(cornerRadius: 8)","                    .fill(Color.indigo)","                    .shadow(color: .black.opacity(0.25), radius: 4, y: 2)","            )","            .foregroundStyle(.white)","            .scaleEffect(configuration.isActive ? 1.0 : 0.75)","            .opacity(configuration.isActive ? 1.0 : 0.0)","            .animation(.spring(response: 0.3, dampingFraction: 0.7), value: configuration.isActive)","    }","}","","struct ContentView: View {","    @State private var value1 = 0.5","    @State private var value2 = 0.5","","    var body: some View {","        VStack(spacing: 20) {","            LSlider(","                $value1,","                range: 0...1,","                keepThumbInTrack: true,","                trackThickness: 20,","                tickMarkSpacing: .count(11),","                affinityEnabled: true","            )","            .linearSliderStyle(MyLSliderStyle())","            .frame(height: 80)","","            LSlider(","                $value2,","                range: 0...1,","                angle: Angle(degrees: 315),","                keepThumbInTrack: true,","                trackThickness: 20,","                tickMarkSpacing: .count(5),","                affinityEnabled: true","            )","            .linearSliderStyle(MyLSliderStyle())","            .frame(width: 200, height: 200)","        }","        .padding()","    }","}"],"syntax":"swift","type":"file"},"doc://Sliders/tutorials/Sliders/LSlider-Basics#Basic-Usage":{"abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"type":"text","text":" is a fully stylable linear slider that can be placed at any angle."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore every configuration option the default style offers —"},{"type":"text","text":" "},{"type":"text","text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with"},{"type":"text","text":" "},{"type":"text","text":"custom labels."}],"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Basic-Usage","role":"pseudoSymbol","type":"section","url":"\/tutorials\/sliders\/lslider-basics#Basic-Usage","title":"Bas