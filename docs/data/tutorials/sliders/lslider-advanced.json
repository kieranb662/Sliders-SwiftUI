   .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            .fill(Color.gray.opacity(0.4))","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(width: 4, height: 4)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        LSlider($value, range: 0...1, keepThumbInTrack: true, trackThickness: 20)","            .linearSliderStyle(MyLSliderStyle())","            .frame(height: 60)","            .padding()","    }","}"],"syntax":"swift","fileType":"swift","identifier":"LSlider_Advanced_Step_1.swift","type":"file","fileName":"MyLSliderStyle.swift"},"doc://Sliders/documentation/Sliders/AdaptiveLine":{"kind":"symbol","abstract":[],"navigatorTitle":[{"kind":"identifier","text":"AdaptiveLine"}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine","title":"AdaptiveLine","url":"\/documentation\/sliders\/adaptiveline","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AdaptiveLine"}],"type":"topic"},"doc://Sliders/tutorials/Sliders/LSlider-Basics#Affinity-Snapping":{"url":"\/tutorials\/sliders\/lslider-basics#Affinity-Snapping","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"type":"text","text":" is a fully stylable linear slider that can be placed at any angle."},{"text":" ","type":"text"},{"text":"In this tutorial you’ll explore every configuration option the default style offers —","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with"},{"type":"text","text":" "},{"type":"text","text":"custom labels."}],"type":"section","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Affinity-Snapping","title":"Affinity Snapping","role":"pseudoSymbol","kind":"section"},"doc://Sliders/tutorials/Sliders/LSlider-Basics#Tick-Marks":{"abstract":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true},{"type":"text","text":" is a fully stylable linear slider that can be placed at any angle."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore every configuration option the default style offers —"},{"type":"text","text":" "},{"type":"text","text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with"},{"type":"text","text":" "},{"type":"text","text":"custom labels."}],"type":"section","url":"\/tutorials\/sliders\/lslider-basics#Tick-Marks","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Tick-Marks","title":"Tick Marks","role":"pseudoSymbol","kind":"section"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Implementing-makeTrack":{"url":"\/tutorials\/sliders\/lslider-advanced#Implementing-makeTrack","abstract":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","isActive":true},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"text":" ","type":"text"},{"text":"In this tutorial you’ll build ","type":"text"},{"type":"codeVoice","code":"MyLSliderStyle"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"type":"section","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTrack","title":"Implementing makeTrack","role":"pseudoSymbol","kind":"section"},"doc://Sliders/documentation/Sliders/LSliderConfiguration":{"navigatorTitle":[{"kind":"identifier","text":"LSliderConfiguration"}],"abstract":[{"type":"text","text":"A value type describing the current state of an "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true},{"type":"text","text":"."}],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"LSliderConfiguration","kind":"identifier"}],"title":"LSliderConfiguration","role":"symbol","type":"topic","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderConfiguration","url":"\/documentation\/sliders\/lsliderconfiguration"},"LSlider_Advanced_Step_1.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/LSlider_Advanced_Step_1.png"}],"alt":"Gray stub slider confirming the style is wired up","type":"image","identifier":"LSlider_Advanced_Step_1.png"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Implementing-makeTickMark":{"title":"Implementing makeTickMark","kind":"section","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTickMark","url":"\/tutorials\/sliders\/lslider-advanced#Implementing-makeTickMark","role":"pseudoSymbol","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll build "},{"code":"MyLSliderStyle","type":"codeVoice"},{"type":"text","text":" from scratch — implementing each"},{"type":"text","text":" "},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"type":"section"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Implementing-makeThumb":{"abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll build "},{"type":"codeVoice","code":"MyLSliderStyle"},{"type":"text","text":" from scratch — implementing each"},{"type":"text","text":" "},{"type":"text","text":"protocol method one at a time — and applying the finished style to both horizontal"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"role":"pseudoSymbol","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeThumb","title":"Implementing makeThumb","url":"\/tutorials\/sliders\/lslider-advanced#Implementing-makeThumb","type":"section","kind":"section"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced":{"abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll build "},{"type":"codeVoice","code":"MyLSliderStyle"},{"type":"text","text":" from scratch — implementing each"},{"type":"text","text":" "},{"type":"text","text":"protocol method one at a time — and applying the finished style to both horizontal"},{"type":"text","text":" "},{"type":"text","text":"and diagonal sliders."}],"role":"project","title":"Building a Custom LSlider Style","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced","url":"\/tutorials\/sliders\/lslider-advanced","estimatedTime":"20min","type":"topic","kind":"project"},"LSlider_Advanced_Step_6.swift":{"fileType":"swift","highlights":[],"identifier":"LSlider_Advanced_Step_6.swift","content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled","            ? Color.gray","            : (configuration.isActive ? Color.white : Color.indigo)","        return Circle()","            .fill(color)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","            .shadow(","                color: .black.opacity(configuration.isDisabled ? 0 : 0.2),","                radius: configuration.isActive ? 6 : 2","            )","            .animation(.easeOut(duration: 0.12), value: configuration.isActive)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let distance  = abs(thumbPct - tickPct)","        let proximity = max(0, 1 - distance \/ 0.15)","","        let size    = 5.0 + 7.0 * proximity","        let opacity = 0.3 + 0.7 * proximity","","        return Circle()","            .fill(Color.indigo.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","","    func makeLabel(configuration: LSliderConfiguration, content: AnyView) -> some View {","        content","            .padding(.horizontal, 10)","            .padding(.vertical, 5)","            .background(","                RoundedRectangle(cornerRadius: 8)","                    .fill(Color.indigo)","                    .shadow(color: .black.opacity(0.25), radius: 4, y: 2)","            )","            .foregroundStyle(.white)","            .scaleEffect(configuration.isActive ? 1.0 : 0.75)","            .opacity(configuration.isActive ? 1.0 : 0.0)","            .animation(.spring(response: 0.3, dampingFraction: 0.7), value: configuration.isActive)","    }","}","","struct ContentView: View {","    @State private var value1 = 0.5","    @State private var value2 = 0.5","","    var body: some View {","        VStack(spacing: 20) {","            LSlider(","                $value1,","                range: 0...1,","                keepThumbInTrack: true,","                trackThickness: 20,","                tickMarkSpacing: .count(11),","                affinityEnabled: true","            )","            .linearSliderStyle(MyLSliderStyle())","            .frame(height: 80)","","            LSlider(","                $value2,","                range: 0...1,","                angle: Angle(degrees: 315),","                keepThumbInTrack: true,","                trackThickness: 20,","                tickMarkSpacing: .count(5),","                affinityEnabled: true","            )","            .linearSliderStyle(MyLSliderStyle())","            .frame(width: 200, height: 200)","        }","        .padding()","    }","}"],"syntax":"swift","fileName":"ContentView.swift","type":"file"},"LSlider_Advanced_Step_2.sw