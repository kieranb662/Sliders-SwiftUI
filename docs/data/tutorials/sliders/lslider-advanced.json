trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(width: 4, height: 4)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        LSlider($value, range: 0...1, keepThumbInTrack: true, trackThickness: 20)","            .linearSliderStyle(MyLSliderStyle())","            .frame(height: 60)","            .padding()","    }","}"],"fileType":"swift"},"doc://Sliders/tutorials/LSlider-Tutorials":{"kind":"overview","type":"topic","title":"Building Sliders with LSlider","role":"overview","url":"\/tutorials\/lslider-tutorials","identifier":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials","abstract":[{"type":"text","text":"Learn how to add a spatially adaptive linear slider to your app — starting with the"},{"type":"text","text":" "},{"type":"text","text":"built-in default style and its full range of configuration options, then advancing to"},{"type":"text","text":" "},{"type":"text","text":"building a completely custom style from scratch."}]},"doc://Sliders/tutorials/Sliders/LSlider-Advanced":{"abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","type":"reference","isActive":true},{"text":" lets you take full control of every visual element of the slider.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll build ","type":"text"},{"code":"MyLSliderStyle","type":"codeVoice"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"role":"project","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced","kind":"project","title":"Building a Custom LSlider Style","estimatedTime":"20min","type":"topic","url":"\/tutorials\/sliders\/lslider-advanced"},"LSlider_Advanced_Step_3.swift":{"fileType":"swift","type":"file","identifier":"LSlider_Advanced_Step_3.swift","highlights":[],"syntax":"swift","content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled","            ? Color.gray","            : (configuration.isActive ? Color.white : Color.indigo)","        return Circle()","            .fill(color)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","            .shadow(","                color: .black.opacity(configuration.isDisabled ? 0 : 0.2),","                radius: configuration.isActive ? 6 : 2","            )","            .animation(.easeOut(duration: 0.12), value: configuration.isActive)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(width: 4, height: 4)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        VStack(spacing: 20) {","            LSlider($value, range: 0...1, keepThumbInTrack: true, trackThickness: 20)","                .linearSliderStyle(MyLSliderStyle())","                .frame(height: 60)","            LSlider($value, range: 0...1, keepThumbInTrack: true, trackThickness: 20)","                .linearSliderStyle(MyLSliderStyle())","                .disabled(true)","                .frame(height: 60)","        }","        .padding()","    }","}"],"fileName":"MyLSliderStyle.swift"},"LSlider_Advanced_Step_6.swift":{"fileName":"ContentView.swift","highlights":[],"type":"file","identifier":"LSlider_Advanced_Step_6.swift","content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled","            ? Color.gray","            : (configuration.isActive ? Color.white : Color.indigo)","        return Circle()","            .fill(color)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","            .shadow(","                color: .black.opacity(configuration.isDisabled ? 0 : 0.2),","                radius: configuration.isActive ? 6 : 2","            )","            .animation(.easeOut(duration: 0.12), value: configuration.isActive)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let distance  = abs(thumbPct - tickPct)","        let proximity = max(0, 1 - distance \/ 0.15)","","        let size    = 5.0 + 7.0 * proximity","        let opacity = 0.3 + 0.7 * proximity","","        return Circle()","            .fill(Color.indigo.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","","    func makeLabel(configuration: LSliderConfiguration, content: AnyView) -> some View {","        content","            .padding(.horizontal, 10)","            .padding(.vertical, 5)","            .background(","                RoundedRectangle(cornerRadius: 8)","                    .fill(Color.indigo)","                    .shadow(color: .black.opacity(0.25), radius: 4, y: 2)","            )","            .foregroundStyle(.white)","            .scaleEffect(configuration.isActive ? 1.0 : 0.75)","            .opacity(configuration.isActive ? 1.0 : 0.0)","            .animation(.spring(response: 0.3, dampingFraction: 0.7), value: configuration.isActive)","    }","}","","struct ContentView: View {","    @State private var value1 = 0.5","    @State private var value2 = 0.5","","    var body: some View {","        VStack(spacing: 20) {","            LSlider(","                $value1,","                range: 0...1,","                keepThumbInTrack: true,","                trackThickness: 20,","                tickMarkSpacing: .count(11),","                affinityEnabled: true","            )","            .linearSliderStyle(MyLSliderStyle())","            .frame(height: 80)","","            LSlider(","                $value2,","                range: 0...1,","                angle: Angle(degrees: 315),","                keepThumbInTrack: true,","                trackThickness: 20,","                tickMarkSpacing: .count(5),","                affinityEnabled: true","            )","            .linearSliderStyle(MyLSliderStyle())","            .frame(width: 200, height: 200)","        }","        .padding()","    }","}"],"fileType":"swift","syntax":"swift"},"LSlider_Advanced_Step_4.swift":{"identifier":"LSlider_Advanced_Step_4.swift","syntax":"swift","fileType":"swift","highlights":[],"content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled","            ? Color.gray","            : (configuration.isActive ? Color.white : Color.indigo)","        return Circle()","            .fill(color)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","            .shadow(","                color: .black.opacity(configuration.isDisabled ? 0 : 0.2),","                radius: configuration.isActive ? 6 : 2","            )","            .animation(.easeOut(duration: 0.12), value: configuration.isActive)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let distance  = abs(thumbPct - tickPct)","        let proximity = max(0, 1 - distance \/ 0.15)","","        let size    = 5.0 + 7.0 * proximity","        let opacity = 0.3 + 0.7 * proximity","","        return Circle()","            .fill(Color.indigo.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        VStack(spacing: 8) {","            LSlider(","                $value,","                range: 0...1,","                keepThumbInTrack: true,","                trackThickness: 20,","                tickMarkSpacing: .count(11)","            )","            .linearSliderStyle(MyLSliderStyle())","            .frame(height: 60)","            Text(\"Value: \\(value, specifier: \"%.2f\")\")","                .font(.caption)","        }","        .padding()","    }","}"],"type":"file","fileName":"MyLSliderStyle.swift"},"doc://Sliders/tutorials/Sliders/LSlider-Basics#Tick-Marks":{"abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"type":"text","text":" is a fully stylable linear slider that can be placed at any angle."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore every configuration option the default style offers —"},{"type":"text","text":" "},{"type":"text","text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with"},{"type":"text","text":" "},{"type":"text","text":"custom labels."}],"url":"\/tutorials\/sliders\/lslider-basics#Tick-Marks","title":"Tick Marks","role":"pseudoSymbol","type":"section","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Tick-Marks","kind":"section"},"LSlider_Advanced_Step_4.png":{"alt":"Indigo circles growing as the thumb passes over them","variants":[{"url":"\/images\/Sliders\/LSlider_Advanced_Step_4.png","traits":["1x","light"]}],"type":"image","identifier":"LSlider_Advanced_Step_4.png"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Applying-the-Finished-Style":{"kind":"section","title":"Applying the Finished Style","type":"section","url":"\/tutorials\/sliders\/lslider-advanced#Applying-the-Finished-Style","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"text":" lets you take full contro