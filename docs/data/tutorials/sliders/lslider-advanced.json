onent":"LSlider-Tutorials","title":"Building a Custom LSlider Style","role":"project"},"sections":[{"estimatedTimeInMinutes":20,"chapter":"Creating a Custom Style","kind":"hero","title":"Building a Custom LSlider Style","backgroundImage":"LSlider_Advanced_Step_6.png","image":"LSlider_Advanced_Step_6.png","content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll build "},{"type":"codeVoice","code":"MyLSliderStyle"},{"type":"text","text":" from scratch — implementing each"},{"type":"text","text":" "},{"type":"text","text":"protocol method one at a time — and applying the finished style to both horizontal"},{"type":"text","text":" "},{"text":"and diagonal sliders.","type":"text"}],"type":"paragraph"}]},{"tasks":[{"anchor":"Declaring-the-Style","contentSection":[{"mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"text":"Start by creating a struct that conforms to ","type":"text"},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","isActive":true},{"type":"text","text":".  The protocol"},{"text":" ","type":"text"},{"text":"requires four methods; you’ll add stub implementations first to make the code","type":"text"},{"type":"text","text":" "},{"text":"compile, then flesh each one out in the following sections.","type":"text"}]}],"media":"LSlider_Advanced_Step_1.png","kind":"contentAndMedia"}],"title":"Declaring the Style","stepsSection":[{"caption":[{"type":"paragraph","inlineContent":[{"text":"Apply the style with ","type":"text"},{"code":".linearSliderStyle(MyLSliderStyle())","type":"codeVoice"},{"text":" to see it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"immediately in the preview."}]}],"runtimePreview":"LSlider_Advanced_Step_1.png","code":"LSlider_Advanced_Step_1.swift","type":"step","content":[{"inlineContent":[{"type":"text","text":"Create a new Swift file and declare "},{"type":"codeVoice","code":"MyLSliderStyle"},{"type":"text","text":" as a "},{"code":"struct","type":"codeVoice"},{"type":"text","text":" that"},{"text":" ","type":"text"},{"text":"conforms to ","type":"text"},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","isActive":true,"type":"reference"},{"text":".  Provide placeholder bodies for all four","type":"text"},{"text":" ","type":"text"},{"text":"required methods — ","type":"text"},{"code":"makeThumb","type":"codeVoice"},{"text":", ","type":"text"},{"code":"makeTrack","type":"codeVoice"},{"text":", ","type":"text"},{"code":"makeTickMark","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"makeLabel"},{"text":" — so the project compiles while you iterate.","type":"text"}],"type":"paragraph"}],"media":null}]},{"contentSection":[{"mediaPosition":"trailing","content":[{"inlineContent":[{"text":"The track is the backbone of the slider.  It consists of two layered","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine","type":"reference","isActive":true},{"type":"text","text":" shapes: a dim background and a filled foreground that"},{"type":"text","text":" "},{"text":"grows with ","type":"text"},{"type":"codeVoice","code":"pctFill"},{"type":"text","text":"."}],"type":"paragraph"}],"media":"LSlider_Advanced_Step_2.png","kind":"contentAndMedia"}],"stepsSection":[{"code":"LSlider_Advanced_Step_2.swift","caption":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"configuration.pctFill"},{"type":"text","text":" for the fill percentage and"},{"type":"text","text":" "},{"code":"configuration.keepThumbInTrack","type":"codeVoice"},{"type":"text","text":" to compute the correct "},{"type":"codeVoice","code":"adjustmentForThumb"},{"type":"text","text":" "},{"type":"text","text":"so the fill always ends under the thumb’s centre."}]}],"media":null,"runtimePreview":"LSlider_Advanced_Step_2.png","type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Replace the stub ","type":"text"},{"code":"makeTrack","type":"codeVoice"},{"type":"text","text":" body.  Layer two "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine"},{"type":"text","text":" shapes in a"},{"type":"text","text":" "},{"type":"codeVoice","code":"ZStack"},{"text":": one as the empty background and one as the filled foreground.","type":"text"},{"type":"text","text":" "},{"text":"Mask the filled portion so it stays within the capsule.","type":"text"}]}]}],"title":"Implementing makeTrack","anchor":"Implementing-makeTrack"},{"anchor":"Implementing-makeThumb","title":"Implementing makeThumb","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"The thumb needs to communicate three states visually: normal, active (while","type":"text"},{"text":" ","type":"text"},{"text":"dragging), and disabled.  Use ","type":"text"},{"code":"configuration.isActive","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"configuration.isDisabled","type":"codeVoice"},{"text":" to drive color and shadow changes.","type":"text"}]}],"media":"LSlider_Advanced_Step_3.png","mediaPosition":"trailing"}],"stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Replace the stub ","type":"text"},{"code":"makeThumb","type":"codeVoice"},{"text":" body.  Size the ","type":"text"},{"code":"Circle","type":"codeVoice"},{"text":" from","type":"text"},{"text":" ","type":"text"},{"code":"configuration.trackThickness","type":"codeVoice"},{"type":"text","text":" (double it for a standard thumb diameter)."}]}],"code":"LSlider_Advanced_Step_3.swift","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pick the fill color based on "},{"type":"codeVoice","code":"isDisabled"},{"type":"text","text":" → "},{"type":"codeVoice","code":"isActive"},{"type":"text","text":", and add a shadow"},{"type":"text","text":" "},{"type":"text","text":"whose radius expands when the thumb is active to give a lifted feel.  Wrap"},{"text":" ","type":"text"},{"type":"text","text":"the color and shadow in an "},{"type":"codeVoice","code":".animation"},{"type":"text","text":" so the transition is smooth."}]}],"media":null,"type":"step","runtimePreview":"LSlider_Advanced_Step_3.png"}]},{"title":"Implementing makeTickMark","anchor":"Implementing-makeTickMark","stepsSection":[{"type":"step","media":null,"caption":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"proximity"},{"type":"text","text":" to interpolate both the circle’s "},{"type":"codeVoice","code":"size"},{"text":" and its ","type":"text"},{"type":"codeVoice","code":"opacity"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and wrap the result in "},{"type":"codeVoice","code":".animation(.easeOut)"},{"text":" so it feels responsive.","type":"text"}],"type":"paragraph"}],"code":"LSlider_Advanced_Step_4.swift","runtimePreview":"LSlider_Advanced_Step_4.png","content":[{"inlineContent":[{"type":"text","text":"Replace the stub "},{"type":"codeVoice","code":"makeTickMark"},{"type":"text","text":" body.  Compute the normalised positions of"},{"type":"text","text":" "},{"text":"the thumb (","type":"text"},{"code":"thumbPct","type":"codeVoice"},{"text":") and the tick mark (","type":"text"},{"code":"tickPct","type":"codeVoice"},{"text":") in the ","type":"text"},{"code":"0…1","type":"codeVoice"},{"type":"text","text":" space,"},{"type":"text","text":" "},{"text":"then derive a ","type":"text"},{"type":"codeVoice","code":"proximity"},{"type":"text","text":" value between "},{"code":"0","type":"codeVoice"},{"text":" (far) and ","type":"text"},{"code":"1","type":"codeVoice"},{"type":"text","text":" (on top)."}],"type":"paragraph"}]}],"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"text":"Tick marks should react to the thumb’s proximity — growing and brightening as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the thumb approaches.  "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderConfiguration"},{"type":"text","text":" provides "},{"code":"value","type":"codeVoice"},{"text":", ","type":"text"},{"code":"min","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"max"},{"text":" so you can compute a normalised distance.","type":"text"}]}],"media":"LSlider_Advanced_Step_4.png"}]},{"anchor":"Implementing-makeLabel","title":"Implementing makeLabel","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","media":"LSlider_Advanced_Step_5.png","content":[{"type":"paragraph","inlineContent":[{"text":"The floating label container wraps the caller-provided content view.  Override","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"makeLabel"},{"text":" to brand it with the same indigo palette and give it a spring","type":"text"},{"text":" ","type":"text"},{"text":"entrance\/exit animation tied to ","type":"text"},{"type":"codeVoice","code":"isActive"},{"text":".","type":"text"}]}]}],"stepsSection":[{"code":"LSlider_Advanced_Step_5.swift","runtimePreview":"LSlider_Advanced_Step_5.png","media":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement "},{"type":"codeVoice","code":"makeLabel(configuration:content:)"},{"type":"text","text":".  Wrap the "},{"type":"codeVoice","code":"content"},{"type":"text","text":" view in"},{"type":"text","text":" "},{"type":"text","text":"horizontal and vertical padding, then apply a "},{"type":"codeVoice","code":"RoundedRectangle"},{"type":"text","text":" background"},{"text":" ","type":"text"},{"type":"text","text":"filled with indigo and a drop shadow."}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Drive ","type":"text"},{"code":"scaleEffect","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"opacity"},{"type":"text","text":" from "},{"type":"codeVoice","code":"configuration.isActive"},{"type":"text","text":" — the label"},{"text":" ","type":"text"},{"text":"springs in when the user starts dragging and fades away when they lift their","type":"text"},{"text":" ","type":"text"},{"text":"finger.","type":"text"}]}]}]},{"title":"Applying the Finished Style","contentSection":[{"content":[{"inlineContent":[{"text":"With all four methods complete, apply ","type":"text"},{"code":"MyLSliderStyle","type":"codeVoice"},{"text":" to a range of sliders —","type":"text"},{"text":" ","type":"text"},{"text":"horizontal, diagonal, with tick marks and affinity — to confirm everything works","type":"text"},{"text":" ","type":"text"},{"text":"together.","type":"text"}],"type":"paragraph"}],"media":"LSlider_Advanced_Step_6.png","mediaPosition":"trailing","kind":"contentAndMedia"}],"stepsSection":[{"code":"LSlider_Advanced_Step_6.swift","type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apply "},{"code":".linearSliderStyle(MyLSliderStyle())","type":"codeVoice"},{"type":"text","text":" to both a horizontal slider"},{"type":"text","text":" "},{"text":"(with tick marks and affinity) and a diagonal slider.  The style adapts","type":"text"},{"text":" ","type":"text"},{"text":"automatically to any angle and thickness thanks to ","type":"text"},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine","isActive":true},{"type":"text","text":"."}]}],"caption":[],"runtimePreview":"LSlider_Advanced_Step_6.png","media":null}],"anchor":"Applying-the-Finished-Style"}],"kind":"tasks"}],"kind":"project","references":{"LSlider_Advanced_Step_5.swift":{"content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled","            ? Color.gray","            : (configuration.isActive ? Color.white : Color.indigo)","        return Circle()","            .fill(color)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","            .shadow(","                color: .black.opacity(configuration.isDisabled ? 0 : 0.2),","                radius: configuration.isActive ? 6 : 2","            )","            .animation(.easeOut(duration: 0.12), value: configuration.isActive)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let distance  = abs(thumbPct - tickPct)","        let proximity = max(0, 1 - distance \/ 0.15)","","        let size    = 5.0 + 7.0 * proximity","        let opacity = 0.3 + 0.7 * proximity","","        return Circle()","            .fill(Color.indigo.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","","    func makeLabel(configuration: LSliderConfiguration, content: AnyView) -> some View {","        content","            .padding(.horizontal, 10)","            .padding(.vertical, 5)","            .background(","                RoundedRectangle(cornerRadius: 8)","                    .fill(Color.indigo)","                    .shadow(color: .black.opacity(0.25), radius: 4, y: 2)","            )","            .foregroundStyle(.white)","            .scaleEffect(configuration.isActive ? 1.0 : 0.75)","            .opacity(configuration.isActive ? 1.0 : 0.0)","            .animation(.spring(response: 0.3, dampingFraction: 0.7), value: configuration.isActive)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        LSlider(","            $value,","            range: 0...1,","            keepThumbInTrack: true,","            trackThickness: 20,","            tickMarkSpacing: .count(11)","        )","        .linearSliderStyle(MyLSliderStyle())","        .frame(height: 80)","        .padding()","    }","}"],"syntax":"swift","identifier":"LSlider_Advanced_Step_5.swift","type":"file","fileName":"MyLSliderStyle.swift","highlights":[],"fileType":"swift"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Implementing-makeThumb":{"abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"text":" lets you take full control of every visual element of the slider.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll build ","type":"text"},{"type":