{"kind":"project","sections":[{"kind":"hero","title":"Building a Custom LSlider Style","estimatedTimeInMinutes":20,"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","isActive":true,"type":"reference"},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"text":"In this tutorial you’ll build ","type":"text"},{"code":"MyLSliderStyle","type":"codeVoice"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and diagonal sliders."}]}],"image":"LSlider_Advanced_Step_6.png","backgroundImage":"LSlider_Advanced_Step_6.png","chapter":"Creating a Custom Style"},{"kind":"tasks","tasks":[{"anchor":"Declaring-the-Style","stepsSection":[{"caption":[{"inlineContent":[{"text":"Apply the style with ","type":"text"},{"code":".linearSliderStyle(MyLSliderStyle())","type":"codeVoice"},{"text":" to see it","type":"text"},{"text":" ","type":"text"},{"text":"immediately in the preview.","type":"text"}],"type":"paragraph"}],"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a new Swift file and declare "},{"code":"MyLSliderStyle","type":"codeVoice"},{"type":"text","text":" as a "},{"code":"struct","type":"codeVoice"},{"text":" that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"conforms to "},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","type":"reference","isActive":true},{"text":".  Provide placeholder bodies for all four","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"required methods — "},{"type":"codeVoice","code":"makeThumb"},{"type":"text","text":", "},{"type":"codeVoice","code":"makeTrack"},{"text":", ","type":"text"},{"code":"makeTickMark","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"code":"makeLabel","type":"codeVoice"},{"text":" — so the project compiles while you iterate.","type":"text"}]}],"media":null,"code":"LSlider_Advanced_Step_1.swift","runtimePreview":"LSlider_Advanced_Step_1.png"}],"title":"Declaring the Style","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"text":"Start by creating a struct that conforms to ","type":"text"},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","isActive":true},{"type":"text","text":".  The protocol"},{"type":"text","text":" "},{"type":"text","text":"requires four methods; you’ll add stub implementations first to make the code"},{"type":"text","text":" "},{"type":"text","text":"compile, then flesh each one out in the following sections."}],"type":"paragraph"}],"media":"LSlider_Advanced_Step_1.png"}]},{"title":"Implementing makeTrack","anchor":"Implementing-makeTrack","contentSection":[{"media":"LSlider_Advanced_Step_2.png","mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"text":"The track is the backbone of the slider.  It consists of two layered","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine","isActive":true,"type":"reference"},{"text":" shapes: a dim background and a filled foreground that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"grows with "},{"type":"codeVoice","code":"pctFill"},{"type":"text","text":"."}],"type":"paragraph"}]}],"stepsSection":[{"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"configuration.pctFill"},{"type":"text","text":" for the fill percentage and"},{"type":"text","text":" "},{"type":"codeVoice","code":"configuration.keepThumbInTrack"},{"type":"text","text":" to compute the correct "},{"type":"codeVoice","code":"adjustmentForThumb"},{"text":" ","type":"text"},{"text":"so the fill always ends under the thumb’s centre.","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Replace the stub "},{"code":"makeTrack","type":"codeVoice"},{"text":" body.  Layer two ","type":"text"},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine","type":"reference","isActive":true},{"text":" shapes in a","type":"text"},{"text":" ","type":"text"},{"code":"ZStack","type":"codeVoice"},{"text":": one as the empty background and one as the filled foreground.","type":"text"},{"text":" ","type":"text"},{"text":"Mask the filled portion so it stays within the capsule.","type":"text"}]}],"code":"LSlider_Advanced_Step_2.swift","media":null,"type":"step","runtimePreview":"LSlider_Advanced_Step_2.png"}]},{"title":"Implementing makeThumb","stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Replace the stub "},{"type":"codeVoice","code":"makeThumb"},{"type":"text","text":" body.  Size the "},{"type":"codeVoice","code":"Circle"},{"type":"text","text":" from"},{"text":" ","type":"text"},{"type":"codeVoice","code":"configuration.trackThickness"},{"text":" (double it for a standard thumb diameter).","type":"text"}],"type":"paragraph"}],"type":"step","runtimePreview":"LSlider_Advanced_Step_3.png","caption":[{"inlineContent":[{"type":"text","text":"Pick the fill color based on "},{"type":"codeVoice","code":"isDisabled"},{"type":"text","text":" → "},{"type":"codeVoice","code":"isActive"},{"type":"text","text":", and add a shadow"},{"type":"text","text":" "},{"type":"text","text":"whose radius expands when the thumb is active to give a lifted feel.  Wrap"},{"type":"text","text":" "},{"type":"text","text":"the color and shadow in an "},{"type":"codeVoice","code":".animation"},{"type":"text","text":" so the transition is smooth."}],"type":"paragraph"}],"media":null,"code":"LSlider_Advanced_Step_3.swift"}],"contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"The thumb needs to communicate three states visually: normal, active (while"},{"text":" ","type":"text"},{"text":"dragging), and disabled.  Use ","type":"text"},{"code":"configuration.isActive","type":"codeVoice"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"code":"configuration.isDisabled","type":"codeVoice"},{"text":" to drive color and shadow changes.","type":"text"}],"type":"paragraph"}],"mediaPosition":"trailing","media":"LSlider_Advanced_Step_3.png","kind":"contentAndMedia"}],"anchor":"Implementing-makeThumb"},{"title":"Implementing makeTickMark","anchor":"Implementing-makeTickMark","contentSection":[{"content":[{"inlineContent":[{"text":"Tick marks should react to the thumb’s proximity — growing and brightening as","type":"text"},{"text":" ","type":"text"},{"text":"the thumb approaches.  ","type":"text"},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderConfiguration","isActive":true},{"text":" provides ","type":"text"},{"type":"codeVoice","code":"value"},{"text":", ","type":"text"},{"type":"codeVoice","code":"min"},{"type":"text","text":", and"},{"type":"text","text":" "},{"code":"max","type":"codeVoice"},{"text":" so you can compute a normalised distance.","type":"text"}],"type":"paragraph"}],"mediaPosition":"trailing","kind":"contentAndMedia","media":"LSlider_Advanced_Step_4.png"}],"stepsSection":[{"type":"step","runtimePreview":"LSlider_Advanced_Step_4.png","code":"LSlider_Advanced_Step_4.swift","caption":[{"inlineContent":[{"text":"Use ","type":"text"},{"code":"proximity","type":"codeVoice"},{"text":" to interpolate both the circle’s ","type":"text"},{"code":"size","type":"codeVoice"},{"text":" and its ","type":"text"},{"code":"opacity","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"and wrap the result in ","type":"text"},{"code":".animation(.easeOut)","type":"codeVoice"},{"text":" so it feels responsive.","type":"text"}],"type":"paragraph"}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Replace the stub "},{"code":"makeTickMark","type":"codeVoice"},{"type":"text","text":" body.  Compute the normalised positions of"},{"type":"text","text":" "},{"type":"text","text":"the thumb ("},{"code":"thumbPct","type":"codeVoice"},{"text":") and the tick mark (","type":"text"},{"code":"tickPct","type":"codeVoice"},{"text":") in the ","type":"text"},{"code":"0…1","type":"codeVoice"},{"text":" space,","type":"text"},{"text":" ","type":"text"},{"text":"then derive a ","type":"text"},{"code":"proximity","type":"codeVoice"},{"text":" value between ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" (far) and ","type":"text"},{"code":"1","type":"codeVoice"},{"text":" (on top).","type":"text"}]}],"media":null}]},{"anchor":"Implementing-makeLabel","title":"Implementing makeLabel","contentSection":[{"media":"LSlider_Advanced_Step_5.png","mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"text":"The floating label container wraps the caller-provided content view.  Override","type":"text"},{"text":" ","type":"text"},{"code":"makeLabel","type":"codeVoice"},{"text":" to brand it with the same indigo palette and give it a spring","type":"text"},{"text":" ","type":"text"},{"text":"entrance\/exit animation tied to ","type":"text"},{"type":"codeVoice","code":"isActive"},{"type":"text","text":"."}],"type":"paragraph"}]}],"stepsSection":[{"type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Drive "},{"type":"codeVoice","code":"scaleEffect"},{"type":"text","text":" and "},{"type":"codeVoice","code":"opacity"},{"type":"text","text":" from "},{"type":"codeVoice","code":"configuration.isActive"},{"type":"text","text":" — the label"},{"type":"text","text":" "},{"type":"text","text":"springs in when the user starts dragging and fades away when they lift their"},{"type":"text","text":" "},{"type":"text","text":"finger."}]}],"media":null,"code":"LSlider_Advanced_Step_5.swift","runtimePreview":"LSlider_Advanced_Step_5.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement "},{"type":"codeVoice","code":"makeLabel(configuration:content:)"},{"type":"text","text":".  Wrap the "},{"type":"codeVoice","code":"content"},{"type":"text","text":" view in"},{"type":"text","text":" "},{"type":"text","text":"horizontal and vertical padding, then apply a "},{"type":"codeVoice","code":"RoundedRectangle"},{"type":"text","text":" background"},{"type":"text","text":" "},{"type":"text","text":"filled with indigo and a drop shadow."}]}]}]},{"title":"Applying the Finished Style","stepsSection":[{"caption":[],"media":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apply "},{"type":"codeVoice","code":".linearSliderStyle(MyLSliderStyle())"},{"type":"text","text":" to both a horizontal slider"},{"type":"text","text":" "},{"type":"text","text":"(with tick marks and affinity) and a diagonal slider.  The style adapts"},{"type":"text","text":" "},{"type":"text","text":"automatically to any angle and thickness thanks to "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine","isActive":true},{"type":"text","text":"."}]}],"code":"LSlider_Advanced_Step_6.swift","runtimePreview":"LSlider_Advanced_Step_6.png"}],"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"With all four methods complete, apply ","type":"text"},{"type":"codeVoice","code":"MyLSliderStyle"},{"text":" to a range of sliders —","type":"text"},{"text":" ","type":"text"},{"text":"horizontal, diagonal, with tick marks and affinity — to confirm everything works","type":"text"},{"text":" ","type":"text"},{"text":"together.","type":"text"}]}],"media":"LSlider_Advanced_Step_6.png"}],"anchor":"Applying-the-Finished-Style"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"category":"LSlider","categoryPathComponent":"LSlider-Tutorials","role":"project","title":"Building a Custom LSlider Style"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/sliders\/lslider-advanced"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced"},"hierarchy":{"modules":[{"projects":[{"sections":[{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Basic-Usage"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Tick-Marks"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Affinity-Snapping"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Interaction-Labels-Accessibility"}],"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics"}],"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Using-the-Default-Style"},{"projects":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced","sections":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Declaring-the-Style","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTrack","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeThumb","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTickMark","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeLabel","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Applying-the-Finished-Style","kind":"task"}]}],"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Creating-a-Custom-Style"}],"paths":[["doc:\/\/Sliders\/tutorials\/LSlider-Tutorials","doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/$volume","doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Creating-a-Custom-Style"]],"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials"},"references":{"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Declaring-the-Style":{"title":"Declaring the Style","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","isActive":true,"type":"reference"},{"text":" lets you take full control of every visual element of the slider.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll build ","type":"text"},{"code":"MyLSliderStyle","type":"codeVoice"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"role":"pseudoSymbol","type":"section","url":"\/tutorials\/sliders\/lslider-advanced#Declaring-the-Style","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Declaring-the-Style","kind":"section"},"doc://Sliders/tutorials/Sliders/LSlider-Basics#Affinity-Snapping":{"role":"pseudoSymbol","type":"section","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Affinity-Snapping","kind":"section","url":"\/tutorials\/sliders\/lslider-basics#Affinity-Snapping","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","type":"reference","isActive":true},{"text":" is a fully stylable linear slider that can be placed at any angle.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll explore every configuration option the default style offers —","type":"text"},{"text":" ","type":"text"},{"text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with","type":"text"},{"text":" ","type":"text"},{"text":"custom labels.","type":"text"}],"title":"Affinity Snapping"},"doc://Sliders/documentation/Sliders/AdaptiveLine":{"abstract":[],"role":"symbol","navigatorTitle":[{"text":"AdaptiveLine","kind":"identifier"}],"type":"topic","kind":"symbol","url":"\/documentation\/sliders\/adaptiveline","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"AdaptiveLine","kind":"identifier"}],"title":"AdaptiveLine","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine"},"doc://Sliders/tutorials/Sliders/LSlider-Basics#Tick-Marks":{"kind":"section","title":"Tick Marks","role":"pseudoSymbol","type":"section","url":"\/tutorials\/sliders\/lslider-basics#Tick-Marks","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Tick-Marks","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"type":"text","text":" is a fully stylable linear slider that can be placed at any angle."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore every configuration option the default style offers —"},{"type":"text","text":" "},{"type":"text","text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with"},{"type":"text","text":" "},{"type":"text","text":"custom labels."}]},"doc://Sliders/tutorials/Sliders/LSlider-Basics":{"title":"Using LSlider with the Default Style","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"type":"text","text":" is a fully stylable linear slider that can be placed at any angle."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore every configuration option the default style offers —"},{"type":"text","text":" "},{"type":"text","text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with"},{"type":"text","text":" "},{"type":"text","text":"custom labels."}],"role":"project","type":"topic","estimatedTime":"20min","url":"\/tutorials\/sliders\/lslider-basics","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics","kind":"project"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced":{"role":"project","type":"topic","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","type":"reference","isActive":true},{"text":" lets you take full control of every visual element of the slider.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll build ","type":"text"},{"code":"MyLSliderStyle","type":"codeVoice"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"kind":"project","url":"\/tutorials\/sliders\/lslider-advanced","estimatedTime":"20min","title":"Building a Custom LSlider Style"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Implementing-makeTickMark":{"abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll build "},{"code":"MyLSliderStyle","type":"codeVoice"},{"text":" from scratch — implementing each","type":"text"},{"type":"text","text":" "},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"kind":"section","url":"\/tutorials\/sliders\/lslider-advanced#Implementing-makeTickMark","role":"pseudoSymbol","type":"section","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTickMark","title":"Implementing makeTickMark"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Implementing-makeTrack":{"role":"pseudoSymbol","type":"section","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTrack","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","type":"reference","isActive":true},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll build "},{"code":"MyLSliderStyle","type":"codeVoice"},{"type":"text","text":" from scratch — implementing each"},{"text":" ","type":"text"},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and diagonal sliders."}],"url":"\/tutorials\/sliders\/lslider-advanced#Implementing-makeTrack","kind":"section","title":"Implementing makeTrack"},"LSlider_Advanced_Step_3.png":{"identifier":"LSlider_Advanced_Step_3.png","alt":"Thumb changing color between active and disabled states","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/LSlider_Advanced_Step_3.png"}]},"LSlider_Advanced_Step_6.png":{"identifier":"LSlider_Advanced_Step_6.png","alt":"Horizontal and diagonal sliders using MyLSliderStyle","variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/LSlider_Advanced_Step_6.png"}],"type":"image"},"LSlider_Advanced_Step_2.png":{"alt":"Track with indigo fill growing from the left","type":"image","variants":[{"url":"\/images\/Sliders\/LSlider_Advanced_Step_2.png","traits":["1x","light"]}],"identifier":"LSlider_Advanced_Step_2.png"},"doc://Sliders/documentation/Sliders/LSliderStyle":{"url":"\/documentation\/sliders\/lsliderstyle","role":"symbol","navigatorTitle":[{"text":"LSliderStyle","kind":"identifier"}],"title":"LSliderStyle","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LSliderStyle","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","kind":"symbol","abstract":[{"type":"text","text":"A style that determines the appearance of an "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true},{"type":"text","text":"."}]},"doc://Sliders/tutorials/LSlider-Tutorials":{"role":"overview","identifier":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials","kind":"overview","url":"\/tutorials\/lslider-tutorials","type":"topic","abstract":[{"text":"Learn how to add a spatially adaptive linear slider to your app — starting with the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"built-in default style and its full range of configuration options, then advancing to"},{"text":" ","type":"text"},{"type":"text","text":"building a completely custom style from scratch."}],"title":"Building Sliders with LSlider"},"LSlider_Advanced_Step_6.swift":{"content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled","            ? Color.gray","            : (configuration.isActive ? Color.white : Color.indigo)","        return Circle()","            .fill(color)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","            .shadow(","                color: .black.opacity(configuration.isDisabled ? 0 : 0.2),","                radius: configuration.isActive ? 6 : 2","            )","            .animation(.easeOut(duration: 0.12), value: configuration.isActive)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let distance  = abs(thumbPct - tickPct)","        let proximity = max(0, 1 - distance \/ 0.15)","","        let size    = 5.0 + 7.0 * proximity","        let opacity = 0.3 + 0.7 * proximity","","        return Circle()","            .fill(Color.indigo.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","","    func makeLabel(configuration: LSliderConfiguration, content: AnyView) -> some View {","        content","            .padding(.horizontal, 10)","            .padding(.vertical, 5)","            .background(","                RoundedRectangle(cornerRadius: 8)","                    .fill(Color.indigo)","                    .shadow(color: .black.opacity(0.25), radius: 4, y: 2)","            )","            .foregroundStyle(.white)","            .scaleEffect(configuration.isActive ? 1.0 : 0.75)","            .opacity(configuration.isActive ? 1.0 : 0.0)","            .animation(.spring(response: 0.3, dampingFraction: 0.7), value: configuration.isActive)","    }","}","","struct ContentView: View {","    @State private var value1 = 0.5","    @State private var value2 = 0.5","","    var body: some View {","        VStack(spacing: 20) {","            LSlider(","                $value1,","                range: 0...1,","                keepThumbInTrack: true,","                trackThickness: 20,","                tickMarkSpacing: .count(11),","                affinityEnabled: true","            )","            .linearSliderStyle(MyLSliderStyle())","            .frame(height: 80)","","            LSlider(","                $value2,","                range: 0...1,","                angle: Angle(degrees: 315),","                keepThumbInTrack: true,","                trackThickness: 20,","                tickMarkSpacing: .count(5),","                affinityEnabled: true","            )","            .linearSliderStyle(MyLSliderStyle())","            .frame(width: 200, height: 200)","        }","        .padding()","    }","}"],"syntax":"swift","type":"file","fileType":"swift","fileName":"ContentView.swift","identifier":"LSlider_Advanced_Step_6.swift","highlights":[]},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Implementing-makeLabel":{"role":"pseudoSymbol","type":"section","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeLabel","url":"\/tutorials\/sliders\/lslider-advanced#Implementing-makeLabel","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"text":" lets you take full control of every visual element of the slider.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll build ","type":"text"},{"type":"codeVoice","code":"MyLSliderStyle"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"kind":"section","title":"Implementing makeLabel"},"doc://Sliders/tutorials/LSlider-Tutorials/Creating-a-Custom-Style":{"abstract":[],"kind":"article","role":"article","type":"topic","url":"\/tutorials\/lslider-tutorials\/creating-a-custom-style","identifier":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Creating-a-Custom-Style","tit