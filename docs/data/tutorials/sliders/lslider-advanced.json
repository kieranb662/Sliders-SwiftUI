{"identifier":{"url":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced","interfaceLanguage":"swift"},"metadata":{"role":"project","category":"LSlider","title":"Building a Custom LSlider Style","categoryPathComponent":"LSlider-Tutorials"},"sections":[{"title":"Building a Custom LSlider Style","chapter":"Creating a Custom Style","backgroundImage":"LSlider_Advanced_Step_6.png","kind":"hero","image":"LSlider_Advanced_Step_6.png","content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","isActive":true},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll build "},{"type":"codeVoice","code":"MyLSliderStyle"},{"type":"text","text":" from scratch — implementing each"},{"type":"text","text":" "},{"type":"text","text":"protocol method one at a time — and applying the finished style to both horizontal"},{"type":"text","text":" "},{"type":"text","text":"and diagonal sliders."}],"type":"paragraph"}],"estimatedTimeInMinutes":20},{"kind":"tasks","tasks":[{"stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a new Swift file and declare "},{"type":"codeVoice","code":"MyLSliderStyle"},{"text":" as a ","type":"text"},{"code":"struct","type":"codeVoice"},{"text":" that","type":"text"},{"text":" ","type":"text"},{"text":"conforms to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","type":"reference"},{"type":"text","text":".  Provide placeholder bodies for all four"},{"text":" ","type":"text"},{"text":"required methods — ","type":"text"},{"code":"makeThumb","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"makeTrack"},{"type":"text","text":", "},{"code":"makeTickMark","type":"codeVoice"},{"type":"text","text":", and"},{"type":"text","text":" "},{"type":"codeVoice","code":"makeLabel"},{"text":" — so the project compiles while you iterate.","type":"text"}]}],"runtimePreview":"LSlider_Advanced_Step_1.png","code":"LSlider_Advanced_Step_1.swift","media":null,"type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apply the style with "},{"type":"codeVoice","code":".linearSliderStyle(MyLSliderStyle())"},{"type":"text","text":" to see it"},{"type":"text","text":" "},{"type":"text","text":"immediately in the preview."}]}]}],"anchor":"Declaring-the-Style","title":"Declaring the Style","contentSection":[{"mediaPosition":"trailing","content":[{"inlineContent":[{"type":"text","text":"Start by creating a struct that conforms to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"type":"text","text":".  The protocol"},{"type":"text","text":" "},{"type":"text","text":"requires four methods; you’ll add stub implementations first to make the code"},{"type":"text","text":" "},{"type":"text","text":"compile, then flesh each one out in the following sections."}],"type":"paragraph"}],"kind":"contentAndMedia","media":"LSlider_Advanced_Step_1.png"}]},{"anchor":"Implementing-makeTrack","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The track is the backbone of the slider.  It consists of two layered"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine"},{"type":"text","text":" shapes: a dim background and a filled foreground that"},{"type":"text","text":" "},{"type":"text","text":"grows with "},{"code":"pctFill","type":"codeVoice"},{"type":"text","text":"."}]}],"media":"LSlider_Advanced_Step_2.png","kind":"contentAndMedia","mediaPosition":"trailing"}],"title":"Implementing makeTrack","stepsSection":[{"caption":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":"configuration.pctFill","type":"codeVoice"},{"text":" for the fill percentage and","type":"text"},{"text":" ","type":"text"},{"code":"configuration.keepThumbInTrack","type":"codeVoice"},{"text":" to compute the correct ","type":"text"},{"code":"adjustmentForThumb","type":"codeVoice"},{"text":" ","type":"text"},{"text":"so the fill always ends under the thumb’s centre.","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"Replace the stub ","type":"text"},{"code":"makeTrack","type":"codeVoice"},{"text":" body.  Layer two ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine"},{"text":" shapes in a","type":"text"},{"text":" ","type":"text"},{"code":"ZStack","type":"codeVoice"},{"text":": one as the empty background and one as the filled foreground.","type":"text"},{"text":" ","type":"text"},{"text":"Mask the filled portion so it stays within the capsule.","type":"text"}]}],"type":"step","media":null,"runtimePreview":"LSlider_Advanced_Step_2.png","code":"LSlider_Advanced_Step_2.swift"}]},{"stepsSection":[{"code":"LSlider_Advanced_Step_3.swift","runtimePreview":"LSlider_Advanced_Step_3.png","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pick the fill color based on "},{"type":"codeVoice","code":"isDisabled"},{"type":"text","text":" → "},{"type":"codeVoice","code":"isActive"},{"type":"text","text":", and add a shadow"},{"type":"text","text":" "},{"type":"text","text":"whose radius expands when the thumb is active to give a lifted feel.  Wrap"},{"type":"text","text":" "},{"type":"text","text":"the color and shadow in an "},{"type":"codeVoice","code":".animation"},{"type":"text","text":" so the transition is smooth."}]}],"media":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Replace the stub ","type":"text"},{"code":"makeThumb","type":"codeVoice"},{"text":" body.  Size the ","type":"text"},{"code":"Circle","type":"codeVoice"},{"text":" from","type":"text"},{"text":" ","type":"text"},{"code":"configuration.trackThickness","type":"codeVoice"},{"text":" (double it for a standard thumb diameter).","type":"text"}]}]}],"title":"Implementing makeThumb","contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","media":"LSlider_Advanced_Step_3.png","content":[{"type":"paragraph","inlineContent":[{"text":"The thumb needs to communicate three states visually: normal, active (while","type":"text"},{"text":" ","type":"text"},{"text":"dragging), and disabled.  Use ","type":"text"},{"type":"codeVoice","code":"configuration.isActive"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"configuration.isDisabled"},{"text":" to drive color and shadow changes.","type":"text"}]}]}],"anchor":"Implementing-makeThumb"},{"anchor":"Implementing-makeTickMark","title":"Implementing makeTickMark","contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"type":"text","text":"Tick marks should react to the thumb’s proximity — growing and brightening as"},{"text":" ","type":"text"},{"type":"text","text":"the thumb approaches.  "},{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderConfiguration","type":"reference"},{"type":"text","text":" provides "},{"code":"value","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"min"},{"type":"text","text":", and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"max"},{"type":"text","text":" so you can compute a normalised distance."}],"type":"paragraph"}],"media":"LSlider_Advanced_Step_4.png"}],"stepsSection":[{"type":"step","media":null,"runtimePreview":"LSlider_Advanced_Step_4.png","code":"LSlider_Advanced_Step_4.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Replace the stub "},{"code":"makeTickMark","type":"codeVoice"},{"type":"text","text":" body.  Compute the normalised positions of"},{"type":"text","text":" "},{"type":"text","text":"the thumb ("},{"code":"thumbPct","type":"codeVoice"},{"type":"text","text":") and the tick mark ("},{"type":"codeVoice","code":"tickPct"},{"type":"text","text":") in the "},{"type":"codeVoice","code":"0…1"},{"type":"text","text":" space,"},{"text":" ","type":"text"},{"text":"then derive a ","type":"text"},{"code":"proximity","type":"codeVoice"},{"text":" value between ","type":"text"},{"type":"codeVoice","code":"0"},{"type":"text","text":" (far) and "},{"code":"1","type":"codeVoice"},{"type":"text","text":" (on top)."}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":"proximity","type":"codeVoice"},{"text":" to interpolate both the circle’s ","type":"text"},{"type":"codeVoice","code":"size"},{"type":"text","text":" and its "},{"type":"codeVoice","code":"opacity"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and wrap the result in "},{"type":"codeVoice","code":".animation(.easeOut)"},{"type":"text","text":" so it feels responsive."}]}]}]},{"title":"Implementing makeLabel","contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","media":"LSlider_Advanced_Step_5.png","content":[{"inlineContent":[{"type":"text","text":"The floating label container wraps the caller-provided content view.  Override"},{"type":"text","text":" "},{"code":"makeLabel","type":"codeVoice"},{"text":" to brand it with the same indigo palette and give it a spring","type":"text"},{"text":" ","type":"text"},{"text":"entrance\/exit animation tied to ","type":"text"},{"code":"isActive","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}],"stepsSection":[{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Implement ","type":"text"},{"type":"codeVoice","code":"makeLabel(configuration:content:)"},{"type":"text","text":".  Wrap the "},{"type":"codeVoice","code":"content"},{"type":"text","text":" view in"},{"text":" ","type":"text"},{"text":"horizontal and vertical padding, then apply a ","type":"text"},{"type":"codeVoice","code":"RoundedRectangle"},{"text":" background","type":"text"},{"text":" ","type":"text"},{"text":"filled with indigo and a drop shadow.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Drive "},{"code":"scaleEffect","type":"codeVoice"},{"type":"text","text":" and "},{"code":"opacity","type":"codeVoice"},{"type":"text","text":" from "},{"code":"configuration.isActive","type":"codeVoice"},{"type":"text","text":" — the label"},{"type":"text","text":" "},{"type":"text","text":"springs in when the user starts dragging and fades away when they lift their"},{"type":"text","text":" "},{"type":"text","text":"finger."}]}],"code":"LSlider_Advanced_Step_5.swift","runtimePreview":"LSlider_Advanced_Step_5.png","media":null}],"anchor":"Implementing-makeLabel"},{"anchor":"Applying-the-Finished-Style","title":"Applying the Finished Style","stepsSection":[{"runtimePreview":"LSlider_Advanced_Step_6.png","media":null,"code":"LSlider_Advanced_Step_6.swift","type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apply "},{"type":"codeVoice","code":".linearSliderStyle(MyLSliderStyle())"},{"type":"text","text":" to both a horizontal slider"},{"text":" ","type":"text"},{"text":"(with tick marks and affinity) and a diagonal slider.  The style adapts","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"automatically to any angle and thickness thanks to "},{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine","type":"reference"},{"text":".","type":"text"}]}],"caption":[]}],"contentSection":[{"media":"LSlider_Advanced_Step_6.png","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"text":"With all four methods complete, apply ","type":"text"},{"type":"codeVoice","code":"MyLSliderStyle"},{"type":"text","text":" to a range of sliders —"},{"type":"text","text":" "},{"text":"horizontal, diagonal, with tick marks and affinity — to confirm everything works","type":"text"},{"type":"text","text":" "},{"type":"text","text":"together."}]}],"kind":"contentAndMedia"}]}]}],"hierarchy":{"paths":[["doc:\/\/Sliders\/tutorials\/LSlider-Tutorials","doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/$volume","doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Creating-a-Custom-Style"]],"modules":[{"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Using-the-Default-Style","projects":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics","sections":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Basic-Usage","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Tick-Marks","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Affinity-Snapping","kind":"task"},{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Interaction-Labels-Accessibility","kind":"task"}]}]},{"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Creating-a-Custom-Style","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Declaring-the-Style"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTrack"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeThumb"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTickMark"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeLabel"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Applying-the-Finished-Style"}],"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced"}]}],"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials"},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"project","variants":[{"paths":["\/tutorials\/sliders\/lslider-advanced"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"LSlider_Advanced_Step_5.swift":{"type":"file","fileName":"MyLSliderStyle.swift","syntax":"swift","identifier":"LSlider_Advanced_Step_5.swift","highlights":[],"content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled","            ? Color.gray","            : (configuration.isActive ? Color.white : Color.indigo)","        return Circle()","            .fill(color)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","            .shadow(","                color: .black.opacity(configuration.isDisabled ? 0 : 0.2),","                radius: configuration.isActive ? 6 : 2","            )","            .animation(.easeOut(duration: 0.12), value: configuration.isActive)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let distance  = abs(thumbPct - tickPct)","        let proximity = max(0, 1 - distance \/ 0.15)","","        let size    = 5.0 + 7.0 * proximity","        let opacity = 0.3 + 0.7 * proximity","","        return Circle()","            .fill(Color.indigo.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","","    func makeLabel(configuration: LSliderConfiguration, content: AnyView) -> some View {","        content","            .padding(.horizontal, 10)","            .padding(.vertical, 5)","            .background(","                RoundedRectangle(cornerRadius: 8)","                    .fill(Color.indigo)","                    .shadow(color: .black.opacity(0.25), radius: 4, y: 2)","            )","            .foregroundStyle(.white)","            .scaleEffect(configuration.isActive ? 1.0 : 0.75)","            .opacity(configuration.isActive ? 1.0 : 0.0)","            .animation(.spring(response: 0.3, dampingFraction: 0.7), value: configuration.isActive)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        LSlider(","            $value,","            range: 0...1,","            keepThumbInTrack: true,","            trackThickness: 20,","            tickMarkSpacing: .count(11)","        )","        .linearSliderStyle(MyLSliderStyle())","        .frame(height: 80)","        .padding()","    }","}"],"fileType":"swift"},"doc://Sliders/tutorials/LSlider-Tutorials/Creating-a-Custom-Style":{"abstract":[],"url":"\/tutorials\/lslider-tutorials\/creating-a-custom-style","title":"Creating a Custom Style","role":"article","type":"topic","identifier":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Creating-a-Custom-Style","kind":"article"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Implement