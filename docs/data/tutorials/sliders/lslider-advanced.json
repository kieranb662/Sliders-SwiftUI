{"sections":[{"backgroundImage":"LSlider_Advanced_Step_6.png","image":"LSlider_Advanced_Step_6.png","kind":"hero","estimatedTimeInMinutes":20,"title":"Building a Custom LSlider Style","chapter":"Creating a Custom Style","content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"text":" lets you take full control of every visual element of the slider.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll build ","type":"text"},{"type":"codeVoice","code":"MyLSliderStyle"},{"type":"text","text":" from scratch — implementing each"},{"type":"text","text":" "},{"type":"text","text":"protocol method one at a time — and applying the finished style to both horizontal"},{"text":" ","type":"text"},{"type":"text","text":"and diagonal sliders."}],"type":"paragraph"}]},{"tasks":[{"title":"Declaring the Style","stepsSection":[{"media":null,"caption":[{"inlineContent":[{"text":"Apply the style with ","type":"text"},{"code":".linearSliderStyle(MyLSliderStyle())","type":"codeVoice"},{"text":" to see it","type":"text"},{"text":" ","type":"text"},{"text":"immediately in the preview.","type":"text"}],"type":"paragraph"}],"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Create a new Swift file and declare ","type":"text"},{"code":"MyLSliderStyle","type":"codeVoice"},{"text":" as a ","type":"text"},{"code":"struct","type":"codeVoice"},{"text":" that","type":"text"},{"text":" ","type":"text"},{"text":"conforms to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","type":"reference"},{"text":".  Provide placeholder bodies for all four","type":"text"},{"text":" ","type":"text"},{"text":"required methods — ","type":"text"},{"code":"makeThumb","type":"codeVoice"},{"text":", ","type":"text"},{"code":"makeTrack","type":"codeVoice"},{"type":"text","text":", "},{"code":"makeTickMark","type":"codeVoice"},{"type":"text","text":", and"},{"type":"text","text":" "},{"code":"makeLabel","type":"codeVoice"},{"type":"text","text":" — so the project compiles while you iterate."}]}],"code":"LSlider_Advanced_Step_1.swift","runtimePreview":"LSlider_Advanced_Step_1.png"}],"anchor":"Declaring-the-Style","contentSection":[{"media":"LSlider_Advanced_Step_1.png","content":[{"inlineContent":[{"type":"text","text":"Start by creating a struct that conforms to "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","isActive":true},{"type":"text","text":".  The protocol"},{"type":"text","text":" "},{"type":"text","text":"requires four methods; you’ll add stub implementations first to make the code"},{"type":"text","text":" "},{"type":"text","text":"compile, then flesh each one out in the following sections."}],"type":"paragraph"}],"mediaPosition":"trailing","kind":"contentAndMedia"}]},{"title":"Implementing makeTrack","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The track is the backbone of the slider.  It consists of two layered"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine","isActive":true},{"type":"text","text":" shapes: a dim background and a filled foreground that"},{"type":"text","text":" "},{"type":"text","text":"grows with "},{"type":"codeVoice","code":"pctFill"},{"type":"text","text":"."}]}],"media":"LSlider_Advanced_Step_2.png","mediaPosition":"trailing"}],"stepsSection":[{"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"configuration.pctFill"},{"type":"text","text":" for the fill percentage and"},{"type":"text","text":" "},{"type":"codeVoice","code":"configuration.keepThumbInTrack"},{"type":"text","text":" to compute the correct "},{"type":"codeVoice","code":"adjustmentForThumb"},{"type":"text","text":" "},{"type":"text","text":"so the fill always ends under the thumb’s centre."}]}],"code":"LSlider_Advanced_Step_2.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Replace the stub "},{"type":"codeVoice","code":"makeTrack"},{"type":"text","text":" body.  Layer two "},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine","type":"reference","isActive":true},{"type":"text","text":" shapes in a"},{"type":"text","text":" "},{"code":"ZStack","type":"codeVoice"},{"text":": one as the empty background and one as the filled foreground.","type":"text"},{"text":" ","type":"text"},{"text":"Mask the filled portion so it stays within the capsule.","type":"text"}]}],"runtimePreview":"LSlider_Advanced_Step_2.png","type":"step","media":null}],"anchor":"Implementing-makeTrack"},{"title":"Implementing makeThumb","anchor":"Implementing-makeThumb","contentSection":[{"mediaPosition":"trailing","media":"LSlider_Advanced_Step_3.png","content":[{"inlineContent":[{"type":"text","text":"The thumb needs to communicate three states visually: normal, active (while"},{"type":"text","text":" "},{"type":"text","text":"dragging), and disabled.  Use "},{"type":"codeVoice","code":"configuration.isActive"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"configuration.isDisabled"},{"type":"text","text":" to drive color and shadow changes."}],"type":"paragraph"}],"kind":"contentAndMedia"}],"stepsSection":[{"type":"step","runtimePreview":"LSlider_Advanced_Step_3.png","media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Replace the stub ","type":"text"},{"code":"makeThumb","type":"codeVoice"},{"text":" body.  Size the ","type":"text"},{"code":"Circle","type":"codeVoice"},{"text":" from","type":"text"},{"type":"text","text":" "},{"code":"configuration.trackThickness","type":"codeVoice"},{"type":"text","text":" (double it for a standard thumb diameter)."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pick the fill color based on "},{"type":"codeVoice","code":"isDisabled"},{"type":"text","text":" → "},{"type":"codeVoice","code":"isActive"},{"type":"text","text":", and add a shadow"},{"type":"text","text":" "},{"type":"text","text":"whose radius expands when the thumb is active to give a lifted feel.  Wrap"},{"type":"text","text":" "},{"type":"text","text":"the color and shadow in an "},{"type":"codeVoice","code":".animation"},{"type":"text","text":" so the transition is smooth."}]}],"code":"LSlider_Advanced_Step_3.swift"}]},{"anchor":"Implementing-makeTickMark","stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Replace the stub ","type":"text"},{"type":"codeVoice","code":"makeTickMark"},{"text":" body.  Compute the normalised positions of","type":"text"},{"text":" ","type":"text"},{"text":"the thumb (","type":"text"},{"type":"codeVoice","code":"thumbPct"},{"type":"text","text":") and the tick mark ("},{"type":"codeVoice","code":"tickPct"},{"type":"text","text":") in the "},{"type":"codeVoice","code":"0…1"},{"type":"text","text":" space,"},{"type":"text","text":" "},{"type":"text","text":"then derive a "},{"type":"codeVoice","code":"proximity"},{"type":"text","text":" value between "},{"type":"codeVoice","code":"0"},{"type":"text","text":" (far) and "},{"type":"codeVoice","code":"1"},{"type":"text","text":" (on top)."}]}],"type":"step","code":"LSlider_Advanced_Step_4.swift","media":null,"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"proximity"},{"type":"text","text":" to interpolate both the circle’s "},{"type":"codeVoice","code":"size"},{"type":"text","text":" and its "},{"type":"codeVoice","code":"opacity"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and wrap the result in "},{"type":"codeVoice","code":".animation(.easeOut)"},{"type":"text","text":" so it feels responsive."}]}],"runtimePreview":"LSlider_Advanced_Step_4.png"}],"title":"Implementing makeTickMark","contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"Tick marks should react to the thumb’s proximity — growing and brightening as"},{"type":"text","text":" "},{"type":"text","text":"the thumb approaches.  "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderConfiguration","isActive":true},{"type":"text","text":" provides "},{"type":"codeVoice","code":"value"},{"type":"text","text":", "},{"type":"codeVoice","code":"min"},{"type":"text","text":", and"},{"type":"text","text":" "},{"type":"codeVoice","code":"max"},{"type":"text","text":" so you can compute a normalised distance."}],"type":"paragraph"}],"media":"LSlider_Advanced_Step_4.png","mediaPosition":"trailing"}]},{"title":"Implementing makeLabel","stepsSection":[{"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement "},{"type":"codeVoice","code":"makeLabel(configuration:content:)"},{"type":"text","text":".  Wrap the "},{"type":"codeVoice","code":"content"},{"type":"text","text":" view in"},{"type":"text","text":" "},{"type":"text","text":"horizontal and vertical padding, then apply a "},{"type":"codeVoice","code":"RoundedRectangle"},{"type":"text","text":" background"},{"type":"text","text":" "},{"type":"text","text":"filled with indigo and a drop shadow."}]}],"media":null,"runtimePreview":"LSlider_Advanced_Step_5.png","caption":[{"type":"paragraph","inlineContent":[{"text":"Drive ","type":"text"},{"type":"codeVoice","code":"scaleEffect"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"opacity"},{"text":" from ","type":"text"},{"type":"codeVoice","code":"configuration.isActive"},{"text":" — the label","type":"text"},{"text":" ","type":"text"},{"text":"springs in when the user starts dragging and fades away when they lift their","type":"text"},{"text":" ","type":"text"},{"text":"finger.","type":"text"}]}],"code":"LSlider_Advanced_Step_5.swift"}],"anchor":"Implementing-makeLabel","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The floating label container wraps the caller-provided content view.  Override"},{"type":"text","text":" "},{"type":"codeVoice","code":"makeLabel"},{"type":"text","text":" to brand it with the same indigo palette and give it a spring"},{"type":"text","text":" "},{"type":"text","text":"entrance\/exit animation tied to "},{"code":"isActive","type":"codeVoice"},{"type":"text","text":"."}]}],"media":"LSlider_Advanced_Step_5.png","mediaPosition":"trailing"}]},{"title":"Applying the Finished Style","stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apply "},{"code":".linearSliderStyle(MyLSliderStyle())","type":"codeVoice"},{"text":" to both a horizontal slider","type":"text"},{"text":" ","type":"text"},{"text":"(with tick marks and affinity) and a diagonal slider.  The style adapts","type":"text"},{"text":" ","type":"text"},{"text":"automatically to any angle and thickness thanks to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine","type":"reference"},{"text":".","type":"text"}]}],"code":"LSlider_Advanced_Step_6.swift","caption":[],"type":"step","media":null,"runtimePreview":"LSlider_Advanced_Step_6.png"}],"anchor":"Applying-the-Finished-Style","contentSection":[{"content":[{"inlineContent":[{"text":"With all four methods complete, apply ","type":"text"},{"type":"codeVoice","code":"MyLSliderStyle"},{"text":" to a range of sliders —","type":"text"},{"text":" ","type":"text"},{"text":"horizontal, diagonal, with tick marks and affinity — to confirm everything works","type":"text"},{"text":" ","type":"text"},{"text":"together.","type":"text"}],"type":"paragraph"}],"kind":"contentAndMedia","media":"LSlider_Advanced_Step_6.png","mediaPosition":"trailing"}]}],"kind":"tasks"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/Sliders\/tutorials\/LSlider-Tutorials","doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/$volume","doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Creating-a-Custom-Style"]],"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials","modules":[{"projects":[{"sections":[{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Basic-Usage"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Tick-Marks"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Affinity-Snapping"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Interaction-Labels-Accessibility"}],"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics"}],"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Using-the-Default-Style"},{"projects":[{"sections":[{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Declaring-the-Style"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTrack"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeThumb"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTickMark"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeLabel"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Applying-the-Finished-Style"}],"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced"}],"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Creating-a-Custom-Style"}]},"identifier":{"url":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced","interfaceLanguage":"swift"},"metadata":{"category":"LSlider","role":"project","categoryPathComponent":"LSlider-Tutorials","title":"Building a Custom LSlider Style"},"kind":"project","variants":[{"paths":["\/tutorials\/sliders\/lslider-advanced"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://Sliders/documentation/Sliders/LSliderConfiguration":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LSliderConfiguration","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"LSliderConfiguration","kind":"identifier"}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderConfiguration","title":"LSliderConfiguration","url":"\/documentation\/sliders\/lsliderconfiguration","type":"topic","abstract":[{"text":"A value type describing the current state of an ","type":"text"},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true,"type":"reference"},{"text":".","type":"text"}],"kind":"symbol"},"doc://Sliders/documentation/Sliders/LSliderStyle":{"title":"LSliderStyle","url":"\/documentation\/sliders\/lsliderstyle","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"LSliderStyle"}],"role":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"LSliderStyle"}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","abstract":[{"text":"A style that determines the appearance of an ","type":"text"},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true},{"type":"text","text":"."}]},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Implementing-makeTickMark":{"kind":"section","abstract":[{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","type":"reference"},{"text":" lets you take full control of every visual element of the slider.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll build ","type":"text"},{"code":"MyLSliderStyle","type":"codeVoice"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTickMark","role":"pseudoSymbol","title":"Implementing makeTickMark","url":"\/tutorials\/sliders\/lslider-advanced#Implementing-makeTickMark","type":"section"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Implementing-makeLabel":{"title":"Implementing makeLabel","url":"\/tutorials\/sliders\/lslider-advanced#Implementing-makeLabel","kind":"section","role":"pseudoSymbol","type":"section","abstract":[{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","type":"reference"},{"text":" lets you take full control of every visual element of the slider.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll build ","type":"text"},{"code":"MyLSliderStyle","type":"codeVoice"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"text":"and diagonal sliders.","type":"text"}],"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeLabel"},"doc://Sliders/tutorials/LSlider-Tutorials/Creating-a-Custom-Style":{"kind":"article","abstract":[],"identifier":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Creating-a-Custom-Style","role":"article","title":"Creating a Custom Style","url":"\/tutorials\/lslider-tutorials\/creating-a-custom-style","type":"topic"},"LSlider_Advanced_Step_3.png":{"type":"image","alt":"Thumb changing color between active and disabled states","variants":[{"url":"\/images\/Sliders\/LSlider_Advanced_Step_3.png","traits":["1x","light"]}],"identifier":"LSlider_Advanced_Step_3.png"},"LSlider_Advanced_Step_4.swift":{"type":"file","fileType":"swift","content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled","            ? Color.gray","            : (configuration.isActive ? Color.white : Color.indigo)","        return Circle()","            .fill(color)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","            .shadow(","                color: .black.opacity(configuration.isDisabled ? 0 : 0.2),","                radius: configuration.isActive ? 6 : 2","            )","            .animation(.easeOut(duration: 0.12), value: configuration.isActive)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let distance  = abs(thumbPct - tickPct)","        let proximity = max(0, 1 - distance \/ 0.15)","","        let size    = 5.0 + 7.0 * proximity","        let opacity = 0.3 + 0.7 * proximity","","        return Circle()","            .fill(Color.indigo.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        VStack(spacing: 8) {","            LSlider(","                $value,","                range: 0...1,","                keepThumbInTrack: true,","                trackThickness: 20,","                tickMarkSpacing: .count(11)","            )","            .linearSliderStyle(MyLSliderStyle())","            .frame(height: 60)","            Text(\"Value: \\(value, specifier: \"%.2f\")\")","                .font(.caption)","        }","        .padding()","    }","}"],"fileName":"MyLSliderStyle.swift","identifier":"LSlider_Advanced_Step_4.swift","highlights":[],"syntax":"swift"},"doc://Sliders/tutorials/Sliders/LSlider-Basics#Affinity-Snapping":{"url":"\/tutorials\/sliders\/lslider-basics#Affinity-Snapping","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true,"type":"reference"},{"text":" is a fully stylable linear slider that can be placed at any angle.","type":"text"},{"text":" ","type":"text"},{"text":"In this tutorial you’ll explore every configuration option the default style offers —","type":"text"},{"text":" ","type":"text"},{"text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with","type":"text"},{"text":" ","type":"text"},{"text":"custom labels.","type":"text"}],"type":"section","title":"Affinity Snapping","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Affinity-Snapping","role":"pseudoSymbol","kind":"section"},"doc://Sliders/tutorials/Sliders/LSlider-Basics#Tick-Marks":{"url":"\/tutorials\/sliders\/lslider-basics#Tick-Marks","abstract":[{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","type":"reference"},{"text":" is a fully stylable linear slider that can be placed at any angle.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"In this tutorial you’ll explore every configuration option the default style offers —"},{"text":" ","type":"text"},{"text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with","type":"text"},{"type":"text","text":" "},{"text":"custom labels.","type":"text"}],"type":"section","title":"Tick Marks","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Tick-Marks","role":"pseudoSymbol","kind":"section"},"doc://Sliders/tutorials/Sliders/LSlider-Basics":{"url":"\/tutorials\/sliders\/lslider-basics","title":"Using LSlider with the Default Style","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics","abstract":[{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","type":"reference","isActive":true},{"type":"text","text":" is a fully stylable linear slider that can be placed at any angle."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore every configuration option the default style offers —"},{"type":"text","text":" "},{"type":"text","text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with"},{"type":"text","text":" "},{"text":"custom labels.","type":"text"}],"type":"topic","kind":"project","estimatedTime":"20min","role":"project"},"LSlider_Advanced_Step_1.swift":{"highlights":[],"type":"file","fileType":"swift","identifier":"LSlider_Advanced_Step_1.swift","fileName":"MyLSliderStyle.swift","content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            .fill(Color.gray.opacity(0.4))","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(width: 4, height: 4)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        LSlider($value, range: 0...1, keepThumbInTrack: true, trackThickness: 20)","            .linearSliderStyle(MyLSliderStyle())","            .frame(height: 60)","            .padding()","    }","}"],"syntax":"swift"},"LSlider_Advanced_Step_5.png":{"identifier":"LSlider_Advanced_Step_5.png","variants":[{"url":"\/images\/Sliders\/LSlider_Advanced_Step_5.png","traits":["1x","light"]}],"type":"image","alt":"Indigo rounded-rectangle label appearing above the thumb"},"doc://Sliders/tutorials/LSlider-Tutorials/Using-the-Default-Style":{"title":"Using the Default Style","abstract":[],"kind":"article","identifier":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Using-the-Default-Style","type":"topic","role":"article","url":"\/tutorials\/lslider-tutorials\/using-the-default-style"},"LSlider_Advanced_Step_4.png":{"type":"image","alt":"Indigo circles growing as the thumb passes over them","variants":[{"traits":["1x","light"],"url":"\/images\/Sliders\/LSlider_Advanced_Step_4.png"}],"identifier":"LSlider_Advanced_Step_4.png"},"LSlider_Advanced_Step_2.swift":{"content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(width: 4, height: 4)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        LSlider($value, range: 0...1, keepThumbInTrack: true, trackThickness: 20)","            .linearSliderStyle(MyLSliderStyle())","            .frame(height: 60)","            .padding()","    }","}"],"identifier":"LSlider_Advanced_Step_2.swift","syntax":"swift","type":"file","fileType":"swift","fileName":"MyLSliderStyle.swift","highlights":[]},"doc://Sliders/tutorials/LSlider-Tutorials":{"role":"overview","title":"Building Sliders with LSlider","identifier":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials","abstract":[{"text":"Learn how to add a spatially adaptive linear slider to your app — starting with the","type":"text"},{"text":" ","type":"text"},{"text":"built-in default style and its full range of configuration options, then advancing to","type":"text"},{"text":" ","type":"text"},{"text":"building a completely custom style from scratch.","type":"text"}],"kind":"overview","url":"\/tutorials\/lslider-tutorials","type":"top