{"kind":"project","identifier":{"url":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"categoryPathComponent":"LSlider-Tutorials","category":"LSlider","role":"project","title":"Building a Custom LSlider Style"},"sections":[{"title":"Building a Custom LSlider Style","content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"text":"In this tutorial you’ll build ","type":"text"},{"type":"codeVoice","code":"MyLSliderStyle"},{"type":"text","text":" from scratch — implementing each"},{"type":"text","text":" "},{"text":"protocol method one at a time — and applying the finished style to both horizontal","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and diagonal sliders."}],"type":"paragraph"}],"image":"LSlider_Advanced_Step_6.png","chapter":"Creating a Custom Style","kind":"hero","estimatedTimeInMinutes":20,"backgroundImage":"LSlider_Advanced_Step_6.png"},{"tasks":[{"stepsSection":[{"runtimePreview":"LSlider_Advanced_Step_1.png","code":"LSlider_Advanced_Step_1.swift","content":[{"inlineContent":[{"type":"text","text":"Create a new Swift file and declare "},{"code":"MyLSliderStyle","type":"codeVoice"},{"type":"text","text":" as a "},{"code":"struct","type":"codeVoice"},{"text":" that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"conforms to "},{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","isActive":true},{"type":"text","text":".  Provide placeholder bodies for all four"},{"text":" ","type":"text"},{"text":"required methods — ","type":"text"},{"type":"codeVoice","code":"makeThumb"},{"text":", ","type":"text"},{"code":"makeTrack","type":"codeVoice"},{"text":", ","type":"text"},{"code":"makeTickMark","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"code":"makeLabel","type":"codeVoice"},{"text":" — so the project compiles while you iterate.","type":"text"}],"type":"paragraph"}],"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"Apply the style with ","type":"text"},{"type":"codeVoice","code":".linearSliderStyle(MyLSliderStyle())"},{"text":" to see it","type":"text"},{"text":" ","type":"text"},{"text":"immediately in the preview.","type":"text"}]}],"media":null}],"title":"Declaring the Style","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Start by creating a struct that conforms to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","type":"reference"},{"type":"text","text":".  The protocol"},{"type":"text","text":" "},{"type":"text","text":"requires four methods; you’ll add stub implementations first to make the code"},{"type":"text","text":" "},{"text":"compile, then flesh each one out in the following sections.","type":"text"}]}],"mediaPosition":"trailing","kind":"contentAndMedia","media":"LSlider_Advanced_Step_1.png"}],"anchor":"Declaring-the-Style"},{"anchor":"Implementing-makeTrack","title":"Implementing makeTrack","contentSection":[{"media":"LSlider_Advanced_Step_2.png","kind":"contentAndMedia","content":[{"inlineContent":[{"text":"The track is the backbone of the slider.  It consists of two layered","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine","type":"reference","isActive":true},{"type":"text","text":" shapes: a dim background and a filled foreground that"},{"type":"text","text":" "},{"type":"text","text":"grows with "},{"type":"codeVoice","code":"pctFill"},{"type":"text","text":"."}],"type":"paragraph"}],"mediaPosition":"trailing"}],"stepsSection":[{"runtimePreview":"LSlider_Advanced_Step_2.png","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"code":"configuration.pctFill","type":"codeVoice"},{"type":"text","text":" for the fill percentage and"},{"type":"text","text":" "},{"type":"codeVoice","code":"configuration.keepThumbInTrack"},{"type":"text","text":" to compute the correct "},{"type":"codeVoice","code":"adjustmentForThumb"},{"type":"text","text":" "},{"type":"text","text":"so the fill always ends under the thumb’s centre."}]}],"media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Replace the stub ","type":"text"},{"code":"makeTrack","type":"codeVoice"},{"text":" body.  Layer two ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine"},{"type":"text","text":" shapes in a"},{"type":"text","text":" "},{"type":"codeVoice","code":"ZStack"},{"type":"text","text":": one as the empty background and one as the filled foreground."},{"type":"text","text":" "},{"text":"Mask the filled portion so it stays within the capsule.","type":"text"}]}],"type":"step","code":"LSlider_Advanced_Step_2.swift"}]},{"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"The thumb needs to communicate three states visually: normal, active (while","type":"text"},{"text":" ","type":"text"},{"text":"dragging), and disabled.  Use ","type":"text"},{"type":"codeVoice","code":"configuration.isActive"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"configuration.isDisabled","type":"codeVoice"},{"type":"text","text":" to drive color and shadow changes."}]}],"media":"LSlider_Advanced_Step_3.png"}],"stepsSection":[{"caption":[{"type":"paragraph","inlineContent":[{"text":"Pick the fill color based on ","type":"text"},{"type":"codeVoice","code":"isDisabled"},{"type":"text","text":" → "},{"code":"isActive","type":"codeVoice"},{"text":", and add a shadow","type":"text"},{"text":" ","type":"text"},{"text":"whose radius expands when the thumb is active to give a lifted feel.  Wrap","type":"text"},{"text":" ","type":"text"},{"text":"the color and shadow in an ","type":"text"},{"code":".animation","type":"codeVoice"},{"text":" so the transition is smooth.","type":"text"}]}],"code":"LSlider_Advanced_Step_3.swift","type":"step","runtimePreview":"LSlider_Advanced_Step_3.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Replace the stub "},{"type":"codeVoice","code":"makeThumb"},{"type":"text","text":" body.  Size the "},{"type":"codeVoice","code":"Circle"},{"type":"text","text":" from"},{"type":"text","text":" "},{"type":"codeVoice","code":"configuration.trackThickness"},{"text":" (double it for a standard thumb diameter).","type":"text"}]}],"media":null}],"anchor":"Implementing-makeThumb","title":"Implementing makeThumb"},{"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"Tick marks should react to the thumb’s proximity — growing and brightening as","type":"text"},{"text":" ","type":"text"},{"text":"the thumb approaches.  ","type":"text"},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderConfiguration","isActive":true,"type":"reference"},{"text":" provides ","type":"text"},{"code":"value","type":"codeVoice"},{"text":", ","type":"text"},{"code":"min","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"code":"max","type":"codeVoice"},{"text":" so you can compute a normalised distance.","type":"text"}]}],"media":"LSlider_Advanced_Step_4.png"}],"title":"Implementing makeTickMark","stepsSection":[{"code":"LSlider_Advanced_Step_4.swift","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"proximity"},{"type":"text","text":" to interpolate both the circle’s "},{"type":"codeVoice","code":"size"},{"type":"text","text":" and its "},{"type":"codeVoice","code":"opacity"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and wrap the result in "},{"type":"codeVoice","code":".animation(.easeOut)"},{"type":"text","text":" so it feels responsive."}]}],"content":[{"inlineContent":[{"text":"Replace the stub ","type":"text"},{"type":"codeVoice","code":"makeTickMark"},{"type":"text","text":" body.  Compute the normalised positions of"},{"type":"text","text":" "},{"type":"text","text":"the thumb ("},{"type":"codeVoice","code":"thumbPct"},{"type":"text","text":") and the tick mark ("},{"type":"codeVoice","code":"tickPct"},{"type":"text","text":") in the "},{"type":"codeVoice","code":"0…1"},{"type":"text","text":" space,"},{"type":"text","text":" "},{"type":"text","text":"then derive a "},{"type":"codeVoice","code":"proximity"},{"type":"text","text":" value between "},{"type":"codeVoice","code":"0"},{"type":"text","text":" (far) and "},{"type":"codeVoice","code":"1"},{"type":"text","text":" (on top)."}],"type":"paragraph"}],"runtimePreview":"LSlider_Advanced_Step_4.png","type":"step","media":null}],"anchor":"Implementing-makeTickMark"},{"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","media":"LSlider_Advanced_Step_5.png","content":[{"type":"paragraph","inlineContent":[{"text":"The floating label container wraps the caller-provided content view.  Override","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"makeLabel"},{"text":" to brand it with the same indigo palette and give it a spring","type":"text"},{"text":" ","type":"text"},{"text":"entrance\/exit animation tied to ","type":"text"},{"type":"codeVoice","code":"isActive"},{"type":"text","text":"."}]}]}],"anchor":"Implementing-makeLabel","title":"Implementing makeLabel","stepsSection":[{"runtimePreview":"LSlider_Advanced_Step_5.png","caption":[{"type":"paragraph","inlineContent":[{"text":"Drive ","type":"text"},{"code":"scaleEffect","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"opacity","type":"codeVoice"},{"text":" from ","type":"text"},{"code":"configuration.isActive","type":"codeVoice"},{"text":" — the label","type":"text"},{"text":" ","type":"text"},{"text":"springs in when the user starts dragging and fades away when they lift their","type":"text"},{"text":" ","type":"text"},{"text":"finger.","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"Implement ","type":"text"},{"code":"makeLabel(configuration:content:)","type":"codeVoice"},{"text":".  Wrap the ","type":"text"},{"code":"content","type":"codeVoice"},{"text":" view in","type":"text"},{"text":" ","type":"text"},{"text":"horizontal and vertical padding, then apply a ","type":"text"},{"code":"RoundedRectangle","type":"codeVoice"},{"text":" background","type":"text"},{"text":" ","type":"text"},{"text":"filled with indigo and a drop shadow.","type":"text"}]}],"media":null,"type":"step","code":"LSlider_Advanced_Step_5.swift"}]},{"title":"Applying the Finished Style","contentSection":[{"mediaPosition":"trailing","media":"LSlider_Advanced_Step_6.png","content":[{"inlineContent":[{"type":"text","text":"With all four methods complete, apply "},{"type":"codeVoice","code":"MyLSliderStyle"},{"text":" to a range of sliders —","type":"text"},{"text":" ","type":"text"},{"text":"horizontal, diagonal, with tick marks and affinity — to confirm everything works","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"together."}],"type":"paragraph"}],"kind":"contentAndMedia"}],"stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Apply ","type":"text"},{"code":".linearSliderStyle(MyLSliderStyle())","type":"codeVoice"},{"text":" to both a horizontal slider","type":"text"},{"text":" ","type":"text"},{"text":"(with tick marks and affinity) and a diagonal slider.  The style adapts","type":"text"},{"text":" ","type":"text"},{"text":"automatically to any angle and thickness thanks to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine","type":"reference"},{"type":"text","text":"."}]}],"media":null,"code":"LSlider_Advanced_Step_6.swift","caption":[],"type":"step","runtimePreview":"LSlider_Advanced_Step_6.png"}],"anchor":"Applying-the-Finished-Style"}],"kind":"tasks"}],"hierarchy":{"modules":[{"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Using-the-Default-Style","projects":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics","sections":[{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Basic-Usage"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Tick-Marks"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Affinity-Snapping"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Interaction-Labels-Accessibility"}]}]},{"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Creating-a-Custom-Style","projects":[{"reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced","sections":[{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Declaring-the-Style"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTrack"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeThumb"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTickMark"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeLabel"},{"kind":"task","reference":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Applying-the-Finished-Style"}]}]}],"paths":[["doc:\/\/Sliders\/tutorials\/LSlider-Tutorials","doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/$volume","doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Creating-a-Custom-Style"]],"reference":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials"},"variants":[{"paths":["\/tutorials\/sliders\/lslider-advanced"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://Sliders/tutorials/Sliders/