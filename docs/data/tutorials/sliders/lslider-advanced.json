"abstract":[{"type":"text","text":"A value type describing the current state of an "},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"topic","url":"\/documentation\/sliders\/lsliderconfiguration","title":"LSliderConfiguration","kind":"symbol","navigatorTitle":[{"text":"LSliderConfiguration","kind":"identifier"}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"LSliderConfiguration","kind":"identifier"}],"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderConfiguration"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Implementing-makeTrack":{"abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll build "},{"code":"MyLSliderStyle","type":"codeVoice"},{"text":" from scratch — implementing each","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"protocol method one at a time — and applying the finished style to both horizontal"},{"type":"text","text":" "},{"text":"and diagonal sliders.","type":"text"}],"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeTrack","url":"\/tutorials\/sliders\/lslider-advanced#Implementing-makeTrack","title":"Implementing makeTrack","role":"pseudoSymbol","kind":"section","type":"section"},"LSlider_Advanced_Step_3.swift":{"syntax":"swift","fileName":"MyLSliderStyle.swift","fileType":"swift","identifier":"LSlider_Advanced_Step_3.swift","content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled","            ? Color.gray","            : (configuration.isActive ? Color.white : Color.indigo)","        return Circle()","            .fill(color)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","            .shadow(","                color: .black.opacity(configuration.isDisabled ? 0 : 0.2),","                radius: configuration.isActive ? 6 : 2","            )","            .animation(.easeOut(duration: 0.12), value: configuration.isActive)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        Circle()","            .fill(Color.gray)","            .frame(width: 4, height: 4)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        VStack(spacing: 20) {","            LSlider($value, range: 0...1, keepThumbInTrack: true, trackThickness: 20)","                .linearSliderStyle(MyLSliderStyle())","                .frame(height: 60)","            LSlider($value, range: 0...1, keepThumbInTrack: true, trackThickness: 20)","                .linearSliderStyle(MyLSliderStyle())","                .disabled(true)","                .frame(height: 60)","        }","        .padding()","    }","}"],"type":"file","highlights":[]},"LSlider_Advanced_Step_6.png":{"alt":"Horizontal and diagonal sliders using MyLSliderStyle","identifier":"LSlider_Advanced_Step_6.png","type":"image","variants":[{"url":"\/images\/Sliders\/LSlider_Advanced_Step_6.png","traits":["1x","light"]}]},"doc://Sliders/tutorials/LSlider-Tutorials":{"abstract":[{"type":"text","text":"Learn how to add a spatially adaptive linear slider to your app — starting with the"},{"text":" ","type":"text"},{"text":"built-in default style and its full range of configuration options, then advancing to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"building a completely custom style from scratch."}],"type":"topic","url":"\/tutorials\/lslider-tutorials","title":"Building Sliders with LSlider","kind":"overview","role":"overview","identifier":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials"},"LSlider_Advanced_Step_4.swift":{"type":"file","highlights":[],"identifier":"LSlider_Advanced_Step_4.swift","fileName":"MyLSliderStyle.swift","content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled","            ? Color.gray","            : (configuration.isActive ? Color.white : Color.indigo)","        return Circle()","            .fill(color)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","            .shadow(","                color: .black.opacity(configuration.isDisabled ? 0 : 0.2),","                radius: configuration.isActive ? 6 : 2","            )","            .animation(.easeOut(duration: 0.12), value: configuration.isActive)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let distance  = abs(thumbPct - tickPct)","        let proximity = max(0, 1 - distance \/ 0.15)","","        let size    = 5.0 + 7.0 * proximity","        let opacity = 0.3 + 0.7 * proximity","","        return Circle()","            .fill(Color.indigo.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        VStack(spacing: 8) {","            LSlider(","                $value,","                range: 0...1,","                keepThumbInTrack: true,","                trackThickness: 20,","                tickMarkSpacing: .count(11)","            )","            .linearSliderStyle(MyLSliderStyle())","            .frame(height: 60)","            Text(\"Value: \\(value, specifier: \"%.2f\")\")","                .font(.caption)","        }","        .padding()","    }","}"],"fileType":"swift","syntax":"swift"},"LSlider_Advanced_Step_1.png":{"alt":"Gray stub slider confirming the style is wired up","identifier":"LSlider_Advanced_Step_1.png","type":"image","variants":[{"url":"\/images\/Sliders\/LSlider_Advanced_Step_1.png","traits":["1x","light"]}]},"doc://Sliders/tutorials/Sliders/LSlider-Basics#Tick-Marks":{"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Tick-Marks","role":"pseudoSymbol","type":"section","kind":"section","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider"},{"text":" is a fully stylable linear slider that can be placed at any angle.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore every configuration option the default style offers —"},{"type":"text","text":" "},{"type":"text","text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with"},{"type":"text","text":" "},{"type":"text","text":"custom labels."}],"url":"\/tutorials\/sliders\/lslider-basics#Tick-Marks","title":"Tick Marks"},"doc://Sliders/tutorials/LSlider-Tutorials/Creating-a-Custom-Style":{"identifier":"doc:\/\/Sliders\/tutorials\/LSlider-Tutorials\/Creating-a-Custom-Style","role":"article","type":"topic","kind":"article","abstract":[],"url":"\/tutorials\/lslider-tutorials\/creating-a-custom-style","title":"Creating a Custom Style"},"doc://Sliders/tutorials/Sliders/LSlider-Basics#Affinity-Snapping":{"identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics#Affinity-Snapping","role":"pseudoSymbol","type":"section","kind":"section","abstract":[{"isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","type":"reference"},{"text":" is a fully stylable linear slider that can be placed at any angle.","type":"text"},{"text":" ","type":"text"},{"type"