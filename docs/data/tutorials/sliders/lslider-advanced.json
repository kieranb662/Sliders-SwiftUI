g-the-Style","type":"section","kind":"section"},"LSlider_Advanced_Step_6.png":{"alt":"Horizontal and diagonal sliders using MyLSliderStyle","type":"image","identifier":"LSlider_Advanced_Step_6.png","variants":[{"url":"\/images\/Sliders\/LSlider_Advanced_Step_6.png","traits":["1x","light"]}]},"LSlider_Advanced_Step_3.png":{"type":"image","variants":[{"url":"\/images\/Sliders\/LSlider_Advanced_Step_3.png","traits":["1x","light"]}],"alt":"Thumb changing color between active and disabled states","identifier":"LSlider_Advanced_Step_3.png"},"doc://Sliders/tutorials/Sliders/LSlider-Basics":{"url":"\/tutorials\/sliders\/lslider-basics","estimatedTime":"20min","type":"topic","kind":"project","title":"Using LSlider with the Default Style","abstract":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSlider","isActive":true},{"type":"text","text":" is a fully stylable linear slider that can be placed at any angle."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll explore every configuration option the default style offers —"},{"type":"text","text":" "},{"type":"text","text":"from a minimal one-liner to diagonal, tick-marked, affinity-snapping sliders with"},{"type":"text","text":" "},{"type":"text","text":"custom labels."}],"role":"project","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Basics"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced#Implementing-makeLabel":{"url":"\/tutorials\/sliders\/lslider-advanced#Implementing-makeLabel","type":"section","kind":"section","title":"Implementing makeLabel","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"type":"text","text":" lets you take full control of every visual element of the slider."},{"type":"text","text":" "},{"type":"text","text":"In this tutorial you’ll build "},{"code":"MyLSliderStyle","type":"codeVoice"},{"type":"text","text":" from scratch — implementing each"},{"type":"text","text":" "},{"type":"text","text":"protocol method one at a time — and applying the finished style to both horizontal"},{"type":"text","text":" "},{"type":"text","text":"and diagonal sliders."}],"role":"pseudoSymbol","identifier":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced#Implementing-makeLabel"},"LSlider_Advanced_Step_4.swift":{"type":"file","content":["import SwiftUI","","struct MyLSliderStyle: LSliderStyle {","","    func makeThumb(configuration: LSliderConfiguration) -> some View {","        let color: Color = configuration.isDisabled","            ? Color.gray","            : (configuration.isActive ? Color.white : Color.indigo)","        return Circle()","            .fill(color)","            .frame(","                width: configuration.trackThickness * 2,","                height: configuration.trackThickness * 2","            )","            .shadow(","                color: .black.opacity(configuration.isDisabled ? 0 : 0.2),","                radius: configuration.isActive ? 6 : 2","            )","            .animation(.easeOut(duration: 0.12), value: configuration.isActive)","    }","","    func makeTrack(configuration: LSliderConfiguration) -> some View {","        let adjustment: Double = configuration.keepThumbInTrack","            ? configuration.trackThickness * (1 - configuration.pctFill)","            : configuration.trackThickness \/ 2","","        return ZStack {","            AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","                .fill(Color.indigo.opacity(0.25))","            AdaptiveLine(","                thickness: configuration.trackThickness,","                angle: configuration.angle,","                percentFilled: configuration.pctFill,","                adjustmentForThumb: adjustment","            )","            .fill(Color.indigo)","            .mask(","                AdaptiveLine(thickness: configuration.trackThickness, angle: configuration.angle)","            )","        }","    }","","    func makeTickMark(configuration: LSliderConfiguration, tickValue: Double) -> some View {","        let range = configuration.max - configuration.min","        let thumbPct = range > 0 ? (configuration.value - configuration.min) \/ range : 0","        let tickPct  = range > 0 ? (tickValue - configuration.min) \/ range : 0","        let distance  = abs(thumbPct - tickPct)","        let proximity = max(0, 1 - distance \/ 0.15)","","        let size    = 5.0 + 7.0 * proximity","        let opacity = 0.3 + 0.7 * proximity","","        return Circle()","            .fill(Color.indigo.opacity(opacity))","            .frame(width: size, height: size)","            .animation(.easeOut(duration: 0.1), value: proximity)","    }","}","","struct ContentView: View {","    @State private var value = 0.5","","    var body: some View {","        VStack(spacing: 8) {","            LSlider(","                $value,","                range: 0...1,","                keepThumbInTrack: true,","                trackThickness: 20,","                tickMarkSpacing: .count(11)","            )","            .linearSliderStyle(MyLSliderStyle())","            .frame(height: 60)","            Text(\"Value: \\(value, specifier: \"%.2f\")\")","                .font(.caption)","        }","        .padding()","    }","}"],"fileName":"MyLSliderStyle.swift","fileType":"swift","highlights":[],"syntax":"swift","identifier":"LSlider_Advanced_Step_4.swift"},"doc://Sliders/tutorials/Sliders/LSlider-Advanced":{"role":"project","title":"Building a Custom LSlider Style","abstract":[{"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","isActive":true},{"text":" lets you take full control of every visual element of the slider.","type":"text"},{"type":"text","text":" "},{"text":"In this tutorial you’ll build ","type":"text"},{"code":"MyLSliderStyle","type":"codeVoice"},{"type":"text","text":" from scratch — implementing each"},{"type":"text","text":" "},{"t