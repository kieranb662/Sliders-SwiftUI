iew":"LSlider_Advanced_Step_2.png","caption":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":"configuration.pctFill","type":"codeVoice"},{"text":" for the fill percentage and","type":"text"},{"text":" ","type":"text"},{"code":"configuration.keepThumbInTrack","type":"codeVoice"},{"text":" to compute the correct ","type":"text"},{"type":"codeVoice","code":"adjustmentForThumb"},{"type":"text","text":" "},{"text":"so the fill always ends under the thumb’s centre.","type":"text"}]}]}],"title":"Implementing makeTrack","anchor":"Implementing-makeTrack"},{"contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The thumb needs to communicate three states visually: normal, active (while"},{"text":" ","type":"text"},{"type":"text","text":"dragging), and disabled.  Use "},{"type":"codeVoice","code":"configuration.isActive"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"configuration.isDisabled"},{"type":"text","text":" to drive color and shadow changes."}]}],"mediaPosition":"trailing","kind":"contentAndMedia","media":"LSlider_Advanced_Step_3.png"}],"anchor":"Implementing-makeThumb","title":"Implementing makeThumb","stepsSection":[{"content":[{"inlineContent":[{"text":"Replace the stub ","type":"text"},{"code":"makeThumb","type":"codeVoice"},{"text":" body.  Size the ","type":"text"},{"code":"Circle","type":"codeVoice"},{"text":" from","type":"text"},{"text":" ","type":"text"},{"code":"configuration.trackThickness","type":"codeVoice"},{"text":" (double it for a standard thumb diameter).","type":"text"}],"type":"paragraph"}],"caption":[{"inlineContent":[{"type":"text","text":"Pick the fill color based on "},{"code":"isDisabled","type":"codeVoice"},{"text":" → ","type":"text"},{"code":"isActive","type":"codeVoice"},{"type":"text","text":", and add a shadow"},{"type":"text","text":" "},{"type":"text","text":"whose radius expands when the thumb is active to give a lifted feel.  Wrap"},{"type":"text","text":" "},{"text":"the color and shadow in an ","type":"text"},{"code":".animation","type":"codeVoice"},{"type":"text","text":" so the transition is smooth."}],"type":"paragraph"}],"media":null,"code":null,"runtimePreview":"LSlider_Advanced_Step_3.png","type":"step"}]},{"anchor":"Implementing-makeTickMark","stepsSection":[{"runtimePreview":"LSlider_Advanced_Step_4.png","type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"proximity"},{"type":"text","text":" to interpolate both the circle’s "},{"type":"codeVoice","code":"size"},{"text":" and its ","type":"text"},{"code":"opacity","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"and wrap the result in ","type":"text"},{"code":".animation(.easeOut)","type":"codeVoice"},{"text":" so it feels responsive.","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"Replace the stub ","type":"text"},{"type":"codeVoice","code":"makeTickMark"},{"type":"text","text":" body.  Compute the normalised positions of"},{"text":" ","type":"text"},{"type":"text","text":"the thumb ("},{"code":"thumbPct","type":"codeVoice"},{"text":") and the tick mark (","type":"text"},{"code":"tickPct","type":"codeVoice"},{"text":") in the ","type":"text"},{"code":"0…1","type":"codeVoice"},{"type":"text","text":" space,"},{"type":"text","text":" "},{"type":"text","text":"then derive a "},{"type":"codeVoice","code":"proximity"},{"type":"text","text":" value between "},{"code":"0","type":"codeVoice"},{"type":"text","text":" (far) and "},{"code":"1","type":"codeVoice"},{"type":"text","text":" (on top)."}]}],"media":null,"code":null}],"title":"Implementing makeTickMark","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Tick marks should react to the thumb’s proximity — growing and brightening as","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the thumb approaches.  "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderConfiguration"},{"text":" provides ","type":"text"},{"code":"value","type":"codeVoice"},{"text":", ","type":"text"},{"code":"min","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"max"},{"type":"text","text":" so you can compute a normalised distance."}]}],"media":"LSlider_Advanced_Step_4.png","mediaPosition":"trailing","kind":"contentAndMedia"}]},{"anchor":"Implementing-makeLabel","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The floating label container wraps the caller-provided content view.  Override"},{"type":"text","text":" "},{"code":"makeLabel","type":"codeVoice"},{"text":" to brand it with the same indigo palette and give it a spring","type":"text"},{"type":"text","text":" "},{"text":"entrance\/exit animation tied to ","type":"text"},{"type":"codeVoice","code":"isActive"},{"text":".","type":"text"}]}],"kind":"contentAndMedia","media":"LSlider_Advanced_Step_5.png","mediaPosition":"trailing"}],"stepsSection":[{"runtimePreview":"LSlider_Advanced_Step_5.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement "},{"type":"codeVoice","code":"makeLabel(configuration:content:)"},{"type":"text","text":".  Wrap the "},{"type":"codeVoice","code":"content"},{"type":"text","text":" view in"},{"text":" ","type":"text"},{"type":"text","text":"horizontal and vertical padding, then apply a "},{"type":"codeVoice","code":"RoundedRectangle"},{"type":"text","text":" background"},{"type":"text","text":" "},{"type":"text","text":"filled with indigo and a drop shadow."}]}],"type":"step","media":null,"code":null,"caption":[{"inlineContent":[{"text":"Drive ","type":"text"},{"type":"codeVoice","code":"scaleEffect"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"opacity"},{"type":"text","text":" from "},{"type":"codeVoice","code":"configuration.isActive"},{"type":"text","text":" — the label"},{"text":" ","type":"text"},{"type":"text","text":"springs in when the user starts dragging and fades away when they lift their"},{"text":" ","type":"text"},{"type":"text","text":"finger."}],"type":"paragraph"}]}],"title":"Implementing makeLabel"},{"contentSection":[{"media":"LSlider_Advanced_Step_6.png","mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"With all four methods complete, apply "},{"code":"MyLSliderStyle","type":"codeVoice"},{"type":"text","text":" to a range of sliders —"},{"type":"text","text":" "},{"text":"horizontal, diagonal, with tick marks and affinity — to confirm everything works","type":"text"},{"type":"text","text":" "},{"text":"together.","type":"text"}],"type":"paragraph"}]}],"anchor":"Applying-the-Finished-Style","stepsSection":[{"type":"step","caption":[],"code":null,"runtimePreview":"LSlider_Advanced_Step_6.png","media":null,"content":[{"inlineContent":[{"text":"Apply ","type":"text"},{"type":"codeVoice","code":".linearSliderStyle(MyLSliderStyle())"},{"text":" to both a horizontal slider","type":"text"},{"text":" ","type":"text"},{"text":"(with tick marks and affinity) and a diagonal slider.  The style adapts","type":"text"},{"text":" ","type":"text"},{"text":"automatically to any angle and thickness thanks to ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/AdaptiveLine"},{"type":"text","text":"."}],"type":"paragraph"}]}],"title":"Applying the Finished Style"},{"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"SwiftUI’s built-in styles are applied with dot syntax (e.g. "},{"type":"codeVoice","code":".linearSliderStyle(.default)"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"You can give your own style the same ergonomic API by adding a constrained"},{"type":"text","text":" "},{"type":"text","text":"extension on "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle"},{"type":"text","text":"."}]}]}],"stepsSection":[{"type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now you can write "},{"type":"codeVoice","code":".linearSliderStyle(.myLSliderStyle)"},{"type":"text","text":" anywhere in your"},{"type":"text","text":" "},{"type":"text","text":"app, just like the built-in "},{"type":"codeVoice","code":".default"},{"type":"text","text":" preset."}]}],"media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add an extension on "},{"identifier":"doc:\/\/Sliders\/documentation\/Sliders\/LSliderStyle","type":"reference","isActive":true},{"type":"text","text":" constrained to "},{"type":"codeVoice","code":"Self == MyLSliderStyle"},{"type":"text","text":" "},{"type":"text","text":"and expose a static "},{"type":"codeVoice","code":"myLSliderStyle"},{"type":"text","text":" property that returns a fresh instance."}]}],"code":null,"runtimePreview":null}],"title":"Exposing a Static Preset","anchor":"Exposing-a-Static-Preset"}]}],"identifier":{"url":"doc:\/\/Sliders\/tutorials\/Sliders\/LSlider-Advanced","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/sliders\/lslider-advanced"]}],"kind":"project","metadata":{"category":"LSlider","role":"project","title":"Building a Custom LSlider Style","categoryPathComponent":"LSlider-Tutorials"},"references":{"LSlider_Advanced_Step_1.png":{"alt":"Gray stub slider confirming the style is wired up","variants":[{"url":"\/images\/Sliders\/LSlider_Advanced_Step_1.png","traits":["1x","light"]}],"type":"image","identifier":"LSlider_Advanced_Step_1.png"},"doc://Sliders/tutorials/LSlider-Tutorials/Creating-a-Custom-Style":{"kind":"article","abstract":[],"url":"\/tutorials\/lslider-tutorials\/creating-a-custom-style","title":"Creating a Custom Style","ide